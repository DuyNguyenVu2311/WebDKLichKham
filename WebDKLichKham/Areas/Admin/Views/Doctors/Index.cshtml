@model IEnumerable<WebDKLichKham.Models.Doctor>
@{
    ViewData["Title"] = "Quản lý bác sĩ";
}

<div class="max-w-[1280px] mx-auto px-4 md:px-8 py-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-[#00346f] text-[28px]">stethoscope</span>
                <h1 class="text-[28px] font-bold text-[#0b1c30]">Quản lý bác sĩ</h1>
            </div>
            <p class="text-[14px] text-gray-500">Danh sách đội ngũ bác sĩ tại phòng khám — @Model.Count() bác sĩ đang hoạt động.</p>
        </div>
        <a class="px-4 py-2.5 border border-gray-300 text-gray-600 rounded-lg text-[13px] font-semibold hover:bg-gray-50 transition-colors no-underline flex items-center gap-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span> Về tổng quan
        </a>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-100 flex items-center gap-3">
            <div class="w-9 h-9 bg-[#f0f4fa] rounded-lg flex items-center justify-center">
                <span class="material-symbols-outlined text-[#00346f] text-[20px]">badge</span>
            </div>
            <div>
                <h2 class="text-[18px] font-bold text-[#0b1c30]">Danh sách bác sĩ</h2>
                <p class="text-[12px] text-gray-400">Phân loại theo chuyên khoa và cơ sở làm việc</p>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-[14px]">
                <thead class="bg-[#f8fafc]">
                    <tr>
                        <th class="text-left px-6 py-3 font-semibold text-[12px] text-gray-500 uppercase tracking-wider">Họ tên</th>
                        <th class="text-left px-6 py-3 font-semibold text-[12px] text-gray-500 uppercase tracking-wider">Chuyên khoa</th>
                        <th class="text-left px-6 py-3 font-semibold text-[12px] text-gray-500 uppercase tracking-wider">Học vị</th>
                        <th class="text-left px-6 py-3 font-semibold text-[12px] text-gray-500 uppercase tracking-wider">Kinh nghiệm</th>
                        <th class="text-left px-6 py-3 font-semibold text-[12px] text-gray-500 uppercase tracking-wider">Cơ sở</th>
                        <th class="text-left px-6 py-3 font-semibold text-[12px] text-gray-500 uppercase tracking-wider">Phí khám</th>
                        <th class="text-left px-6 py-3 font-semibold text-[12px] text-gray-500 uppercase tracking-wider">Trạng thái</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var doctor in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 bg-gradient-to-br from-[#00346f] to-[#004a99] rounded-lg flex items-center justify-center text-white text-[11px] font-bold shrink-0">
                                        @doctor.FullName.Split(' ').LastOrDefault()?[..1]@(doctor.FullName.Split(' ').Length > 1 ? doctor.FullName.Split(' ')[^2][..1] : "")
                                    </div>
                                    <div>
                                        <div class="font-semibold text-[#0b1c30]">@doctor.FullName</div>
                                        <div class="text-[12px] text-gray-400">@doctor.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2.5 py-1 bg-[#f0f4fa] text-[#00346f] rounded-full text-[12px] font-semibold">@doctor.Specialty</span>
                            </td>
                            <td class="px-6 py-4 text-gray-600">@doctor.Qualification</td>
                            <td class="px-6 py-4 text-gray-600">@doctor.ExperienceYears năm</td>
                            <td class="px-6 py-4 text-[13px] text-gray-600">@doctor.Workplace</td>
                            <td class="px-6 py-4 font-semibold text-teal-700">@doctor.Fee.ToString("N0")đ</td>
                            <td class="px-6 py-4">
                                @if (doctor.IsActive)
                                {
                                    <span class="px-3 py-1 bg-green-50 text-green-700 border border-green-200 rounded-full text-[11px] font-bold">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 bg-gray-100 text-gray-500 border border-gray-200 rounded-full text-[11px] font-bold">Tạm dừng</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>
