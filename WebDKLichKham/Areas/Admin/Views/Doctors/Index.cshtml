@model IEnumerable<WebDKLichKham.Models.Doctor>
@{
    ViewData["Title"] = "Quản lý bác sĩ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 mb-1">Quản lý bác sĩ</h1>
        <p class="text-secondary mb-0">Đây là khung danh sách để bạn mở rộng CRUD thêm, sửa, xóa bác sĩ.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Về dashboard</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Họ tên</th>
                    <th>Chuyên khoa</th>
                    <th>Học vị</th>
                    <th>Phí khám</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doctor in Model)
                {
                    <tr>
                        <td>@doctor.FullName</td>
                        <td>@doctor.Specialty</td>
                        <td>@doctor.Qualification</td>
                        <td>@doctor.Fee.ToString("N0") VND</td>
                        <td>@(doctor.IsActive ? "Đang hoạt động" : "Tạm dừng")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
