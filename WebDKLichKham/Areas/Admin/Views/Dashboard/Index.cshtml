@model WebDKLichKham.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Tổng quan quản trị";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 mb-1">Tổng quan quản trị</h1>
        <p class="text-secondary mb-0">Trang khởi đầu cho vai trò admin quản lý phòng khám.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Doctors" asp-action="Index">Quản lý bác sĩ</a>
        <a class="btn btn-primary" asp-area="Admin" asp-controller="Appointments" asp-action="Index">Quản lý lịch khám</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="text-secondary small">Bác sĩ</div><div class="display-6">@Model.TotalDoctors</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="text-secondary small">Bệnh nhân</div><div class="display-6">@Model.TotalPatients</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="text-secondary small">Chờ xác nhận</div><div class="display-6">@Model.PendingAppointments</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="text-secondary small">Đã xác nhận</div><div class="display-6">@Model.ConfirmedAppointments</div></div></div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <h2 class="h4 mb-3">Lịch đặt gần đây</h2>
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Bệnh nhân</th>
                        <th>Bác sĩ</th>
                        <th>Ngày</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RecentAppointments)
                    {
                        <tr>
                            <td>@item.PatientProfile?.FullName</td>
                            <td>@item.Doctor?.FullName</td>
                            <td>@item.AppointmentDate.ToString("dd/MM/yyyy") @item.StartTime.ToString(@"hh\:mm")</td>
                            <td>@item.Status.GetDisplayName()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
