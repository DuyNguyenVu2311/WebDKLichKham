@model WebDKLichKham.Models.ViewModels.AppointmentBookingViewModel
@{
    ViewData["Title"] = "Dịch Vụ & Đặt Lịch";
}

<main class="font-sans bg-white">
        <section class="bg-[#f4f7fc] py-16 border-b border-gray-100">
        <div class="max-w-[800px] mx-auto px-4 text-center">
            <h1 class="text-[36px] font-bold text-[#00346f] mb-4">Dịch vụ y tế &<br/>Đặt lịch khám</h1>
            <p class="text-[16px] text-gray-500 mb-2">Trải nghiệm dịch vụ chăm sóc sức khỏe chất lượng cao với quy trình đặt lịch trực tuyến nhanh chóng và tiện lợi.</p>
        </div>
    </section>

    <div class="max-w-[1280px] mx-auto px-4 md:px-8 pt-8">
        <partial name="_BookingSteps" model="4" />
    </div>

    <section class="max-w-[1280px] mx-auto px-4 md:px-8 py-4 flex flex-col lg:flex-row gap-8">
                <aside class="w-full lg:w-[320px] shrink-0">
            <!-- Tóm tắt lịch khám -->
            <div class="bg-white border border-[#e2e8f0] rounded-xl overflow-hidden shadow-sm mb-6 sticky top-6">
                <div class="bg-[#00346f] p-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-white">receipt_long</span>
                    <h3 class="font-bold text-white text-[16px] m-0">Thông tin đặt khám</h3>
                </div>
                <div class="p-5">
                    <div class="space-y-4">
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-gray-400 text-[20px] mt-0.5">person</span>
                            <div>
                                <p class="text-[12px] text-gray-500 mb-0.5">Bác sĩ</p>
                                <p class="text-[14px] font-bold text-[#1e293b] m-0" id="summaryDoctor">Chưa chọn</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-gray-400 text-[20px] mt-0.5">medical_services</span>
                            <div>
                                <p class="text-[12px] text-gray-500 mb-0.5">Chuyên khoa</p>
                                <p class="text-[14px] font-bold text-[#1e293b] m-0" id="summarySpecialty">Chưa chọn</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-gray-400 text-[20px] mt-0.5">home_health</span>
                            <div>
                                <p class="text-[12px] text-gray-500 mb-0.5">Dịch vụ khám</p>
                                <p class="text-[14px] font-bold text-[#1e293b] m-0" id="summaryService">Chưa chọn</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-gray-400 text-[20px] mt-0.5">calendar_month</span>
                            <div>
                                <p class="text-[12px] text-gray-500 mb-0.5">Thời gian khám</p>
                                <p class="text-[14px] font-bold text-[#1e293b] m-0" id="summaryTime">Chưa chọn</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-gray-400 text-[20px] mt-0.5">payments</span>
                            <div>
                                <p class="text-[12px] text-gray-500 mb-0.5">Phí khám (Dự kiến)</p>
                                <p class="text-[14px] font-bold text-[#e11d48] m-0">Theo giá niêm yết</p>
                                <p class="text-[11px] text-gray-400 m-0 mt-0.5">Thanh toán tại viện</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-blue-50 p-4 border-t border-blue-100">
                    <h4 class="text-[13px] font-bold text-[#1e3a8a] mb-2 flex items-center gap-1.5 m-0">
                        <span class="material-symbols-outlined text-[16px]">info</span> Lưu ý quan trọng
                    </h4>
                    <ul class="text-[12px] text-[#1e3a8a] space-y-1.5 m-0 pl-4 list-disc mt-2">
                        <li>Vui lòng đến trước <strong>15 phút</strong> để làm thủ tục.</li>
                        <li>Mang theo CMND/CCCD và BHYT (nếu có).</li>
                        <li>Lịch khám có thể thay đổi do ca cấp cứu đột xuất.</li>
                    </ul>
                </div>
            </div>

            <div class="bg-[#fce8e6] border border-[#f5c2c7] rounded-lg p-5 shadow-sm">
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 bg-[#c5221f] rounded-lg flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-white text-[24px] font-bold">asterisk</span>
                    </div>
                    <h3 class="text-[#b31412] font-bold text-[16px] m-0">Cấp cứu 24/24</h3>
                </div>
                <p class="text-[#c5221f] text-[13px] mb-4">Gọi ngay hotline nếu bạn đang trong tình trạng khẩn cấp cần hỗ trợ y tế.</p>
                <a href="tel:19001234" class="w-full bg-[#c5221f] text-white py-2.5 rounded-md font-bold text-[14px] hover:bg-[#b31412] transition-colors flex items-center justify-center gap-2 no-underline shadow-sm">
                    <span class="material-symbols-outlined text-[18px]">call</span> 1900 1234
                </a>
            </div>
        </aside>

                <div class="flex-1">
            <div class="bg-white border border-gray-200 rounded-lg p-6 md:p-8 shadow-sm relative overflow-hidden">
                                <div class="absolute top-0 left-0 w-full h-1 bg-[#00346f]"></div>
                
                <div class="mb-8">
                    <p class="text-[12px] font-semibold uppercase tracking-wider mb-2 text-[#008a7b]">BIỂU MẪU ĐĂNG KÝ</p>
                    <h2 class="text-[28px] font-bold text-[#1e293b] mb-2">Thông Tin Đặt Lịch</h2>
                    <p class="text-[14px] text-gray-500">Vui lòng điền đầy đủ thông tin bên dưới. Chúng tôi sẽ xác nhận lịch hẹn của bạn trong thời gian sớm nhất.</p>
                </div>

                <form method="post" class="space-y-8">
                    <div asp-validation-summary="ModelOnly" class="text-red-600 text-[13px] mb-4 bg-red-50 p-3 rounded border border-red-200"></div>

                                        <div>
                        <div class="flex items-center gap-3 mb-4 border-b border-gray-100 pb-3">
                            <div class="w-8 h-8 bg-[#f0f4fa] rounded-full flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-[#00346f] text-[18px]">stethoscope</span>
                            </div>
                            <h3 class="text-[16px] font-bold text-[#00346f]">1. Chọn Cơ Sở & Dịch Vụ</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
                            <div>
                                <label asp-for="Facility" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Cơ sở khám</label>
                                <select asp-for="Facility" id="facilitySelect" class="w-full px-3 py-2.5 rounded border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none bg-white shadow-sm">
                                    <option value="">-- Chọn cơ sở --</option>
                                    <option value="CS1">Cơ sở 1: TP. Thủ Đức</option>
                                    <option value="CS2">Cơ sở 2: Nhơn Trạch</option>
                                </select>
                                <span asp-validation-for="Facility" class="text-red-500 text-[12px] mt-1 block"></span>
                            </div>
                            <div>
                                <label asp-for="SpecialtyId" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Chuyên khoa</label>
                                <select asp-for="SpecialtyId" id="specialtySelect" asp-items="Model.Specialties" class="w-full px-3 py-2.5 rounded border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none bg-white shadow-sm">
                                    <option value="">-- Chọn chuyên khoa --</option>
                                </select>
                                <span asp-validation-for="SpecialtyId" class="text-red-500 text-[12px] mt-1 block"></span>
                            </div>
                            <div>
                                <label asp-for="DoctorId" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Bác sĩ khám</label>
                                <select asp-for="DoctorId" id="doctorSelect" asp-items="Model.Doctors" class="w-full px-3 py-2.5 rounded border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none bg-white shadow-sm">
                                    <option value="">-- Chọn bác sĩ trực ca --</option>
                                </select>
                                <span asp-validation-for="DoctorId" class="text-red-500 text-[12px] mt-1 block"></span>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
                            <div>
                                <label asp-for="MedicalService" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Chọn dịch vụ khám *</label>
                                <select asp-for="MedicalService" id="medicalServiceSelect" class="w-full px-3 py-2.5 rounded border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none bg-white shadow-sm">
                                    <option value="">-- Chọn dịch vụ khám --</option>
                                    <optgroup label="Khám Chuyên Khoa">
                                        <option value="Khám Nội tổng quát">Khám Nội tổng quát</option>
                                        <option value="Tầm soát Tim mạch & Đái tháo đường">Tầm soát Tim mạch & Đái tháo đường</option>
                                        <option value="Khám & Điều trị bệnh lý Da liễu">Khám & Điều trị bệnh lý Da liễu</option>
                                        <option value="Trị mụn & Chăm sóc da chuyên sâu">Trị mụn & Chăm sóc da chuyên sâu</option>
                                        <option value="Khám Nhi tổng quát & Tư vấn dinh dưỡng">Khám Nhi tổng quát & Tư vấn dinh dưỡng</option>
                                        <option value="Khám & Tiêm chủng vắc-xin cho trẻ">Khám & Tiêm chủng vắc-xin cho trẻ</option>
                                        <option value="Khám & Nội sơ Tai Mũi Họng">Khám & Nội soi Tai Mũi Họng</option>
                                        <option value="Điều trị viêm mũi họng, viêm xoang">Điều trị viêm mũi họng, viêm xoang</option>
                                        <option value="Khám thai định kỳ & Quản lý thai sản">Khám thai định kỳ & Quản lý thai sản</option>
                                        <option value="Khám Phụ khoa & Tầm soát ung thư cổ tử cung">Khám Phụ khoa & Tầm soát ung thư cổ tử cung</option>
                                        <option value="Khám răng tổng quát & Cạo vôi răng">Khám răng tổng quát & Cạo vôi răng</option>
                                        <option value="Nhổ răng khôn & Hàn răng thẩm mỹ">Nhổ răng khôn & Hàn răng thẩm mỹ</option>
                                        <option value="Khám Nội thần kinh (Đau đầu, chóng mặt, mất ngủ)">Khám Nội thần kinh (Đau đầu, chóng mặt, mất ngủ)</option>
                                        <option value="Tầm soát nguy cơ đột quỵ & Tai biến">Tầm soát nguy cơ đột quỵ & Tai biến</option>
                                    </optgroup>
                                    <optgroup label="Dịch Vụ Khám Đặc Thù">
                                        <option value="Khám sức khỏe tổng quát định kỳ">Khám sức khỏe tổng quát định kỳ</option>
                                        <option value="Gói tầm soát sức khỏe Toàn diện (VIP)">Gói tầm soát sức khỏe Toàn diện (VIP)</option>
                                        <option value="Xét nghiệm máu & Kiểm tra sinh hóa tại nhà">Xét nghiệm máu & Kiểm tra sinh hóa tại nhà</option>
                                    </optgroup>
                                </select>
                                <span asp-validation-for="MedicalService" class="text-red-500 text-[12px] mt-1 block"></span>
                            </div>
                            <div>
                                <label class="block text-[13px] font-semibold text-gray-700 mb-2 flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-[#00346f] text-[18px]">calendar_today</span> Thời gian khám
                                </label>
                                <input asp-for="AppointmentDate" id="appointmentDateInput" type="hidden" />
                                <div class="grid grid-cols-4 gap-2 md:gap-3" id="dateCardsContainer">
                                    <button type="button" id="quickDateCard0" class="date-card py-2.5 px-2 border border-gray-200 rounded-xl flex flex-col items-center justify-center transition-all bg-white hover:border-gray-400 cursor-pointer">
                                        <span class="text-[14px] font-bold text-gray-800" id="quickDateStr0"></span>
                                        <span class="text-[11px] text-gray-400 mt-0.5" id="quickDayStr0"></span>
                                    </button>
                                    <button type="button" id="quickDateCard1" class="date-card py-2.5 px-2 border border-gray-200 rounded-xl flex flex-col items-center justify-center transition-all bg-white hover:border-gray-400 cursor-pointer">
                                        <span class="text-[14px] font-bold text-gray-800" id="quickDateStr1"></span>
                                        <span class="text-[11px] text-gray-400 mt-0.5" id="quickDayStr1"></span>
                                    </button>
                                    <button type="button" id="quickDateCard2" class="date-card py-2.5 px-2 border border-gray-200 rounded-xl flex flex-col items-center justify-center transition-all bg-white hover:border-gray-400 cursor-pointer">
                                        <span class="text-[14px] font-bold text-gray-800" id="quickDateStr2"></span>
                                        <span class="text-[11px] text-gray-400 mt-0.5" id="quickDayStr2"></span>
                                    </button>
                                    <button type="button" id="otherDateCard" class="date-card py-2.5 px-2 border border-gray-200 rounded-xl flex flex-col items-center justify-center transition-all bg-white hover:border-gray-400 cursor-pointer relative">
                                        <span class="material-symbols-outlined text-[18px] text-gray-500 mb-0.5">calendar_month</span>
                                        <span class="text-[11px] text-gray-500 font-bold">Ngày khác</span>
                                        <input type="date" id="hiddenDateInput" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full" />
                                    </button>
                                </div>
                                <span asp-validation-for="AppointmentDate" class="text-red-500 text-[12px] mt-1 block"></span>
                            </div>
                        </div>
                            
                            <input asp-for="StartTime" id="startTimeInput" type="hidden" />
                            <input asp-for="EndTime" id="endTimeHidden" type="hidden" />

                            <div>
                                <div class="flex items-center gap-2 mb-3 border-b border-gray-100 pb-2 mt-2">
                                    <span class="material-symbols-outlined text-[#00346f] text-[18px]">calendar_clock</span>
                                    <label class="block text-[14px] font-bold text-[#00346f] m-0">Khung giờ khám</label>
                                </div>
                                
                                <div id="schedulePlaceholder" class="p-6 text-center border border-dashed border-gray-300 rounded-lg bg-gray-50">
                                    <span class="material-symbols-outlined text-gray-400 text-[32px] mb-2 block">event_busy</span>
                                    <p class="text-[13px] text-gray-500 m-0">Vui lòng chọn <strong>Bác sĩ</strong> và <strong>Ngày khám</strong> để xem lịch trống.</p>
                                </div>

                                <div id="scheduleInfoPanel" class="hidden">
                                    <div id="scheduleInfoContent" class="space-y-5">
                                        <!-- JS will generate Morning/Afternoon grids here -->
                                    </div>
                                    <div id="scheduleTimeWarning" class="hidden mt-3 text-[12px] text-amber-700 bg-amber-50 border border-amber-200 rounded px-3 py-2 flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[15px]">warning</span>
                                        <span id="scheduleTimeWarningText"></span>
                                    </div>
                                </div>
                                <span asp-validation-for="StartTime" class="text-red-500 text-[12px] mt-2 block"></span>
                            </div>
                    </div>

                        <div class="flex items-center gap-3 mb-4 border-b border-gray-100 pb-3 mt-8">
                            <div class="w-8 h-8 bg-[#f0f4fa] rounded-full flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-[#00346f] text-[18px]">person</span>
                            </div>
                            <h3 class="text-[16px] font-bold text-[#00346f] m-0">2. Thông Tin Bệnh Nhân</h3>
                        </div>

                        <!-- Đăng nhập nhanh -->
                        <div class="text-[14px] text-gray-600 mb-4">
                            Hoặc <a href="/Home/Login?ReturnUrl=@Url.Action("Create", "Appointments")" class="text-[#0088ff] hover:underline font-bold">Đăng nhập</a> để lấy nhanh thông tin đặt khám
                        </div>

                        <!-- Vạch kẻ phân cách -->
                        <div class="flex items-center justify-center my-6">
                            <div class="grow h-px bg-gray-200"></div>
                            <span class="px-4 text-[13px] text-gray-400 font-medium bg-white">Hoặc nhập thủ công</span>
                            <div class="grow h-px bg-gray-200"></div>
                        </div>

                        <div class="space-y-5">
                            <!-- Dòng 1: Số điện thoại (trái) và Họ và tên (phải) -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div>
                                    <label asp-for="PhoneNumber" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Số điện thoại *</label>
                                    <input asp-for="PhoneNumber" class="w-full px-3 py-2.5 rounded border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none shadow-sm" placeholder="Nhập số điện thoại..." required />
                                    <span asp-validation-for="PhoneNumber" class="text-red-500 text-[12px] mt-1 block"></span>
                                </div>
                                <div>
                                    <label asp-for="FullName" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Họ và tên *</label>
                                    <input asp-for="FullName" class="w-full px-3 py-2.5 rounded border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none shadow-sm" placeholder="NHẬP HỌ VÀ TÊN..." required style="text-transform: uppercase;" />
                                    <span asp-validation-for="FullName" class="text-red-500 text-[12px] mt-1 block"></span>
                                </div>
                            </div>

                            <!-- Mục collapsible: Thông tin khác -->
                            <div class="border border-gray-200 rounded-xl p-4 bg-gray-50/50">
                                <button type="button" onclick="toggleOtherInfo()" class="flex items-center justify-between w-full text-[#0088ff] hover:text-[#0066cc] font-bold text-[14px] focus:outline-none transition-colors border-none bg-transparent cursor-pointer">
                                    <span class="flex items-center gap-1.5">
                                        <span class="material-symbols-outlined text-[18px]">add_circle</span> Thông tin khác
                                    </span>
                                    <span id="toggleArrow" class="transition-transform duration-200">⋁</span>
                                </button>
                                
                                <div id="otherInfoContent" class="hidden grid grid-cols-1 md:grid-cols-2 gap-5 mt-4 pt-4 border-t border-gray-150">
                                    <!-- Dòng 2: Ngày sinh (trái) và Giới tính (phải) -->
                                    <div>
                                        <label asp-for="DateOfBirth" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Ngày sinh</label>
                                        <input asp-for="DateOfBirth" type="date" class="w-full px-3 py-2.5 rounded border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none shadow-sm text-gray-700" placeholder="Nhập ngày sinh" />
                                        <span asp-validation-for="DateOfBirth" class="text-red-500 text-[12px] mt-1 block"></span>
                                    </div>
                                    <div>
                                        <label asp-for="Gender" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Giới tính</label>
                                        <select asp-for="Gender" class="w-full px-3 py-2.5 rounded border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none bg-white shadow-sm">
                                            <option value="">Chọn giới tính</option>
                                            <option value="Nam">Nam</option>
                                            <option value="Nữ">Nữ</option>
                                            <option value="Khác">Khác</option>
                                        </select>
                                        <span asp-validation-for="Gender" class="text-red-500 text-[12px] mt-1 block"></span>
                                    </div>

                                    <!-- Dòng 3: Mã định danh/CCCD (trái) và Mã bảo hiểm y tế (phải) -->
                                    <div>
                                        <label asp-for="IdentityCard" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Mã định danh/CCCD</label>
                                        <div class="flex">
                                            <select class="px-2.5 py-2.5 rounded-l border border-r-0 border-gray-300 bg-gray-100 text-[13px] focus:outline-none outline-none text-gray-700 font-semibold">
                                                <option value="CCCD">CCCD</option>
                                                <option value="CMND">CMND</option>
                                                <option value="HC">Hộ chiếu</option>
                                            </select>
                                            <input asp-for="IdentityCard" class="w-full px-3 py-2.5 rounded-r border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none shadow-sm" placeholder="Vui lòng nhập Mã định danh/CCCD" />
                                        </div>
                                        <span asp-validation-for="IdentityCard" class="text-red-500 text-[12px] mt-1 block"></span>
                                    </div>
                                    <div>
                                        <label asp-for="InsuranceCode" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Mã bảo hiểm y tế</label>
                                        <input asp-for="InsuranceCode" class="w-full px-3 py-2.5 rounded border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none shadow-sm" placeholder="Nhập Mã bảo hiểm y tế" />
                                        <span asp-validation-for="InsuranceCode" class="text-red-500 text-[12px] mt-1 block"></span>
                                    </div>

                                    <!-- Dòng 4: Nghề nghiệp (trái) và Quốc gia (phải) -->
                                    <div>
                                        <label asp-for="Occupation" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Nghề nghiệp</label>
                                        <input asp-for="Occupation" class="w-full px-3 py-2.5 rounded border border-gray-300 text-[14px] focus:ring-1 focus:ring-blue-500 outline-none shadow-sm" placeholder="Nhập nghề nghiệp..." />
                                        <span asp-validation-for="Occupation" class="text-red-500 text-[12px] mt-1 block"></span>
                                    </div>
                                    <div>
                                        <label asp-for="Country" class="block text-[13px] font-semibold text-gray-700 mb-1.5">Quốc gia</label>
