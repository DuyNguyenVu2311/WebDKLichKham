@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const facilitySelect    = document.getElementById('facilitySelect');
            const specialtySelect   = document.getElementById('specialtySelect');
            const doctorSelect      = document.getElementById('doctorSelect');
            const dateInput         = document.getElementById('appointmentDateInput');
            const startInput        = document.getElementById('startTimeInput');
            const endHidden         = document.getElementById('endTimeHidden');
            const display           = document.getElementById('estimatedEndTimeDisplay');
            const displayText       = document.getElementById('estimatedEndTimeText');
            const schedulePanel     = document.getElementById('scheduleInfoPanel');
            const scheduleContent   = document.getElementById('scheduleInfoContent');
            const scheduleTitle     = document.getElementById('scheduleInfoTitle');
            const timeWarning       = document.getElementById('scheduleTimeWarning');
            const timeWarningText   = document.getElementById('scheduleTimeWarningText');

            // Summary elements
            const summaryDoctor     = document.getElementById('summaryDoctor');
            const summarySpecialty  = document.getElementById('summarySpecialty');
            const summaryService    = document.getElementById('summaryService');
            const summaryTime       = document.getElementById('summaryTime');

            // Lưu lịch làm hiện tại để validate
            let currentSchedules = [];

            function updateSummary() {
                const serviceSelect = document.getElementById('medicalServiceSelect') || document.querySelector('select[name="MedicalService"]');
                const serviceVal = serviceSelect ? serviceSelect.value : '';
                const selectedService = medicalServices.find(s => s.value === serviceVal);
                const isSpecialized = selectedService && selectedService.group === "Dịch Vụ Khám Đặc Thù";

                if (isSpecialized) {
                    if (summarySpecialty) summarySpecialty.textContent = 'Khám đặc thù';
                    if (summaryDoctor) summaryDoctor.textContent = 'Không có';
                } else {
                    if (summarySpecialty && specialtySelect && specialtySelect.selectedIndex > 0) {
                        summarySpecialty.textContent = specialtySelect.options[specialtySelect.selectedIndex].text;
                    } else if (summarySpecialty) {
                        summarySpecialty.textContent = 'Chưa chọn';
                    }

                    if (summaryDoctor && doctorSelect && doctorSelect.selectedIndex > 0) {
                        let docName = doctorSelect.options[doctorSelect.selectedIndex].text.split(' - ')[0];
                        summaryDoctor.textContent = docName;
                    } else if (summaryDoctor) {
                        summaryDoctor.textContent = 'Chưa chọn';
                    }
                }

                if (summaryService && serviceSelect && serviceSelect.selectedIndex > 0) {
                    summaryService.textContent = serviceSelect.options[serviceSelect.selectedIndex].text;
                } else if (summaryService) {
                    summaryService.textContent = 'Chưa chọn';
                }

                if (summaryTime && dateInput) {
                    let timeStr = 'Chưa chọn';
                    if (dateInput.value) {
                        const dateParts = dateInput.value.split('-');
                        if (dateParts.length === 3) {
                            timeStr = `${dateParts[2]}/${dateParts[1]}/${dateParts[0]}`;
                        } else {
                            timeStr = dateInput.value;
                        }
                        if (startInput && startInput.value) {
                            timeStr += ' - ' + startInput.value;
                        }
                    }
                    summaryTime.textContent = timeStr;
                }
            }

            // ---- Tiện ích ----
            function timeStrToMinutes(str) {
                if (!str) return -1;
                const [h, m] = str.split(':').map(Number);
                return h * 60 + m;
            }

            // Generate time slots every 30 mins
            function generateSlotsForShift(startStr, endStr, bookedSlots) {
                const slots = [];
                let [h, m] = startStr.split(':').map(Number);
                let endMin = timeStrToMinutes(endStr);
                
                while (h * 60 + m < endMin) {
                    const slotStr = String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0');
                    const isBooked = bookedSlots.includes(slotStr);
                    slots.push({ time: slotStr, booked: isBooked });
                    
                    m += 30;
                    if (m >= 60) {
                        h++;
                        m -= 60;
                    }
                }
                return slots;
            }

            function calcEndTime(timeStr) {
                if (!timeStr) return;
                const parts = timeStr.split(':');
                if (parts.length < 2) return;
                const h = parseInt(parts[0], 10);
                const m = parseInt(parts[1], 10);
                const endMin = h * 60 + m + 30;
                const endH = Math.floor(endMin / 60) % 24;
                const endM = endMin % 60;
                const formattedEndTime = String(endH).padStart(2, '0') + ':' + String(endM).padStart(2, '0');
                if (endHidden) {
                    endHidden.value = formattedEndTime;
                }
            }

            window.selectTimeSlot = function(timeStr) {
                startInput.value = timeStr;
                // Calculate end time (+30 mins)
                let [h, m] = timeStr.split(':').map(Number);
                let endMin = h * 60 + m + 30;
                let endH = Math.floor(endMin / 60) % 24;
                let endM = endMin % 60;
                endHidden.value = String(endH).padStart(2, '0') + ':' + String(endM).padStart(2, '0');
                
                // Update active style
                document.querySelectorAll('.time-slot-btn').forEach(btn => {
                    if (btn.dataset.time === timeStr) {
                        btn.classList.remove('bg-white', 'text-gray-700', 'border-gray-300');
                        btn.classList.add('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'ring-2', 'ring-green-200');
                    } else {
                        btn.classList.remove('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'ring-2', 'ring-green-200');
                        btn.classList.add('bg-white', 'text-gray-700', 'border-gray-300');
                    }
                });
                
                if (timeWarning) timeWarning.classList.add('hidden');
                updateSummary();
            };

            // ---- Load danh sách bác sĩ theo chi nhánh + chuyên khoa ----
            async function loadDoctors() {
                if (!doctorSelect) return;

                const serviceVal = serviceSelectElement ? serviceSelectElement.value : '';
                const selectedService = medicalServices.find(s => s.value === serviceVal);
                const isSpecialized = selectedService && selectedService.group === "Dịch Vụ Khám Đặc Thù";

                if (isSpecialized) {
                    doctorSelect.innerHTML = '<option value="">-- Dịch vụ này không cần chọn Bác sĩ --</option>';
                    doctorSelect.value = "";
                    doctorSelect.disabled = true;
                    if (specialtySelect) {
                        specialtySelect.value = "";
                        specialtySelect.disabled = true;
                    }
                    updateSummary();
                    return;
                } else {
                    doctorSelect.disabled = false;
                    if (specialtySelect) {
                        specialtySelect.disabled = false;
                    }
                }

                const facility   = facilitySelect ? facilitySelect.value : '';
                const specialty  = specialtySelect ? specialtySelect.value : '';
                const currentVal = doctorSelect ? doctorSelect.value : '';

                const params = new URLSearchParams();
                if (facility)  params.set('facility', facility);
                if (specialty) params.set('specialtyId', specialty);

                try {
                    const res = await fetch('/Appointments/GetDoctors?' + params.toString());
                    const doctors = await res.json();

                    // Rebuild options
                    doctorSelect.innerHTML = '<option value="">-- Chọn bác sĩ trực ca --</option>';
                    doctors.forEach(d => {
                        const opt = document.createElement('option');
                        opt.value = d.value;
                        opt.textContent = d.text;
                        if (d.value === currentVal) opt.selected = true;
                        doctorSelect.appendChild(opt);
                    });

                    // Nếu bác sĩ cũ vẫn còn trong danh sách mới, giữ lại và load lịch
                    if (currentVal && [...doctorSelect.options].some(o => o.value === currentVal)) {
                        doctorSelect.value = currentVal;
                    }
                    updateSummary();
                } catch (e) {
                    console.error('Lỗi tải danh sách bác sĩ:', e);
                }
            }

            // ---- Render lịch dịch vụ đặc thù (7h-12h và 13h-18h) ----
            function renderSpecializedSchedule(dateVal) {
                const placeholder = document.getElementById('schedulePlaceholder');
                if (placeholder) placeholder.classList.add('hidden');
                schedulePanel.classList.remove('hidden');

                const morningSlots = ["07:00", "07:30", "08:00", "08:30", "09:00", "09:30", "10:00", "10:30", "11:00", "11:30"];
                const afternoonSlots = ["13:00", "13:30", "14:00", "14:30", "15:00", "15:30", "16:00", "16:30", "17:00", "17:30"];

                const now = new Date();
                const todayStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
                const isToday = dateVal === todayStr;

                let html = '';

                // Ca Sáng
                html += `
                <div>
                    <h4 class="text-[13px] font-bold text-gray-700 mb-3 flex items-center gap-1.5 border-b border-gray-100 pb-2">
                        <span class="material-symbols-outlined text-[18px] text-amber-500">wb_sunny</span> 
                        Ca sáng (07:00 - 12:00)
                    </h4>
                    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3">
                `;
                morningSlots.forEach(time => {
                    let isPast = false;
                    if (isToday) {
                        const [sh, sm] = time.split(':').map(Number);
                        if (sh < now.getHours() || (sh === now.getHours() && sm <= now.getMinutes())) {
                            isPast = true;
                        }
                    }

                    if (isPast) {
                        html += `<button type="button" disabled class="px-3 py-2.5 text-[14px] font-semibold rounded-xl border border-gray-200 bg-gray-50 text-gray-400 cursor-not-allowed flex flex-col items-center justify-center gap-0.5 opacity-65">
                                    ${time}
                                    <span class="text-[10px] font-normal text-red-500/80 no-underline">Đã qua</span>
                                 </button>`;
                    } else {
                        const isSelected = startInput && startInput.value === time;
                        const btnClass = isSelected 
                            ? 'bg-[#10b981] text-white border-[#10b981] ring-2 ring-green-200 font-bold scale-[1.02]' 
                            : 'bg-white text-gray-700 border-gray-300 hover:border-green-500 hover:text-green-600';
                        
                        html += `<button type="button" data-time="${time}" onclick="selectTimeSlot('${time}')" class="time-slot-btn px-3 py-2.5 text-[14px] font-semibold rounded-xl border shadow-sm transition-all ${btnClass} flex flex-col items-center justify-center gap-0.5">
                                    ${time}
                                    <span class="text-[10px] font-normal opacity-70">Còn trống</span>
                                 </button>`;
                    }
                });
                html += `</div></div>`;

                // Ca Chiều
                html += `
                <div class="mt-5">
                    <h4 class="text-[13px] font-bold text-gray-700 mb-3 flex items-center gap-1.5 border-b border-gray-100 pb-2">
                        <span class="material-symbols-outlined text-[18px] text-orange-500">wb_twilight</span> 
                        Ca chiều (13:00 - 18:00)
                    </h4>
                    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3">
                `;
                afternoonSlots.forEach(time => {
                    let isPast = false;
                    if (isToday) {
                        const [sh, sm] = time.split(':').map(Number);
                        if (sh < now.getHours() || (sh === now.getHours() && sm <= now.getMinutes())) {
                            isPast = true;
                        }
                    }

                    if (isPast) {
                        html += `<button type="button" disabled class="px-3 py-2.5 text-[14px] font-semibold rounded-xl border border-gray-200 bg-gray-50 text-gray-400 cursor-not-allowed flex flex-col items-center justify-center gap-0.5 opacity-65">
                                    ${time}
                                    <span class="text-[10px] font-normal text-red-500/80 no-underline">Đã qua</span>
                                 </button>`;
                    } else {
                        const isSelected = startInput && startInput.value === time;
                        const btnClass = isSelected 
                            ? 'bg-[#10b981] text-white border-[#10b981] ring-2 ring-green-200 font-bold scale-[1.02]' 
                            : 'bg-white text-gray-700 border-gray-300 hover:border-green-500 hover:text-green-600';
                        
                        html += `<button type="button" data-time="${time}" onclick="selectTimeSlot('${time}')" class="time-slot-btn px-3 py-2.5 text-[14px] font-semibold rounded-xl border shadow-sm transition-all ${btnClass} flex flex-col items-center justify-center gap-0.5">
                                    ${time}
                                    <span class="text-[10px] font-normal opacity-70">Còn trống</span>
                                 </button>`;
                    }
                });
                html += `</div></div>`;

                scheduleContent.innerHTML = html;
            }

            // ---- Load lịch làm của bác sĩ ----
            async function loadDoctorSchedule() {
                const doctorId = doctorSelect ? doctorSelect.value : '';
                const dateVal  = dateInput ? dateInput.value : '';

                currentSchedules = [];
                schedulePanel.classList.add('hidden');
                scheduleContent.innerHTML = '';
                if (timeWarning) timeWarning.classList.add('hidden');
                const placeholder = document.getElementById('schedulePlaceholder');

                // Kiểm tra xem dịch vụ chọn có phải là dịch vụ đặc thù không
                const serviceSelect = document.getElementById('medicalServiceSelect') || document.querySelector('select[name="MedicalService"]');
                const serviceVal = serviceSelect ? serviceSelect.value : '';
                const selectedService = medicalServices.find(s => s.value === serviceVal);
                const isSpecialized = selectedService && selectedService.group === "Dịch Vụ Khám Đặc Thù";

                if (isSpecialized) {
                    if (!dateVal) {
                        if (placeholder) {
                            placeholder.classList.remove('hidden');
                            placeholder.innerHTML = `
                                <span class="material-symbols-outlined text-gray-400 text-[32px] mb-2 block">event_busy</span>
                                <p class="text-[13px] text-gray-500 m-0">Vui lòng chọn <strong>Ngày khám</strong> để xem khung giờ trống.</p>`;
                        }
                        updateSummary();
                        return;
                    }
                    renderSpecializedSchedule(dateVal);
                    updateSummary();
                    return;
                }

                if (!doctorId || !dateVal) {
                    if (placeholder) {
                        placeholder.classList.remove('hidden');
                        placeholder.innerHTML = `
                            <span class="material-symbols-outlined text-gray-400 text-[32px] mb-2 block">event_busy</span>
                            <p class="text-[13px] text-gray-500 m-0">Vui lòng chọn <strong>Bác sĩ</strong> và <strong>Ngày khám</strong> để xem lịch trống.</p>`;
                    }
                    updateSummary();
                    return;
                }

                try {
                    const res = await fetch(`/Appointments/GetDoctorSchedule?doctorId=${doctorId}&date=${dateVal}`);
                    const data = await res.json();
                    const schedules = data.schedules;
                    const bookedSlots = data.bookedSlots || [];
                    currentSchedules = schedules;

                    if (schedules.length === 0) {
                        schedulePanel.classList.add('hidden');
                        if (placeholder) {
                            placeholder.classList.remove('hidden');
                            placeholder.innerHTML = `
                                <span class="material-symbols-outlined text-red-400 text-[32px] mb-2 block">event_busy</span>
                                <p class="text-[13px] text-red-500 m-0">Bác sĩ không có lịch làm việc vào ngày này.</p>`;
                        }
                    } else {
                        if (placeholder) placeholder.classList.add('hidden');
                        schedulePanel.classList.remove('hidden');
                        
                        let html = '';
                        schedules.forEach(s => {
                            const slots = generateSlotsForShift(s.startTime, s.endTime, bookedSlots);
                            const shiftIcon = s.shift === 'Morning' ? 'wb_sunny' : (s.shift === 'Afternoon' ? 'wb_twilight' : 'dark_mode');
                            const shiftColor = s.shift === 'Morning' ? 'text-amber-500' : (s.shift === 'Afternoon' ? 'text-orange-500' : 'text-indigo-500');
                            
                            html += `
                            <div>
                                <h4 class="text-[13px] font-bold text-gray-700 mb-3 flex items-center gap-1.5 border-b border-gray-100 pb-2">
                                    <span class="material-symbols-outlined text-[18px] ${shiftColor}">${shiftIcon}</span> 
                                    ${s.shiftName} (${s.startTime} - ${s.endTime})
                                </h4>
                                <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3">
                            `;
                            
                            const now = new Date();
                            const todayStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
                            const isToday = dateInput.value === todayStr;

                            slots.forEach(slot => {
                                let isPast = false;
                                if (isToday) {
                                    const [sh, sm] = slot.time.split(':').map(Number);
                                    if (sh < now.getHours() || (sh === now.getHours() && sm <= now.getMinutes())) {
                                        isPast = true;
                                    }
                                }

                                if (slot.booked || isPast) {
                                    const reasonText = isPast ? 'Đã qua' : 'Đã đặt';
                                    html += `<button type="button" disabled class="px-3 py-2.5 text-[14px] font-semibold rounded-xl border border-gray-200 bg-gray-50 text-gray-400 cursor-not-allowed flex flex-col items-center justify-center gap-0.5 opacity-65">
                                                ${slot.time}
                                                <span class="text-[10px] font-normal text-red-500/80 no-underline">${reasonText}</span>
                                             </button>`;
                                } else {
                                    const isSelected = startInput && startInput.value === slot.time;
                                    const btnClass = isSelected 
                                        ? 'bg-[#10b981] text-white border-[#10b981] ring-2 ring-green-200 font-bold scale-[1.02]' 
                                        : 'bg-white text-gray-700 border-gray-300 hover:border-green-500 hover:text-green-600';
                                    
                                    html += `<button type="button" data-time="${slot.time}" onclick="selectTimeSlot('${slot.time}')" class="time-slot-btn px-3 py-2.5 text-[14px] font-semibold rounded-xl border shadow-sm transition-all ${btnClass} flex flex-col items-center justify-center gap-0.5">
                                                ${slot.time}
                                                <span class="text-[10px] font-normal opacity-70">Còn trống</span>
                                             </button>`;
                                }
                            });
                            
                            html += `</div></div>`;
                        });
                        
                        scheduleContent.innerHTML = html;
                    }
                    updateSummary();
                } catch (e) {
                    console.error('Lỗi tải lịch bác sĩ:', e);
                }
            }

            // ---- Gắn sự kiện & Đồng bộ Chuyên khoa - Dịch vụ ----
            const serviceSelectElement = document.getElementById('medicalServiceSelect') || document.querySelector('select[name="MedicalService"]');
            
            const medicalServices = [
                // Nội tổng hợp
                { value: "Khám Nội tổng quát", text: "Khám Nội tổng quát", specialty: "Nội tổng hợp", group: "Khám Chuyên Khoa" },
                { value: "Tầm soát Tim mạch & Đái tháo đường", text: "Tầm soát Tim mạch & Đái tháo đường", specialty: "Nội tổng hợp", group: "Khám Chuyên Khoa" },
                
                // Da liễu
                { value: "Khám & Điều trị bệnh lý Da liễu", text: "Khám & Điều trị bệnh lý Da liễu", specialty: "Da liễu", group: "Khám Chuyên Khoa" },
                { value: "Trị mụn & Chăm sóc da chuyên sâu", text: "Trị mụn & Chăm sóc da chuyên sâu", specialty: "Da liễu", group: "Khám Chuyên Khoa" },
                
                // Nhi khoa
                { value: "Khám Nhi tổng quát & Tư vấn dinh dưỡng", text: "Khám Nhi tổng quát & Tư vấn dinh dưỡng", specialty: "Nhi khoa", group: "Khám Chuyên Khoa" },
                { value: "Khám & Tiêm chủng vắc-xin cho trẻ", text: "Khám & Tiêm chủng vắc-xin cho trẻ", specialty: "Nhi khoa", group: "Khám Chuyên Khoa" },
                
                // Tai Mũi Họng
                { value: "Khám & Nội soi Tai Mũi Họng", text: "Khám & Nội soi Tai Mũi Họng", specialty: "Tai Mũi Họng", group: "Khám Chuyên Khoa" },
                { value: "Điều trị viêm mũi họng, viêm xoang", text: "Điều trị viêm mũi họng, viêm xoang", specialty: "Tai Mũi Họng", group: "Khám Chuyên Khoa" },
                
                // Sản phụ khoa
                { value: "Khám thai định kỳ & Quản lý thai sản", text: "Khám thai định kỳ & Quản lý thai sản", specialty: "Sản phụ khoa", group: "Khám Chuyên Khoa" },
                { value: "Khám Phụ khoa & Tầm soát ung thư cổ tử cung", text: "Khám Phụ khoa & Tầm soát ung thư cổ tử cung", specialty: "Sản phụ khoa", group: "Khám Chuyên Khoa" },
                
                // Răng Hàm Mặt
                { value: "Khám răng tổng quát & Cạo vôi răng", text: "Khám răng tổng quát & Cạo vôi răng", specialty: "Răng Hàm Mặt", group: "Khám Chuyên Khoa" },
                { value: "Nhổ răng khôn & Hàn răng thẩm mỹ", text: "Nhổ răng khôn & Hàn răng thẩm mỹ", specialty: "Răng Hàm Mặt", group: "Khám Chuyên Khoa" },
                
                // Nội thần kinh
                { value: "Khám Nội thần kinh (Đau đầu, chóng mặt, mất ngủ)", text: "Khám Nội thần kinh (Đau đầu, chóng mặt, mất ngủ)", specialty: "Nội thần kinh", group: "Khám Chuyên Khoa" },
                { value: "Tầm soát nguy cơ đột quỵ & Tai biến", text: "Tầm soát nguy cơ đột quỵ & Tai biến", specialty: "Nội thần kinh", group: "Khám Chuyên Khoa" },
                
                // Dịch Vụ Khám Đặc Thù
                { value: "Khám sức khỏe tổng quát định kỳ", text: "Khám sức khỏe tổng quát định kỳ", specialty: "", group: "Dịch Vụ Khám Đặc Thù" },
                { value: "Gói tầm soát sức khỏe Toàn diện (VIP)", text: "Gói tầm soát sức khỏe Toàn diện (VIP)", specialty: "", group: "Dịch Vụ Khám Đặc Thù" },
                { value: "Xét nghiệm máu & Kiểm tra sinh hóa tại nhà", text: "Xét nghiệm máu & Kiểm tra sinh hóa tại nhà", specialty: "", group: "Dịch Vụ Khám Đặc Thù" }
            ];

            const specialtyNameToId = {};
            const specialtyIdToName = {};
            if (specialtySelect) {
                Array.from(specialtySelect.options).forEach(opt => {
                    if (opt.value) {
                        specialtyNameToId[opt.text.trim()] = opt.value;
                        specialtyIdToName[opt.value] = opt.text.trim();
                    }
                });
            }

            function renderServices(specialtyName) {
                if (!serviceSelectElement) return;
                const currentServiceVal = serviceSelectElement.value;
                
                const filtered = medicalServices.filter(s => {
                    return !specialtyName || s.specialty === specialtyName;
                });

                serviceSelectElement.innerHTML = '<option value="">-- Chọn dịch vụ khám --</option>';
                const groups = {};
                filtered.forEach(s => {
                    if (!groups[s.group]) groups[s.group] = [];
                    groups[s.group].push(s);
                });

                for (const groupName in groups) {
                    const optGroup = document.createElement('optgroup');
                    optGroup.label = groupName;
                    groups[groupName].forEach(s => {
                        const opt = document.createElement('option');
                        opt.value = s.value;
                        opt.textContent = s.text;
                        if (s.value === currentServiceVal) opt.selected = true;
                        optGroup.appendChild(opt);
                    });
                    serviceSelectElement.appendChild(optGroup);
                }
            }

            function lockSpecialties(allowedSpecialtyId) {
                if (!specialtySelect) return;
                Array.from(specialtySelect.options).forEach(opt => {
                    if (opt.value === "") {
                        opt.style.display = "";
                        opt.disabled = false;
                    } else if (allowedSpecialtyId !== "" && opt.value === allowedSpecialtyId) {
                        opt.style.display = "";
                        opt.disabled = false;
                    } else {
                        opt.style.display = "none";
                        opt.disabled = true;
                    }
                });
            }

            function unlockSpecialties() {
                if (!specialtySelect) return;
                Array.from(specialtySelect.options).forEach(opt => {
                    opt.style.display = "";
                    opt.disabled = false;
                });
            }

            function syncSpecialtyAndService(changedSource) {
                const specialtyVal = specialtySelect ? specialtySelect.value : '';
                const specialtyName = specialtyIdToName[specialtyVal] || '';
                const serviceVal = serviceSelectElement ? serviceSelectElement.value : '';
                const selectedService = medicalServices.find(s => s.value === serviceVal);

                if (changedSource === 'specialty') {
                    renderServices(specialtyName);
                    
                    const currentServiceObj = medicalServices.find(s => s.value === serviceSelectElement.value);
                    if (currentServiceObj && specialtyVal !== "" && currentServiceObj.specialty !== specialtyName) {
                        serviceSelectElement.value = "";
                    }
                } 
                else if (changedSource === 'service') {
                    if (selectedService) {
                        if (selectedService.specialty !== "") {
                            const targetSpecialtyId = specialtyNameToId[selectedService.specialty];
                            if (targetSpecialtyId) {
                                specialtySelect.value = targetSpecialtyId;
                                lockSpecialties(targetSpecialtyId);
                            }
                        } else {
                            specialtySelect.value = "";
                            lockSpecialties("");
                            if (doctorSelect) {
                                doctorSelect.innerHTML = '<option value="">-- Chọn bác sĩ trực ca --</option>';
                                doctorSelect.value = "";
                            }
                        }
                        renderServices(selectedService.specialty);
                    } else {
                        unlockSpecialties();
                        renderServices(specialtyName);
                    }
                }
            }

            if (serviceSelectElement) {
                serviceSelectElement.addEventListener('change', function() {
                    syncSpecialtyAndService('service');
                    loadDoctors();
                    loadDoctorSchedule();
                    updateSummary();
                });
            }
            if (specialtySelect) {
                specialtySelect.addEventListener('change', function() {
                    syncSpecialtyAndService('specialty');
                    loadDoctors();
                    updateSummary();
                });
            }
            if (facilitySelect)  facilitySelect.addEventListener('change',  loadDoctors);
            if (doctorSelect) {
                doctorSelect.addEventListener('change', function() {
                    loadDoctorSchedule();
                    updateSummary();
                });
            }
            if (dateInput) {
                dateInput.addEventListener('change', function() {
                    loadDoctorSchedule();
                    updateSummary();
                });
            }

            // Run initial synchronization
            if (specialtySelect && specialtySelect.value) {
                syncSpecialtyAndService('specialty');
            } else if (serviceSelectElement && serviceSelectElement.value) {
                syncSpecialtyAndService('service');
            }

            if (startInput) {
                startInput.addEventListener('change', function () {
                    calcEndTime(this.value);
                    updateSummary();
                });
                if (startInput.value) calcEndTime(startInput.value);
            }

            // Thiết lập giá trị tối thiểu cho date input
            if (dateInput) {
                const now = new Date();
                const todayStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
                let minDateStr = todayStr;

                // Nếu quá 17:30 thì set min và trị mặc định là ngày mai, còn không thì hôm nay
                if (now.getHours() > 17 || (now.getHours() === 17 && now.getMinutes() >= 30)) {
                    const tomorrow = new Date(now);
                    tomorrow.setDate(tomorrow.getDate() + 1);
                    const tomorrowStr = tomorrow.getFullYear() + '-' + String(tomorrow.getMonth() + 1).padStart(2, '0') + '-' + String(tomorrow.getDate()).padStart(2, '0');
                    dateInput.min = tomorrowStr;
                    minDateStr = tomorrowStr;
                    if (!dateInput.value || dateInput.value === todayStr) {
                        dateInput.value = tomorrowStr;
                    }
                } else {
                    dateInput.min = todayStr;
                    if (!dateInput.value) {
                        dateInput.value = todayStr;
                    }
                }

                // Initialize quick date cards
                initQuickDateCards(minDateStr);
            }

            function initQuickDateCards(minDateStr) {
                const parts = minDateStr.split('-');
                const baseDate = new Date(parts[0], parts[1] - 1, parts[2]);
                const dates = [];
                for (let i = 0; i < 3; i++) {
                    const d = new Date(baseDate);
                    d.setDate(baseDate.getDate() + i);
                    dates.push(d);
                }

                const dayNames = ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'];

                dates.forEach((d, idx) => {
                    const yyyy = d.getFullYear();
                    const mm = String(d.getMonth() + 1).padStart(2, '0');
                    const dd = String(d.getDate()).padStart(2, '0');
                    const ymd = `${yyyy}-${mm}-${dd}`;

                    const dateStr = `${dd}/${mm}`;
                    const dayStr = dayNames[d.getDay()];

                    const cardBtn = document.getElementById(`quickDateCard${idx}`);
                    if (cardBtn) {
                        document.getElementById(`quickDateStr${idx}`).textContent = dateStr;
                        document.getElementById(`quickDayStr${idx}`).textContent = dayStr;
                        cardBtn.dataset.date = ymd;

                        cardBtn.onclick = function() {
                            dateInput.value = ymd;
                            dateInput.dispatchEvent(new Event('change'));
                            updateDateCardsHighlight();
                        };
                    }
                });

                const hiddenDateInput = document.getElementById('hiddenDateInput');
                if (hiddenDateInput) {
                    hiddenDateInput.min = minDateStr;
                    hiddenDateInput.onchange = function() {
                        if (this.value) {
                            dateInput.value = this.value;
                            dateInput.dispatchEvent(new Event('change'));
                            updateDateCardsHighlight();
                        }
                    };
                }

                updateDateCardsHighlight();
            }

            function updateDateCardsHighlight() {
                const selectedVal = dateInput.value;
                let found = false;

                for (let i = 0; i < 3; i++) {
                    const cardBtn = document.getElementById(`quickDateCard${i}`);
                    if (cardBtn) {
                        if (cardBtn.dataset.date === selectedVal) {
                            cardBtn.classList.remove('bg-white', 'text-gray-800', 'border-gray-200');
                            cardBtn.classList.add('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'shadow-sm', 'font-bold');
                            found = true;
                        } else {
                            cardBtn.classList.remove('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'shadow-sm', 'font-bold');
                            cardBtn.classList.add('bg-white', 'text-gray-800', 'border-gray-200');
                        }
                    }
                }

                const otherCard = document.getElementById('otherDateCard');
                if (otherCard) {
                    const labelSpan = otherCard.querySelector('span.font-bold');
                    const iconSpan = otherCard.querySelector('span.material-symbols-outlined');
                    if (!found && selectedVal) {
                        otherCard.classList.remove('bg-white', 'text-gray-800', 'border-gray-200');
                        otherCard.classList.add('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'shadow-sm', 'font-bold');
                        
                        const parts = selectedVal.split('-');
                        if (parts.length === 3) {
                            labelSpan.textContent = `${parts[2]}/${parts[1]}`;
                        }
                        if (iconSpan) {
                            iconSpan.classList.remove('text-gray-500');
                            iconSpan.classList.add('text-white');
                        }
                    } else {
                        otherCard.classList.remove('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'shadow-sm', 'font-bold');
                        otherCard.classList.add('bg-white', 'text-gray-800', 'border-gray-200');
                        labelSpan.textContent = 'Ngày khác';
                        if (iconSpan) {
                            iconSpan.classList.remove('text-white');
                            iconSpan.classList.add('text-gray-500');
                        }
                    }
                }
            }

            // Khởi tạo nếu form đã có giá trị (ví dụ từ query string hoặc validation fail)
            updateSummary();
            if (doctorSelect && dateInput && doctorSelect.value && dateInput.value) {
                loadDoctorSchedule();
            }

            // Accordion toggle for "Thông tin khác"
            window.toggleOtherInfo = function() {
                const otherInfoContent = document.getElementById("otherInfoContent");
                const toggleArrow = document.getElementById("toggleArrow");
                if (otherInfoContent.classList.contains("hidden")) {
                    otherInfoContent.classList.remove("hidden");
                    otherInfoContent.classList.add("grid");
                    toggleArrow.style.transform = "rotate(180deg)";
                } else {
                    otherInfoContent.classList.add("hidden");
                    otherInfoContent.classList.remove("grid");
                    toggleArrow.style.transform = "rotate(0deg)";
                }
            };

            // Cascading addresses selection from API
            (async function() {
                const provinceSelect = document.getElementById("provinceSelect");
                const districtSelect = document.getElementById("districtSelect");
                const wardSelect = document.getElementById("wardSelect");
                
                const initialProvince = '@Html.Raw(Model.Province)';
                const initialDistrict = '@Html.Raw(Model.District)';
                const initialWard = '@Html.Raw(Model.Ward)';

                try {
                    const response = await fetch("https://provinces.open-api.vn/api/p/");
                    if (!response.ok) throw new Error("Network response error");
                    const provinces = await response.json();
                    
                    provinceSelect.innerHTML = '<option value="">Chọn tỉnh thành</option>';
                    provinces.forEach(p => {
                        const option = document.createElement("option");
                        option.value = p.name;
                        option.dataset.code = p.code;
                        option.textContent = p.name;
                        if (p.name === initialProvince) {
                            option.selected = true;
                        }
                        provinceSelect.appendChild(option);
                    });

                    if (initialProvince) {
                        await loadDistricts(initialDistrict, initialWard);
                    }
                } catch (err) {
                    console.error("Lỗi khi tải danh sách Tỉnh/Thành phố:", err);
                }

                provinceSelect.addEventListener("change", async function() {
                    districtSelect.innerHTML = '<option value="">Chọn quận huyện</option>';
                    districtSelect.disabled = true;
                    wardSelect.innerHTML = '<option value="">Chọn xã phường</option>';
                    wardSelect.disabled = true;
                    
                    const selectedOption = provinceSelect.options[provinceSelect.selectedIndex];
                    if (selectedOption && selectedOption.dataset.code) {
                        await loadDistricts("", "");
                    }
                });

                districtSelect.addEventListener("change", async function() {
                    wardSelect.innerHTML = '<option value="">Chọn xã phường</option>';
                    wardSelect.disabled = true;
                    
                    const selectedOption = districtSelect.options[districtSelect.selectedIndex];
                    if (selectedOption && selectedOption.dataset.code) {
                        await loadWards("");
                    }
                });

                async function loadDistricts(selectedDistrictName, selectedWardName) {
                    const selectedOption = provinceSelect.options[provinceSelect.selectedIndex];
                    if (!selectedOption || !selectedOption.dataset.code) return;
                    const code = selectedOption.dataset.code;

                    try {
                        const response = await fetch(`https://provinces.open-api.vn/api/p/${code}?depth=2`);
                        if (!response.ok) throw new Error("Network response error");
                        const provinceData = await response.json();
                        
                        districtSelect.innerHTML = '<option value="">Chọn quận huyện</option>';
                        provinceData.districts.forEach(d => {
                            const option = document.createElement("option");
                            option.value = d.name;
                            option.dataset.code = d.code;
                            option.textContent = d.name;
                            if (d.name === selectedDistrictName) {
                                option.selected = true;
                            }
                            districtSelect.appendChild(option);
                        });
                        districtSelect.disabled = false;

                        if (selectedDistrictName) {
                            await loadWards(selectedWardName);
                        }
                    } catch (err) {
                        console.error("Lỗi khi tải danh sách Quận/Huyện:", err);
                    }
                }

                async function loadWards(selectedWardName) {
                    const selectedOption = districtSelect.options[districtSelect.selectedIndex];
                    if (!selectedOption || !selectedOption.dataset.code) return;
                    const code = selectedOption.dataset.code;

                    try {
                        const response = await fetch(`https://provinces.open-api.vn/api/d/${code}?depth=2`);
                        if (!response.ok) throw new Error("Network response error");
                        const districtData = await response.json();
                        
                        wardSelect.innerHTML = '<option value="">Chọn xã phường</option>';
                        districtData.wards.forEach(w => {
                            const option = document.createElement("option");
                            option.value = w.name;
                            option.dataset.code = w.code;
                            option.textContent = w.name;
                            if (w.name === selectedWardName) {
                                option.selected = true;
                            }
                            wardSelect.appendChild(option);
                        });
                        wardSelect.disabled = false;
                    } catch (err) {
                        console.error("Lỗi khi tải danh sách Xã/Phường:", err);
                    }
                }
            })();
        })();
    </script>
}

