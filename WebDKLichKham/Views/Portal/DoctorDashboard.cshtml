@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Không gian làm việc Bác sĩ - Duy Tâm eHospital</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .toast-enter { animation: slideInRight 0.3s ease-out forwards; }
        @@keyframes slideInRight {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    </style>
</head>
<body class="text-slate-800 flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-[#00346f] text-white flex flex-col h-full shrink-0">
        <div class="h-16 flex items-center justify-between px-6 border-b border-white/10">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[24px]">local_hospital</span>
                <span class="font-bold text-[16px]">Phòng Khám Duy Tâm</span>
            </div>
        </div>
        
        <div class="p-6 text-center border-b border-white/10">
            <div class="w-16 h-16 rounded-full bg-white/20 mx-auto mb-3 flex items-center justify-center">
                <span class="material-symbols-outlined text-[32px]">stethoscope</span>
            </div>
            <h3 class="font-bold text-[15px]">BS. Nguyễn Văn An</h3>
            <p class="text-[12px] text-blue-200">Khoa Tiêu Hóa</p>
        </div>
        
        <nav class="flex-1 py-4">
            <ul class="space-y-1">
                <li><a href="#" onclick="switchTab('patients')" id="tab-patients" class="flex items-center gap-3 px-6 py-3 bg-white/10 font-medium text-[14px] border-l-4 border-blue-400"><span class="material-symbols-outlined text-[20px]">group</span> Danh sách bệnh nhân</a></li>
                <li><a href="#" onclick="switchTab('emr')" id="tab-emr" class="flex items-center gap-3 px-6 py-3 hover:bg-white/5 text-blue-100 font-medium text-[14px] border-l-4 border-transparent"><span class="material-symbols-outlined text-[20px]">history_edu</span> Bệnh án điện tử</a></li>
                <li><a href="#" onclick="switchTab('prescriptions')" id="tab-prescriptions" class="flex items-center gap-3 px-6 py-3 hover:bg-white/5 text-blue-100 font-medium text-[14px] border-l-4 border-transparent"><span class="material-symbols-outlined text-[20px]">prescriptions</span> Quản lý toa thuốc</a></li>
            </ul>
        </nav>
        
        <div class="p-4 border-t border-white/10 space-y-2">
            <a href="/" class="flex items-center gap-2 text-blue-200 hover:text-white hover:bg-white/10 px-4 py-2 rounded-lg text-[14px] transition-colors">
                <span class="material-symbols-outlined text-[18px]">home</span> Về Trang Chủ
            </a>
            <a href="/Home/LogoutPortal" class="flex items-center gap-2 text-red-300 hover:text-red-100 hover:bg-white/10 px-4 py-2 rounded-lg text-[14px] transition-colors">
                <span class="material-symbols-outlined text-[18px]">logout</span> Đăng xuất
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-full overflow-hidden relative">
        <!-- Toast Container -->
        <div id="toast-container" class="absolute top-4 right-4 z-50 flex flex-col gap-2"></div>

        <!-- Header -->
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 shrink-0">
            <h1 class="font-bold text-[18px] text-slate-800" id="header-title">Danh sách bệnh nhân (Hôm nay, <span id="currentDate"></span>)</h1>
            <div class="flex items-center gap-4" id="header-stats">
                <span class="bg-blue-50 text-blue-600 px-3 py-1.5 rounded-lg text-[13px] font-bold">Tổng: 3 BN</span>
                <span class="bg-orange-50 text-orange-600 px-3 py-1.5 rounded-lg text-[13px] font-bold">Chờ khám: 2</span>
            </div>
        </header>

        <!-- Content Area -->
        <div class="flex-1 overflow-auto p-8">
            <!-- VIEW: PATIENTS -->
            <div id="view-patients" class="grid grid-cols-1 xl:grid-cols-4 gap-4 h-full">
                <!-- Patient Queue List -->
                <div class="xl:col-span-1 bg-white border border-slate-300 flex flex-col h-full shadow-sm">
                    <div class="p-3 border-b border-slate-300 bg-slate-100 flex justify-between items-center">
                        <h3 class="font-bold text-[13px] text-slate-800 uppercase">Danh sách tiếp nhận</h3>
                        <span class="material-symbols-outlined text-[18px] text-slate-500 cursor-pointer">filter_list</span>
                    </div>
                    <div class="p-2 border-b border-slate-200 bg-slate-50">
                        <input type="text" placeholder="Tìm kiếm nhanh (F3)..." class="w-full px-2 py-1.5 border border-slate-300 text-[12px] outline-none focus:border-blue-500">
                    </div>
                    <div class="flex-1 overflow-y-auto bg-white" id="patient-list">
                        <!-- Rendered by JS -->
                    </div>
                </div>

                <!-- Clinical Workspace Area -->
                <div class="xl:col-span-3 flex flex-col h-full bg-white border border-slate-300 shadow-sm" id="workspace-area">
                    <!-- Top Bar: Patient Info & Vitals -->
                    <div class="bg-slate-50 border-b border-slate-300 p-3 flex justify-between items-start shrink-0">
                        <div class="flex gap-3 items-center">
                            <div class="w-12 h-12 bg-slate-300 text-slate-700 rounded flex items-center justify-center font-bold text-[18px]" id="ws-avatar">TVH</div>
                            <div>
                                <h2 class="font-bold text-[16px] text-slate-800 uppercase" id="ws-name">Trần Văn Hoàng</h2>
                                <div class="text-[12px] text-slate-600 mt-0.5 flex gap-4" id="ws-meta">
                                    <span><i class="font-semibold text-slate-500">Mã BN:</i> BN-847291</span>
                                    <span><i class="font-semibold text-slate-500">Giới tính:</i> Nam</span>
                                    <span><i class="font-semibold text-slate-500">Tuổi:</i> 45</span>
                                    <span><i class="font-semibold text-slate-500">Nhóm máu:</i> O+</span>
                                </div>
                            </div>
                        </div>
                        <button onclick="switchTab('emr')" class="text-blue-600 text-[12px] font-bold hover:underline flex items-center gap-1 border border-blue-200 bg-blue-50 px-2 py-1 rounded">
                            <span class="material-symbols-outlined text-[16px]">history</span> Bệnh án điện tử
                        </button>
                    </div>

                    <!-- Vitals Bar -->
                    <div class="bg-blue-50/50 border-b border-slate-300 p-2 flex flex-wrap gap-x-6 gap-y-2 px-4 shrink-0">
                        <div class="flex items-center gap-1.5 text-[12px]">
                            <span class="material-symbols-outlined text-[16px] text-slate-400">monitor_heart</span>
                            <span class="text-slate-500">Mạch:</span> <span class="font-bold text-slate-800">80</span> <span class="text-slate-400">l/p</span>
                        </div>
                        <div class="flex items-center gap-1.5 text-[12px]">
                            <span class="material-symbols-outlined text-[16px] text-slate-400">blood_pressure</span>
                            <span class="text-slate-500">Huyết áp:</span> <span class="font-bold text-slate-800">120/80</span> <span class="text-slate-400">mmHg</span>
                        </div>
                        <div class="flex items-center gap-1.5 text-[12px]">
                            <span class="material-symbols-outlined text-[16px] text-slate-400">thermometer</span>
                            <span class="text-slate-500">Nhiệt độ:</span> <span class="font-bold text-slate-800">37</span> <span class="text-slate-400">°C</span>
                        </div>
                        <div class="flex items-center gap-1.5 text-[12px]" id="ws-weight-container">
                            <span class="material-symbols-outlined text-[16px] text-slate-400">scale</span>
                            <span class="text-slate-500">Cân nặng:</span> <span class="font-bold text-slate-800" id="ws-weight">65kg</span>
                        </div>
                    </div>

                    <!-- Clinical Form -->
                    <div class="flex-1 overflow-y-auto p-4 bg-slate-100/50">
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                            <!-- Left col: Bệnh sử -->
                            <div class="col-span-1 space-y-4">
                                <div class="bg-white border border-slate-300 rounded shadow-sm">
                                    <div class="bg-slate-100 border-b border-slate-200 px-3 py-1.5 font-bold text-[12px] text-slate-700">1. LÝ DO KHÁM & TIỀN SỬ</div>
                                    <div class="p-3 space-y-3">
                                        <div>
                                            <label class="text-[11px] font-semibold text-slate-500 mb-1 block">Lý do đến khám:</label>
                                            <textarea id="ws-reason" class="w-full text-[13px] border border-slate-300 rounded p-2 outline-none focus:border-blue-500 bg-yellow-50/50 resize-y" rows="2" readonly></textarea>
                                        </div>
                                        <div>
                                            <label class="text-[11px] font-semibold text-slate-500 mb-1 block">Tiền sử bệnh lý:</label>
                                            <textarea id="ws-history" class="w-full text-[13px] border border-slate-300 rounded p-2 outline-none focus:border-blue-500 resize-y" rows="2" readonly></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Right col: Khám & Chẩn đoán -->
                            <div class="col-span-1 space-y-4">
                                <div class="bg-white border border-slate-300 rounded shadow-sm">
                                    <div class="bg-slate-100 border-b border-slate-200 px-3 py-1.5 font-bold text-[12px] text-slate-700">2. KHÁM LÂM SÀNG & CHẨN ĐOÁN</div>
                                    <div class="p-3 space-y-3">
                                        <div>
                                            <label class="text-[11px] font-semibold text-slate-500 mb-1 block">Khám các cơ quan / Toàn thân:</label>
                                            <textarea id="input-clinical" class="w-full text-[13px] border border-slate-300 rounded p-2 outline-none focus:border-blue-500 resize-y" rows="3" placeholder="Nhập diễn biến và triệu chứng lâm sàng..."></textarea>
                                        </div>
                                        <div>
                                            <label class="text-[11px] font-semibold text-slate-500 mb-1 block">Mã bệnh / Chẩn đoán (ICD-10):</label>
                                            <div class="flex gap-2">
                                                <input type="text" id="input-icd10-code" class="w-24 text-[13px] border border-slate-300 rounded p-2 outline-none focus:border-blue-500 font-bold text-center uppercase" placeholder="K29.1">
                                                <input type="text" id="input-icd10-name" class="flex-1 text-[13px] border border-slate-300 rounded p-2 outline-none focus:border-blue-500" placeholder="Diễn giải chẩn đoán chi tiết...">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="bg-white border border-slate-300 rounded shadow-sm">
                                    <div class="bg-slate-100 border-b border-slate-200 px-3 py-1.5 font-bold text-[12px] text-slate-700">3. CHỈ ĐỊNH DỊCH VỤ & ĐIỀU TRỊ</div>
                                    <div class="p-3">
                                        <div class="flex gap-2">
                                            <button onclick="openLabModal()" class="flex-1 border border-teal-500 text-teal-700 bg-teal-50 hover:bg-teal-100 py-2 rounded text-[12px] font-bold flex items-center justify-center gap-1 transition-colors">
                                                <span class="material-symbols-outlined text-[16px]">science</span> Xét nghiệm / Chẩn đoán HA
                                            </button>
                                            <button onclick="switchTab('prescriptions')" class="flex-1 border border-blue-500 text-blue-700 bg-blue-50 hover:bg-blue-100 py-2 rounded text-[12px] font-bold flex items-center justify-center gap-1 transition-colors">
                                                <span class="material-symbols-outlined text-[16px]">prescriptions</span> Kê Toa Thuốc
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer Actions -->
                    <div class="bg-slate-100 border-t border-slate-300 p-3 flex justify-between items-center shrink-0">
                        <div class="text-[12px] text-slate-500 flex items-center gap-2">
                            Trạng thái tiếp nhận: <span id="ws-status-badge" class="font-bold text-orange-600 bg-orange-100 px-2 py-0.5 rounded">Đang chờ</span>
                        </div>
                        <div class="flex gap-2">
                            <button onclick="saveDraft()" class="px-4 py-1.5 border border-slate-300 bg-white text-slate-700 font-bold rounded hover:bg-slate-200 text-[12px] transition-colors">Lưu Nháp</button>
                            <button onclick="finishExam()" class="px-5 py-1.5 bg-[#00346f] text-white font-bold rounded hover:bg-[#002244] text-[12px] flex items-center gap-1 transition-colors">
                                <span class="material-symbols-outlined text-[16px]">done_all</span> Hoàn tất bệnh án
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- VIEW: EMR -->
            <div id="view-emr" class="hidden h-full flex flex-col gap-6">
                <!-- EMR Header -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col md:flex-row md:items-center justify-between gap-4 shrink-0">
                    <div>
                        <h2 class="font-bold text-[20px] text-slate-800">Tra cứu Hồ sơ Bệnh án điện tử</h2>
                        <p class="text-[13px] text-slate-500">Hệ thống lưu trữ tập trung dữ liệu khám chữa bệnh của bệnh nhân</p>
                    </div>
                    <div class="flex gap-2">
                        <div class="relative w-72">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                            <input type="text" id="emr-search-input" placeholder="Mã BN, SĐT hoặc CMND/CCCD" class="w-full pl-10 pr-4 py-2.5 border border-slate-300 rounded-lg text-[14px] outline-none focus:border-blue-500 bg-slate-50">
                        </div>
                        <button onclick="searchEMR()" class="bg-[#00346f] text-white px-5 py-2.5 rounded-lg font-bold text-[14px] hover:bg-[#002244] transition-colors flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">search</span> Tra cứu
                        </button>
                    </div>
                </div>

                <!-- EMR Content (Hidden initially, shown after search) -->
                <div id="emr-results" class="hidden flex-1 grid grid-cols-1 lg:grid-cols-3 gap-6 overflow-hidden">
                    <!-- Thông tin hành chính -->
                    <div class="lg:col-span-1 bg-white rounded-2xl shadow-sm border border-slate-200 p-6 overflow-y-auto">
                        <div class="flex items-center gap-4 mb-6">
                            <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center font-bold text-[24px]">H</div>
                            <div>
                                <h3 class="font-bold text-[18px] text-slate-800">Trần Văn Hoàng</h3>
                                <p class="text-[13px] text-slate-500 font-medium tracking-wider">#BN-847291</p>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-[13px] text-slate-500">Giới tính</span>
                                <span class="text-[13px] font-semibold text-slate-800">Nam</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-[13px] text-slate-500">Ngày sinh</span>
                                <span class="text-[13px] font-semibold text-slate-800">12/05/1979 (45 tuổi)</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-[13px] text-slate-500">Số điện thoại</span>
                                <span class="text-[13px] font-semibold text-slate-800">0987.654.321</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-[13px] text-slate-500">Nhóm máu</span>
                                <span class="text-[13px] font-bold text-red-500 bg-red-50 px-2 py-0.5 rounded">O+</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-[13px] text-slate-500">Tiền sử dị ứng</span>
                                <span class="text-[13px] font-semibold text-orange-600">Kháng sinh Penicillin</span>
                            </div>
                        </div>
                        <button class="w-full mt-6 py-2.5 border border-slate-200 rounded-lg text-slate-600 font-bold text-[13px] hover:bg-slate-50 transition-colors flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">edit_note</span> Cập nhật thông tin
                        </button>
                    </div>

                    <!-- Lịch sử khám bệnh (Timeline) -->
                    <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 flex flex-col overflow-hidden">
                        <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
                            <h3 class="font-bold text-[16px] text-slate-800 flex items-center gap-2">
                                <span class="material-symbols-outlined text-blue-600">timeline</span> Lịch sử thăm khám
                            </h3>
                        </div>
                        <div class="flex-1 overflow-y-auto p-6 space-y-8">
                            <!-- Lần khám 1 -->
                            <div class="relative pl-6 border-l-2 border-blue-500">
                                <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-blue-500 border-4 border-white shadow"></div>
                                <p class="text-[12px] font-bold text-blue-600 mb-1">Hôm nay, 24/11/2024 - 09:30 AM</p>
                                <h4 class="font-bold text-[15px] text-slate-800 mb-2">Khoa Nội Tiêu Hóa</h4>
                                <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl space-y-3">
                                    <p class="text-[13px] text-slate-600"><span class="font-semibold text-slate-700">Chẩn đoán:</span> [K29.1] Viêm dạ dày cấp tính.</p>
                                    <p class="text-[13px] text-slate-600"><span class="font-semibold text-slate-700">Lâm sàng:</span> Đau quặn bụng trái, buồn nôn.</p>
                                    <p class="text-[13px] text-slate-600"><span class="font-semibold text-slate-700">Bác sĩ:</span> BS. Nguyễn Văn An</p>
                                    <div class="flex gap-2 mt-2">
                                        <button class="px-3 py-1.5 bg-white border border-slate-200 rounded text-[12px] font-semibold text-blue-600 flex items-center gap-1 hover:bg-blue-50"><span class="material-symbols-outlined text-[14px]">prescriptions</span> Xem Toa</button>
                                        <button class="px-3 py-1.5 bg-white border border-slate-200 rounded text-[12px] font-semibold text-teal-600 flex items-center gap-1 hover:bg-teal-50"><span class="material-symbols-outlined text-[14px]">science</span> KQ Nội soi</button>
                                    </div>
                                </div>
                            </div>
                            <!-- Lần khám 2 -->
                            <div class="relative pl-6 border-l-2 border-slate-200">
                                <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-slate-300 border-4 border-white"></div>
                                <p class="text-[12px] font-bold text-slate-500 mb-1">10/05/2023 - 14:15 PM</p>
                                <h4 class="font-bold text-[15px] text-slate-800 mb-2">Khoa Nội Tổng Hợp</h4>
                                <div class="bg-white border border-slate-100 p-4 rounded-xl space-y-3 opacity-80">
                                    <p class="text-[13px] text-slate-600"><span class="font-semibold text-slate-700">Chẩn đoán:</span> [J06.9] Viêm đường hô hấp trên cấp.</p>
                                    <p class="text-[13px] text-slate-600"><span class="font-semibold text-slate-700">Lâm sàng:</span> Ho khan, sốt nhẹ về chiều.</p>
                                    <p class="text-[13px] text-slate-600"><span class="font-semibold text-slate-700">Bác sĩ:</span> BS. Lê Tuấn</p>
                                    <div class="flex gap-2 mt-2">
                                        <button class="px-3 py-1.5 bg-white border border-slate-200 rounded text-[12px] font-semibold text-blue-600 flex items-center gap-1 hover:bg-blue-50"><span class="material-symbols-outlined text-[14px]">prescriptions</span> Xem Toa</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Initial Empty State -->
                <div id="emr-empty" class="flex-1 bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex items-center justify-center">
                    <div class="text-center text-slate-400">
                        <span class="material-symbols-outlined text-[64px] mb-2 text-slate-300">folder_open</span>
                        <p class="text-[15px] font-medium text-slate-500">Vui lòng nhập Mã BN hoặc SĐT để tra cứu hồ sơ điện tử.</p>
                        <p class="text-[13px] mt-1">Hệ thống sẽ đồng bộ toàn bộ lịch sử khám chữa bệnh.</p>
                    </div>
                </div>
            </div>

            <!-- VIEW: PRESCRIPTIONS -->
            <div id="view-prescriptions" class="hidden h-full flex flex-col overflow-hidden relative">
                
                <!-- STATE 1: DANH SÁCH & KHO THUỐC -->
                <div id="prescriptions-list" class="flex-1 flex flex-col gap-6 h-full overflow-hidden">
                    <!-- Header -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col md:flex-row justify-between items-center gap-4 shrink-0">
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 bg-teal-50 text-teal-600 rounded-xl flex items-center justify-center">
                                <span class="material-symbols-outlined text-[24px]">vaccines</span>
                            </div>
                            <div>
                                <h2 class="font-bold text-[20px] text-slate-800">Kho Thuốc & Đơn Mẫu</h2>
                                <p class="text-[13px] text-slate-500">Quản lý danh mục thuốc và các phác đồ điều trị mẫu</p>
                            </div>
                        </div>
                        <div class="flex gap-3">
                            <button onclick="togglePrescriptionView('create')" class="bg-[#00346f] text-white px-5 py-2.5 rounded-xl font-bold text-[14px] hover:bg-[#002244] flex items-center gap-2 shadow-sm transition-colors">
                                <span class="material-symbols-outlined text-[20px]">add_circle</span> Tạo Đơn Mẫu Mới
                            </button>
                        </div>
                    </div>

                    <!-- Content grid -->
