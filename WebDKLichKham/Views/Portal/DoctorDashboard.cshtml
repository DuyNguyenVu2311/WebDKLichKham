        </div>
    </main>

    <script>
        // Set current date
        document.getElementById('currentDate').innerText = new Date().toLocaleDateString('vi-VN');

        // Mock Data
        const patients = [
            {
                id: 1, name: "Trần Văn Hoàng", code: "BN-847291", age: 45, gender: "Nam",
                status: "Đang chờ", stt: "06", reason: "Đau quặn bụng trái",
                weight: "68kg", bloodType: "O+",
                history: "Viêm loét dạ dày mãn tính (2020), Dị ứng Penicillin.",
                reasonDetail: "Bệnh nhân khai đau quặn vùng bụng trái sau khi ăn, kèm buồn nôn kéo dài 2 ngày nay.",
                clinical: "", icd: ""
            },
            {
                id: 2, name: "Lê Thị Thanh", code: "BN-192837", age: 32, gender: "Nữ",
                status: "Đang chờ", stt: "07", reason: "Khám định kỳ",
                weight: "52kg", bloodType: "A",
                history: "Rối loạn tiêu hóa nhẹ.",
                reasonDetail: "Tái khám theo lịch hẹn định kỳ 6 tháng. Thỉnh thoảng đầy hơi khó tiêu.",
                clinical: "", icd: ""
            },
            {
                id: 3, name: "Phạm Minh Đức", code: "BN-556123", age: 28, gender: "Nam",
                status: "Hoàn thành", stt: "05", reason: "Đã kê đơn",
                weight: "75kg", bloodType: "B",
                history: "Không có bệnh lý nền.",
                reasonDetail: "Kiểm tra men gan cao từ đợt khám sức khỏe công ty.",
                clinical: "Bệnh nhân tỉnh táo, gan không to.", icd: "K76.0 - Gan nhiễm mỡ"
            }
        ];

        let activePatientId = 1;

        function renderPatientList() {
            const listEl = document.getElementById('patient-list');
            listEl.innerHTML = '';

            patients.forEach(p => {
                const isActive = p.id === activePatientId;
                const activeClass = isActive ? 'bg-blue-50 border-l-4 border-l-blue-500' : 'hover:bg-slate-50 border-l-4 border-l-transparent';
                
                let statusColor = 'bg-orange-100 text-orange-600';
                if(p.status === 'Hoàn thành') statusColor = 'bg-green-100 text-green-700';
                
                const timeStr = p.id === 1 ? '08:30' : (p.id === 2 ? '09:15' : '10:00');
                
                const html = `
                    <div onclick="selectPatient(${p.id})" class="p-3 border-b border-slate-200 cursor-pointer transition-colors ${activeClass} ${p.status === 'Hoàn thành' && !isActive ? 'opacity-60' : ''}">
                        <div class="flex justify-between items-start mb-1">
                            <span class="font-bold text-[13px] text-[#00346f]">${p.stt}. ${p.name}</span>
                            <span class="${statusColor} text-[10px] font-bold px-1.5 py-0.5 rounded">${p.status}</span>
                        </div>
                        <div class="text-[11px] text-slate-500 flex justify-between mb-1">
                            <span>${p.gender}, ${p.age}T | ${p.code}</span>
                            <span class="font-semibold text-slate-400">${timeStr}</span>
                        </div>
                        <div class="text-[11px] text-slate-600 truncate">
                            Lý do: ${p.reason}
                        </div>
                    </div>
                `;
                listEl.insertAdjacentHTML('beforeend', html);
            });
        }

        function selectPatient(id) {
            // Save current input to mock data before switching
            const currentPatient = patients.find(p => p.id === activePatientId);
            if(currentPatient && currentPatient.status !== 'Hoàn thành') {
                currentPatient.clinical = document.getElementById('input-clinical').value;
                const icdCode = document.getElementById('input-icd10-code').value;
                const icdName = document.getElementById('input-icd10-name').value;
                if(icdCode) currentPatient.icd = `${icdCode} - ${icdName}`;
            }

            activePatientId = id;
            renderPatientList();
            updateWorkspace();
        }

        function updateWorkspace() {
            const p = patients.find(p => p.id === activePatientId);
            if(!p) return;

            // Header info
            document.getElementById('ws-avatar').innerText = p.name.charAt(0);
            document.getElementById('ws-name').innerText = p.name;
            document.getElementById('ws-meta').innerHTML = `
                <span><i class="font-semibold text-slate-500">Mã BN:</i> ${p.code}</span>
                <span><i class="font-semibold text-slate-500">Giới tính:</i> ${p.gender}</span>
                <span><i class="font-semibold text-slate-500">Tuổi:</i> ${p.age}</span>
                <span><i class="font-semibold text-slate-500">Nhóm máu:</i> <b class="text-red-500">${p.bloodType}</b></span>
            `;
            document.getElementById('ws-weight').innerText = p.weight;
            
            // Status badge
            const badge = document.getElementById('ws-status-badge');
            badge.innerText = p.status;
            if(p.status === 'Hoàn thành') {
                badge.className = 'font-bold text-green-700 bg-green-100 px-2 py-0.5 rounded';
            } else {
                badge.className = 'font-bold text-orange-600 bg-orange-100 px-2 py-0.5 rounded';
            }

            // Forms
            document.getElementById('ws-reason').value = p.reasonDetail;
            document.getElementById('ws-history').value = p.history;

            const clin = document.getElementById('input-clinical');
            const icdCode = document.getElementById('input-icd10-code');
            const icdName = document.getElementById('input-icd10-name');
            
            clin.value = p.clinical;
            
            if(p.icd) {
                const parts = p.icd.split(' - ');
                icdCode.value = parts[0] || '';
                icdName.value = parts[1] || '';
            } else {
                icdCode.value = '';
                icdName.value = '';
            }

            if(p.status === 'Hoàn thành') {
                clin.disabled = true;
                icdCode.disabled = true;
                icdName.disabled = true;
            } else {
                clin.disabled = false;
                icdCode.disabled = false;
                icdName.disabled = false;
            }
        }

        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const icon = type === 'success' ? 'check_circle' : 'info';
            const bgColor = type === 'success' ? 'bg-green-50 text-green-700 border-green-200' : 'bg-blue-50 text-blue-700 border-blue-200';
            
            const toast = document.createElement('div');
            toast.className = `toast-enter flex items-center gap-2 p-4 rounded-xl shadow-md border ${bgColor}`;
            toast.innerHTML = `<span class="material-symbols-outlined">${icon}</span> <span class="text-[14px] font-semibold">${message}</span>`;
            
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function saveDraft() {
            showToast('Đã lưu bản nháp bệnh án thành công!', 'success');
        }

        function finishExam() {
            const clin = document.getElementById('input-clinical').value;
            const icdCode = document.getElementById('input-icd10-code').value;
            const icdName = document.getElementById('input-icd10-name').value;
            
            if(!clin || !icdCode) {
                showToast('Vui lòng nhập đầy đủ Khám lâm sàng và Mã ICD-10', 'info');
                return;
            }

            const p = patients.find(p => p.id === activePatientId);
            p.status = 'Hoàn thành';
            p.reason = 'Đã hoàn tất khám';
            p.clinical = clin;
            p.icd = `${icdCode} - ${icdName}`;
            
            showToast('Đã hoàn tất khám và chuyển hồ sơ lưu trữ', 'success');
            renderPatientList();
            updateWorkspace();
        }

        function switchTab(tabId) {
            // Update active states on sidebar
            document.querySelectorAll('nav a').forEach(a => {
                a.classList.remove('bg-white/10', 'border-l-4', 'border-blue-400', 'text-white');
                a.classList.add('text-blue-100', 'border-l-4', 'border-transparent');
                if(a.id === `tab-${tabId}`) {
                    a.classList.add('bg-white/10', 'border-l-4', 'border-blue-400', 'text-white');
                    a.classList.remove('text-blue-100', 'border-transparent');
                }
            });

            // Hide all views
            document.getElementById('view-patients').classList.add('hidden');
            document.getElementById('view-emr').classList.add('hidden');
            document.getElementById('view-prescriptions').classList.add('hidden');

            // Show selected view
            if(tabId === 'patients') {
                document.getElementById('view-patients').classList.remove('hidden');
                document.getElementById('view-patients').classList.add('grid');
                document.getElementById('header-title').innerHTML = `Danh sách bệnh nhân (Hôm nay, <span id="currentDate">${new Date().toLocaleDateString('vi-VN')}</span>)`;
                document.getElementById('header-stats').style.display = 'flex';
            } else if(tabId === 'emr') {
                document.getElementById('view-emr').classList.remove('hidden');
                document.getElementById('header-title').innerText = 'Hệ thống Bệnh án điện tử (EMR)';
                document.getElementById('header-stats').style.display = 'none';
            } else if(tabId === 'prescriptions') {
                document.getElementById('view-prescriptions').classList.remove('hidden');
                document.getElementById('header-title').innerText = 'Quản lý Dược & Toa thuốc';
                document.getElementById('header-stats').style.display = 'none';
            }
        }

        function searchEMR() {
            const input = document.getElementById('emr-search-input').value;
            if(!input) {
                showToast("Vui lòng nhập Mã BN hoặc Số điện thoại để tra cứu!", "error");
                return;
            }
            
            showToast("Đang truy xuất dữ liệu bệnh án hệ thống...", "info");
            
            // Simulate API call
            setTimeout(() => {
                document.getElementById('emr-empty').classList.add('hidden');
                document.getElementById('emr-empty').classList.remove('flex-1', 'flex');
                
                document.getElementById('emr-results').classList.remove('hidden');
                document.getElementById('emr-results').classList.add('flex-1');
                
                showToast("Đã tải thành công hồ sơ bệnh nhân Trần Văn Hoàng.", "success");
            }, 800);
        }

        /* --- PRESCRIPTIONS JS --- */
        function togglePrescriptionView(view) {
            if(view === 'create') {
                document.getElementById('prescriptions-list').classList.add('hidden');
                document.getElementById('prescriptions-list').classList.remove('flex-1', 'flex');
                document.getElementById('prescriptions-create').classList.remove('hidden');
                document.getElementById('prescriptions-create').classList.add('flex-1', 'flex');
            } else {
                document.getElementById('prescriptions-create').classList.add('hidden');
                document.getElementById('prescriptions-create').classList.remove('flex-1', 'flex');
                document.getElementById('prescriptions-list').classList.remove('hidden');
                document.getElementById('prescriptions-list').classList.add('flex-1', 'flex');
            }
        }

        let drugCounter = 0;
        let selectedDrugs = [];

        function addDrugToForm(drugName) {
            const list = document.getElementById('selected-drugs-list');
            const emptyState = document.getElementById('empty-drug-state');
            
            if (emptyState) {
                emptyState.style.display = 'none';
            }

            drugCounter++;
            const trId = `drug-row-${drugCounter}`;
            selectedDrugs.push(drugName);
            
            const tr = document.createElement('tr');
            tr.id = trId;
            tr.innerHTML = `
                <td class="px-4 py-3 font-medium text-slate-500">${drugCounter}</td>
                <td class="px-4 py-3 font-bold text-[#00346f]">${drugName}</td>
                <td class="px-4 py-3 text-center">
                    <input type="number" value="1" min="1" class="w-16 px-2 py-1.5 border border-slate-300 rounded outline-none text-center text-[13px] focus:border-teal-500">
                </td>
                <td class="px-4 py-3">
                    <input type="text" placeholder="VD: Sáng 1 viên, Tối 1 viên sau ăn..." class="w-full px-3 py-1.5 border border-slate-300 rounded outline-none text-[13px] focus:border-teal-500">
                </td>
                <td class="px-4 py-3 text-center">
                    <button onclick="removeDrug('${trId}')" class="text-slate-400 hover:text-red-600 transition-colors">
                        <span class="material-symbols-outlined text-[20px]">delete</span>
                    </button>
                </td>
            `;
            list.appendChild(tr);
            showToast(`Đã thêm ${drugName} vào đơn.`, "success");
        }

        function removeDrug(trId) {
            const tr = document.getElementById(trId);
            if (tr) {
                tr.remove();
            }
            
            const list = document.getElementById('selected-drugs-list');
            if (list.children.length === 1 && list.children[0].id === 'empty-drug-state') {
                document.getElementById('empty-drug-state').style.display = 'table-row';
            } else if (list.querySelectorAll('tr[id^="drug-row"]').length === 0) {
                document.getElementById('empty-drug-state').style.display = 'table-row';
            }
        }

        function saveNewTemplate() {
            const name = document.getElementById('new-template-name').value;
            const rows = document.querySelectorAll('#selected-drugs-list tr[id^="drug-row"]');
            
            if(!name) {
                showToast("Vui lòng nhập Tên phác đồ / Đơn mẫu!", "error");
                return;
            }
            if(rows.length === 0) {
                showToast("Vui lòng thêm ít nhất một loại thuốc vào đơn!", "error");
                return;
            }

            // Mở rộng thêm vào danh sách Toa thuốc mẫu (UI mock)
            let drugTexts = [];
            rows.forEach(r => {
                const drugName = r.querySelector('td:nth-child(2)').innerText;
                const quantity = r.querySelector('td:nth-child(3) input').value;
                drugTexts.push(`• ${drugName} - <span class="font-semibold text-slate-800">${quantity}</span>`);
            });

            const templateHTML = `
                <div class="border border-green-200 rounded-xl overflow-hidden hover:border-green-500 transition-colors group bg-green-50/30 shadow-sm animate-pulse-once">
                    <div class="bg-green-100 p-3 border-b border-green-200 flex justify-between items-center">
                        <h4 class="font-bold text-[14px] text-green-800">${name} (Mới)</h4>
                        <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button class="text-slate-400 hover:text-blue-600"><span class="material-symbols-outlined text-[18px]">edit</span></button>
                            <button class="text-slate-400 hover:text-red-600"><span class="material-symbols-outlined text-[18px]">delete</span></button>
                        </div>
                    </div>
                    <div class="p-3 text-[12px] text-slate-600 space-y-1">
                        ${drugTexts.join('')}
                    </div>
                </div>
            `;
            
            const container = document.getElementById('template-list-container');
            container.insertAdjacentHTML('afterbegin', templateHTML);

            showToast("Đã lưu Phác đồ điều trị thành công!", "success");
            
            // Reset form & Go back
            document.getElementById('new-template-name').value = '';
            document.querySelectorAll('#selected-drugs-list tr[id^="drug-row"]').forEach(tr => tr.remove());
            document.getElementById('empty-drug-state').style.display = 'table-row';
            drugCounter = 0;
            
            togglePrescriptionView('list');
        }

        /* --- LAB ORDERS JS --- */
        function openLabModal() {
            const p = patients.find(p => p.id === activePatientId);
            if(p && p.status === 'Hoàn thành') {
                showToast("Bệnh nhân này đã hoàn tất khám, không thể chỉ định thêm!", "error");
                return;
            }

            const modal = document.getElementById('lab-modal');
            const content = document.getElementById('lab-modal-content');
            
            // Reset checkboxes
            document.querySelectorAll('.lab-checkbox').forEach(cb => cb.checked = false);
            calcLabTotal();

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            // Animate pop in
            setTimeout(() => {
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closeLabModal() {
            const modal = document.getElementById('lab-modal');
            const content = document.getElementById('lab-modal-content');
            
            // Animate pop out
            content.classList.remove('scale-100', 'opacity-100');
            content.classList.add('scale-95', 'opacity-0');
            
            setTimeout(() => {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            }, 200);
        }

        function calcLabTotal() {
            const checkboxes = document.querySelectorAll('.lab-checkbox');
            let total = 0;
            let count = 0;
            
            checkboxes.forEach(cb => {
                if (cb.checked) {
                    count++;
                    total += parseInt(cb.dataset.price);
                }
            });
            
            document.getElementById('lab-count').innerText = count;
            document.getElementById('lab-total').innerText = total.toLocaleString('vi-VN');
        }

        function submitLabOrder() {
            const count = parseInt(document.getElementById('lab-count').innerText);
            if(count === 0) {
                showToast("Vui lòng tick chọn ít nhất 1 dịch vụ để chỉ định!", "error");
                return;
            }
            
            closeLabModal();
            showToast(`Đã gửi yêu cầu ${count} dịch vụ Xét nghiệm/CĐHA xuống quầy Thu ngân`, "success");
        }

        // Init
        renderPatientList();
        updateWorkspace();
    </script>
</body>
</html>
