    <!-- TOAST CONTAINER -->
    <div id="toast-container" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none"></div>

    <script>
        // Hiển thị thông báo (Toast)
        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const icon = type === 'success' ? 'check_circle' : (type === 'error' ? 'error' : 'info');
            const bgColor = type === 'success' ? 'bg-green-50 text-green-700 border-green-200' : 
                           (type === 'error' ? 'bg-red-50 text-red-700 border-red-200' : 'bg-blue-50 text-blue-700 border-blue-200');
            
            const toast = document.createElement('div');
            toast.className = `flex items-center gap-2 p-4 rounded-xl shadow-md border ${bgColor} transition-opacity duration-300 opacity-0 pointer-events-auto`;
            toast.innerHTML = `<span class="material-symbols-outlined">${icon}</span> <span class="text-[14px] font-semibold">${message}</span>`;
            
            container.appendChild(toast);
            
            requestAnimationFrame(() => {
                toast.style.opacity = '1';
            });
            
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Đóng/Mở Modal dùng chung
        function openModal(modalId, contentId, renderFunc = null) {
            const modal = document.getElementById(modalId);
            const content = document.getElementById(contentId);
            
            if(renderFunc) renderFunc();

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            setTimeout(() => {
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closeModal(modalId, contentId) {
            const modal = document.getElementById(modalId);
            const content = document.getElementById(contentId);
            
            content.classList.remove('scale-100', 'opacity-100');
            content.classList.add('scale-95', 'opacity-0');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 200);
        }

        // Tính năng: Xem Toa Thuốc
        function viewPrescription(type) {
            openModal('prescription-modal', 'rx-modal-content', () => {
                const rxContent = document.getElementById('rx-content');
                if(type === 'recent') {
                    rxContent.innerHTML = `
                        <div class="text-center mb-6">
                            <h3 class="font-bold text-[18px] text-slate-800 uppercase">Đơn Thuốc Mới Nhất</h3>
                            <p class="text-slate-500 text-[13px]">Ngày kê: 23/05/2026 - BS. Nguyễn Văn An</p>
                        </div>
                        <table class="w-full text-left text-[13px]">
                            <thead class="bg-slate-100 border-b border-slate-200 text-slate-600 font-semibold">
                                <tr>
                                    <th class="px-4 py-3">Tên thuốc</th>
                                    <th class="px-4 py-3 text-center">SL</th>
                                    <th class="px-4 py-3">Liều dùng</th>
                                </tr>
