                            <tbody class="divide-y divide-slate-100 text-slate-800 font-medium">
                                <tr>
                                    <td class="px-4 py-3 text-blue-700">1. Nexium Mups 40mg</td>
                                    <td class="px-4 py-3 text-center">28 Viên</td>
                                    <td class="px-4 py-3 text-slate-600 italic text-[12px]">Ngày 2 viên, sáng 1 viên, tối 1 viên trước ăn 30p</td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-3 text-blue-700">2. Amoxicillin 500mg</td>
                                    <td class="px-4 py-3 text-center">56 Viên</td>
                                    <td class="px-4 py-3 text-slate-600 italic text-[12px]">Ngày 4 viên chia 2 lần sau ăn</td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-3 text-blue-700">3. Clarithromycin 500mg</td>
                                    <td class="px-4 py-3 text-center">28 Viên</td>
                                    <td class="px-4 py-3 text-slate-600 italic text-[12px]">Ngày 2 viên chia 2 lần sau ăn</td>
                                </tr>
                            </tbody>
                        </table>
                    `;
                } else {
                    rxContent.innerHTML = `
                        <div class="text-center mb-6">
                            <h3 class="font-bold text-[18px] text-slate-800 uppercase">Đơn Thuốc Cũ</h3>
                            <p class="text-slate-500 text-[13px]">Ngày kê: 10/11/2025 - BS. Lê Tuấn</p>
                        </div>
                        <table class="w-full text-left text-[13px]">
                            <thead class="bg-slate-100 border-b border-slate-200 text-slate-600 font-semibold">
                                <tr>
                                    <th class="px-4 py-3">Tên thuốc</th>
                                    <th class="px-4 py-3 text-center">SL</th>
                                    <th class="px-4 py-3">Liều dùng</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 text-slate-800 font-medium">
                                <tr>
                                    <td class="px-4 py-3 text-blue-700">1. Panadol Extra 500mg</td>
                                    <td class="px-4 py-3 text-center">10 Viên</td>
                                    <td class="px-4 py-3 text-slate-600 italic text-[12px]">Uống khi sốt trên 38.5 độ</td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-3 text-blue-700">2. Alpha Choay</td>
                                    <td class="px-4 py-3 text-center">20 Viên</td>
                                    <td class="px-4 py-3 text-slate-600 italic text-[12px]">Ngậm dưới lưỡi ngày 4 viên chia 2 lần</td>
                                </tr>
                            </tbody>
                        </table>
                    `;
                }
            });
        }

        // Tính năng: Xem KQ Nội soi
        function viewLabResult() {
            openModal('lab-result-modal', 'lab-result-content');
        }

        function downloadInvoice() {
            openModal('invoice-modal', 'invoice-content');
        }

        // Tính năng: Thanh toán Viện phí
        function payBill() {
            showToast('Đang kết nối cổng thanh toán VNPay...', 'info');
            setTimeout(() => {
                showToast('Thanh toán thành công 600.000đ!', 'success');
                // Chuyển UI box thanh toán thành trạng thái hoàn tất
                document.getElementById('billing-card').innerHTML = `
                    <div class="p-6 flex flex-col items-center text-center">
                        <span class="material-symbols-outlined text-[64px] text-green-500 mb-2">check_circle</span>
                        <h3 class="font-bold text-[16px] text-slate-800 mb-1">Không có nợ viện phí</h3>
                        <p class="text-[13px] text-slate-500">Bạn đã thanh toán đầy đủ các khoản chi phí hiện tại.</p>
                        <button onclick="downloadInvoice()" class="mt-4 px-4 py-2 border border-slate-200 rounded-lg text-[13px] font-bold text-slate-600 hover:bg-slate-50 flex items-center gap-2">
                            <span class="material-symbols-outlined text-[16px] text-red-500">picture_as_pdf</span> Tải hóa đơn điện tử
                        </button>
                    </div>
                `;
            }, 1500);
        }

        // Tính năng: Dời / Hủy lịch
        // Logic thực tế: Hôm nay là 23/05, lịch khám là 26/05 (còn đúng 3 ngày) -> Được dời! Nhưng giả sử còn 2 ngày thì từ chối.
        function validateReschedulePolicy() {
            const today = new Date('2026-05-23');
            const apptDate = new Date('2026-05-26');
            const diffTime = Math.abs(apptDate - today);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)); 
            
            if(diffDays < 3) {
                showToast('Chỉ được dời/hủy lịch trước ít nhất 3 ngày. Vui lòng gọi Hotline để hỗ trợ gấp!', 'error');
                return false;
            }
            return true;
        }

        function rescheduleAppt() {
            if(!validateReschedulePolicy()) return;
            showToast('Vui lòng chọn ngày giờ mới trên hệ thống', 'info');
            setTimeout(() => {
                window.location.href = "/Home/Index#booking-form";
            }, 1500);
        }

        function cancelAppt() {
            if(!validateReschedulePolicy()) return;
            if(confirm("Bạn có chắc chắn muốn hủy lịch hẹn khám Tiêu hóa ngày 26/05/2026 không?")) {
                showToast('Đã hủy lịch hẹn thành công', 'success');
                const apptBox = document.getElementById('upcoming-appt');
                apptBox.style.opacity = '0.5';
                apptBox.style.pointerEvents = 'none';
                apptBox.innerHTML = `
                    <div class="text-center p-6 border border-dashed border-slate-300 rounded-2xl bg-slate-50">
                        <span class="material-symbols-outlined text-[48px] text-slate-400 mb-2">event_busy</span>
                        <p class="font-bold text-slate-600 text-[14px]">Đã hủy lịch hẹn</p>
                    </div>
                `;
            }
        }

        // Tính năng: Chat Bác sĩ
        function chatDoctor() {
            showToast('Đang khởi tạo kết nối mã hóa với Bác sĩ điều trị...', 'info');
        }

        // Toggle Notifications
        function toggleNotifications() {
            const dropdown = document.getElementById('notif-dropdown');
            if (dropdown.classList.contains('hidden')) {
                dropdown.classList.remove('hidden');
            } else {
                dropdown.classList.add('hidden');
            }
        }
        
        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
            const dropdown = document.getElementById('notif-dropdown');
            const btn = document.getElementById('notif-btn');
            if (!btn.contains(event.target) && !dropdown.contains(event.target)) {
                dropdown.classList.add('hidden');
            }
        });

        // Tái khám: Cập nhật tình trạng triệu chứng và phác đồ
        function setFollowUpStatus(apptId, status) {
            fetch('/Portal/UpdateSymptomStatus', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'appointmentId=' + apptId + '&status=' + encodeURIComponent(status)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const giamBtn = document.getElementById('btn-giam-' + apptId);
                    const chuagiamBtn = document.getElementById('btn-chuagiam-' + apptId);
                    const giamIcon = document.getElementById('icon-giam-' + apptId);
                    const chuagiamIcon = document.getElementById('icon-chuagiam-' + apptId);
                    const giamPhacdo = document.getElementById('phacdo-giamphe-' + apptId);
                    const chuagiamPhacdo = document.getElementById('phacdo-chuagiam-' + apptId);

                    // Reset styling
                    giamBtn.className = 'symptom-btn-' + apptId + ' flex items-center justify-between px-4 py-2.5 rounded-xl border text-[13px] font-medium transition-all bg-white hover:bg-slate-50 border-slate-200 text-slate-700';
                    chuagiamBtn.className = 'symptom-btn-' + apptId + ' flex items-center justify-between px-4 py-2.5 rounded-xl border text-[13px] font-medium transition-all bg-white hover:bg-slate-50 border-slate-200 text-slate-700';
                    giamIcon.classList.add('hidden');
                    chuagiamIcon.classList.add('hidden');
                    giamPhacdo.classList.add('hidden');
                    chuagiamPhacdo.classList.add('hidden');

                    if (status === 'Giảm nhiều') {
                        giamBtn.className = 'symptom-btn-' + apptId + ' flex items-center justify-between px-4 py-2.5 rounded-xl border text-[13px] font-medium transition-all border-emerald-500 bg-emerald-50/30 text-emerald-700';
                        giamIcon.classList.remove('hidden');
                        giamPhacdo.classList.remove('hidden');
                        showToast('Đã ghi nhận triệu chứng: Giảm nhiều', 'success');
                    } else if (status === 'Chưa giảm') {
                        chuagiamBtn.className = 'symptom-btn-' + apptId + ' flex items-center justify-between px-4 py-2.5 rounded-xl border text-[13px] font-medium transition-all border-amber-500 bg-amber-50/30 text-amber-700';
                        chuagiamIcon.classList.remove('hidden');
                        chuagiamPhacdo.classList.remove('hidden');
                        showToast('Đã ghi nhận triệu chứng: Chưa giảm', 'warning');
                    }
                } else {
                    showToast(data.message || 'Lỗi cập nhật trạng thái', 'error');
                }
            })
            .catch(err => {
                console.error(err);
                showToast('Không thể kết nối đến máy chủ', 'error');
            });
        }
    </script>
