@model WebDKLichKham.Models.PatientProfile
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hồ sơ sức khỏe cá nhân - Phòng Khám Đa Khoa Duy Tâm</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f1f5f9; }
    </style>
</head>
<body class="text-slate-800">

    <!-- Navbar -->
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-[1280px] mx-auto px-4 md:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-2 text-[#00346f]">
                <span class="material-symbols-outlined text-[28px]">health_and_safety</span>
                <span class="font-bold text-[18px] hidden md:inline">Phòng Khám Đa Khoa Duy Tâm</span>
                <span class="font-bold text-[18px] md:hidden">PK Duy Tâm</span>
            </div>
            <div class="flex items-center gap-4">
                <div class="relative">
                    <button onclick="toggleNotifications()" id="notif-btn" class="relative text-slate-500 hover:text-[#00346f] p-1 rounded-full hover:bg-slate-100 transition-colors focus:outline-none">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-1 right-1 w-2.5 h-2.5 bg-red-500 border-2 border-white rounded-full"></span>
                    </button>
                    
                    <!-- Notification Dropdown -->
                    <div id="notif-dropdown" class="hidden absolute right-[-40px] md:right-0 mt-2 w-[320px] bg-white rounded-xl shadow-xl border border-slate-200 z-[100] overflow-hidden origin-top-right transition-all">
                        <div class="p-3 border-b border-slate-100 bg-slate-50 flex justify-between items-center">
                            <h3 class="font-bold text-slate-800 text-[14px]">Thông báo</h3>
                            <span class="text-[11px] text-[#00346f] font-semibold bg-blue-100 px-2 py-0.5 rounded-full">3 mới</span>
                        </div>
                        <div class="max-h-[350px] overflow-y-auto">
                            <!-- Lịch hẹn sắp tới -->
                            <a href="#upcoming-appt" onclick="toggleNotifications()" class="block p-3 border-b border-slate-50 hover:bg-slate-50 transition-colors bg-blue-50/40">
                                <div class="flex gap-3">
                                    <div class="w-9 h-9 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center shrink-0 mt-0.5 shadow-sm border border-orange-200/50">
                                        <span class="material-symbols-outlined text-[18px]">event</span>
                                    </div>
                                    <div>
                                        <p class="text-[13px] font-bold text-slate-800 mb-0.5">Lịch hẹn sắp tới</p>
                                        <p class="text-[12px] text-slate-600 leading-snug">Bạn có lịch Khám Tiêu hóa vào 09:30 AM ngày 26/05/2026. Vui lòng đến đúng giờ.</p>
                                        <p class="text-[10px] text-slate-400 mt-1 font-medium">10 phút trước</p>
                                    </div>
                                </div>
                            </a>
                            <!-- Kết quả cận lâm sàng -->
                            <a href="#" onclick="viewLabResult(); toggleNotifications();" class="block p-3 border-b border-slate-50 hover:bg-slate-50 transition-colors bg-blue-50/40">
                                <div class="flex gap-3">
                                    <div class="w-9 h-9 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0 mt-0.5 shadow-sm border border-green-200/50">
                                        <span class="material-symbols-outlined text-[18px]">science</span>
                                    </div>
                                    <div>
                                        <p class="text-[13px] font-bold text-slate-800 mb-0.5">Kết quả cận lâm sàng</p>
                                        <p class="text-[12px] text-slate-600 leading-snug">Phiếu kết quả Nội soi dạ dày (NS-260501) đã được cập nhật vào hồ sơ bệnh án.</p>
                                        <p class="text-[10px] text-slate-400 mt-1 font-medium">1 giờ trước</p>
                                    </div>
                                </div>
                            </a>
                            <!-- Đơn thuốc -->
                            <a href="#" onclick="viewPrescription('recent'); toggleNotifications();" class="block p-3 border-b border-slate-50 hover:bg-slate-50 transition-colors bg-blue-50/40">
                                <div class="flex gap-3">
                                    <div class="w-9 h-9 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center shrink-0 mt-0.5 shadow-sm border border-blue-200/50">
                                        <span class="material-symbols-outlined text-[18px]">prescriptions</span>
                                    </div>
                                    <div>
                                        <p class="text-[13px] font-bold text-slate-800 mb-0.5">Đơn thuốc mới</p>
                                        <p class="text-[12px] text-slate-600 leading-snug">BS. Nguyễn Văn An vừa kê đơn thuốc mới. Vui lòng thanh toán viện phí để nhận thuốc.</p>
                                        <p class="text-[10px] text-slate-400 mt-1 font-medium">2 giờ trước</p>
                                    </div>
                                </div>
                            </a>
                            <!-- Đã khám (Read) -->
                            <a href="#" class="block p-3 hover:bg-slate-50 transition-colors opacity-60">
                                <div class="flex gap-3">
                                    <div class="w-9 h-9 rounded-full bg-slate-200 text-slate-600 flex items-center justify-center shrink-0 mt-0.5 shadow-sm border border-slate-300/50">
                                        <span class="material-symbols-outlined text-[18px]">check_circle</span>
                                    </div>
                                    <div>
                                        <p class="text-[13px] font-bold text-slate-800 mb-0.5">Hoàn thành khám bệnh</p>
                                        <p class="text-[12px] text-slate-600 leading-snug">Buổi khám Nội tổng hợp ngày 10/11/2025 đã hoàn tất.</p>
                                        <p class="text-[10px] text-slate-400 mt-1 font-medium">10/11/2025</p>
                                    </div>
                                </div>
                            </a>
                        </div>
                        <div class="p-2 border-t border-slate-100 text-center bg-slate-50">
                            <button onclick="toggleNotifications()" class="text-[12px] font-bold text-[#00346f] hover:underline bg-transparent border-none cursor-pointer">Đóng thông báo</button>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-2 border-l border-slate-200 pl-4">
                    <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-[14px]">@(string.IsNullOrEmpty(Model.FullName) ? "K" : Model.FullName.Substring(0, 1).ToUpper())</div>
                    <div class="hidden md:block">
                        <p class="text-[13px] font-bold text-slate-700 leading-none mb-0.5">@Model.FullName</p>
                        <p class="text-[11px] text-slate-500 leading-none">Khách hàng thành viên</p>
                    </div>
                </div>
                <a href="/" class="text-[#00346f] hover:bg-blue-50 px-3 py-2 rounded-lg font-semibold text-[14px] transition-colors flex items-center gap-1"><span class="material-symbols-outlined text-[20px]">home</span> Trang chủ</a>
                <a href="/Home/LogoutPortal" class="text-red-500 hover:bg-red-50 p-2 rounded-lg ml-2" title="Đăng xuất"><span class="material-symbols-outlined text-[20px]">logout</span></a>
            </div>
        </div>
    </nav>

    <div class="max-w-[1280px] mx-auto px-4 md:px-8 py-8">
        <!-- Patient Banner -->
        <div class="bg-gradient-to-r from-[#00346f] to-[#0052a3] rounded-2xl p-6 md:p-8 text-white shadow-md flex flex-col md:flex-row justify-between items-center gap-6 mb-8 relative overflow-hidden">
            <span class="material-symbols-outlined absolute -right-10 -bottom-10 text-[180px] text-white/10 select-none">ecg_heart</span>
            <div class="flex items-center gap-5 z-10 w-full">
                <div class="w-20 h-20 bg-white/20 rounded-full flex items-center justify-center font-bold text-[36px] backdrop-blur-sm border-2 border-white/40">@(string.IsNullOrEmpty(Model.FullName) ? "K" : Model.FullName.Substring(0, 1).ToUpper())</div>
                <div>
                    <h1 class="text-[26px] font-bold mb-1">@Model.FullName</h1>
                    <div class="flex flex-wrap gap-x-6 gap-y-1 text-blue-100 text-[14px]">
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">pin</span> Mã BN: BN-@(Model.Id.ToString("D6"))</span>
                        @{
                            var age = 0;
                            if (Model.DateOfBirth.HasValue)
                            {
                                age = DateTime.Today.Year - Model.DateOfBirth.Value.Year;
                                if (Model.DateOfBirth.Value.Date > DateTime.Today.AddYears(-age)) age--;
                            }
                        }
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">@(Model.Gender == "Nữ" ? "female" : "male")</span> Giới tính: @Model.Gender@(Model.DateOfBirth.HasValue ? $", {age} tuổi" : "")</span>
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">badge</span> CCCD: <b class="text-white">@(Model.IdentityCard ?? "Chưa cập nhật")</b></span>
                    </div>
                </div>
            </div>
            <div class="z-10 shrink-0 w-full md:w-auto">
                <a href="/Home/Index#booking-form" class="w-full md:w-auto bg-white text-[#00346f] px-6 py-3 rounded-xl font-bold text-[14px] hover:bg-blue-50 transition-colors flex items-center justify-center gap-2 shadow-sm">
                    <span class="material-symbols-outlined text-[20px]">calendar_add_on</span> Đặt lịch khám mới
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Cột trái: Timeline & Lịch sử khám -->
            <div class="lg:col-span-2 space-y-8">
                
                <!-- Lịch hẹn sắp tới -->
                <div id="upcoming-appt" class="transition-opacity duration-300">
                    <h2 class="flex items-center gap-2 text-[18px] font-bold text-slate-800 mb-4">
                        <span class="material-symbols-outlined text-orange-500">event_upcoming</span> Lịch hẹn sắp tới
                    </h2>
                    
                    @{
                        var upcomingAppointments = Model.Appointments
                            .Where(a => a.AppointmentDate >= DateTime.Today && a.Status != AppointmentStatus.Cancelled && a.Status != AppointmentStatus.Completed)
                            .OrderBy(a => a.AppointmentDate)
                            .ThenBy(a => a.StartTime)
                            .ToList();
                    }

                    @if (upcomingAppointments.Any())
                    {
                        @foreach (var appt in upcomingAppointments)
                        {
                            var days = new[] { "Chủ Nhật", "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7" };
                            var dayOfWeekStr = days[(int)appt.AppointmentDate.DayOfWeek];
                            
                            <div class="bg-white border border-orange-200 rounded-2xl p-5 shadow-sm relative overflow-hidden group hover:shadow-md transition-shadow mb-4">
                                <div class="absolute top-0 left-0 w-1.5 h-full bg-orange-500"></div>
                                <div class="flex flex-col md:flex-row items-center gap-6 justify-between">
                                    <div class="flex items-center gap-5 w-full">
                                        <div class="w-16 h-16 bg-orange-50 rounded-xl border border-orange-100 flex flex-col items-center justify-center text-orange-600 shrink-0">
                                            <span class="text-[11px] font-bold uppercase">@dayOfWeekStr</span>
                                            <span class="text-[24px] font-black leading-none mt-0.5">@appt.AppointmentDate.Day</span>
                                        </div>
                                        <div>
                                            <h3 class="font-bold text-slate-800 text-[16px] mb-1">@(appt.MedicalService ?? (appt.Doctor?.SpecialtyInfo?.Name ?? appt.Doctor?.Specialty ?? "Khám bệnh"))</h3>
                                            <p class="text-[13px] text-slate-500 mb-1">
                                                Bác sĩ: @(appt.Doctor?.FullName ?? "Bác sĩ Duy Tâm") • @(string.IsNullOrWhiteSpace(appt.Notes) || !appt.Notes.StartsWith("[") ? "Cơ sở 1" : appt.Notes.Substring(appt.Notes.IndexOf("[") + 1, appt.Notes.IndexOf("]") - appt.Notes.IndexOf("[") - 1))
                                            </p>
                                            <div class="flex items-center gap-2 text-[13px] font-semibold text-orange-600">
                                                <span class="material-symbols-outlined text-[16px]">schedule</span> @appt.StartTime.ToString(@"hh\:mm")
                                                <span class="text-slate-300">•</span>
                                                <span class="text-slate-500 font-normal">@(appt.Status == AppointmentStatus.Pending ? "Chờ xác nhận" : "Đã xác nhận")</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="flex gap-2 w-full md:w-auto shrink-0 justify-end mt-4 md:mt-0">
                                        <a href="/Home/Index#booking-form" class="px-4 py-2 bg-white border border-slate-300 rounded-lg text-[13px] font-bold text-slate-600 hover:bg-slate-50 transition-colors no-underline">Dời lịch</a>
                                        <button onclick="alert('Vui lòng liên hệ hotline 1900 1234 để hủy lịch hẹn đã đặt.')" class="px-4 py-2 bg-white border border-red-200 rounded-lg text-[13px] font-bold text-red-600 hover:bg-red-50 transition-colors">Hủy</button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="bg-white border border-slate-200 rounded-2xl p-6 text-center shadow-sm mb-6">
                            <span class="material-symbols-outlined text-slate-300 text-[48px] mb-2">calendar_today</span>
                            <p class="text-[14px] text-slate-500 font-medium">Bạn chưa có lịch hẹn sắp tới nào.</p>
                            <a href="/Home/Index#booking-form" class="inline-flex items-center gap-1.5 text-[13px] font-bold text-[#00346f] hover:underline mt-2">Đặt lịch ngay <span class="material-symbols-outlined text-[16px]">arrow_forward</span></a>
                        </div>
                    }
                </div>

                <!-- Dòng thời gian Khám chữa bệnh -->
                <div>
                    <h2 class="flex items-center gap-2 text-[18px] font-bold text-slate-800 mb-4">
                        <span class="material-symbols-outlined text-blue-600">history_edu</span> Hồ sơ Bệnh án Điện tử (EMR)
                    </h2>
                    
                    <div class="relative pl-6 space-y-8 before:absolute before:inset-0 before:ml-[11px] before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-blue-500 before:to-slate-200">
                        
                        @{
                            var pastAppointments = Model.Appointments
                                .Where(a => a.Status == AppointmentStatus.Completed || a.AppointmentDate < DateTime.Today)
                                .OrderByDescending(a => a.AppointmentDate)
                                .ThenByDescending(a => a.StartTime)
                                .ToList();
                        }

                        @if (pastAppointments.Any())
                        {
                            @foreach (var appt in pastAppointments)
                            {
                                <div class="relative">
                                    <div class="absolute -left-[31px] w-5 h-5 bg-blue-500 rounded-full border-4 border-[#f1f5f9] shadow flex items-center justify-center">
                                        <div class="w-1.5 h-1.5 bg-white rounded-full"></div>
                                    </div>
                                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden hover:border-blue-300 transition-colors">
                                        <div class="p-4 border-b border-slate-100 bg-slate-50 flex justify-between items-center">
                                            <div class="flex flex-col">
                                                <span class="text-[12px] font-bold text-blue-600 mb-0.5">@appt.AppointmentDate.ToString("dd/MM/yyyy")</span>
                                                <h3 class="font-bold text-[15px] text-slate-800">@(appt.MedicalService ?? (appt.Doctor?.SpecialtyInfo?.Name ?? appt.Doctor?.Specialty ?? "Khám bệnh"))</h3>
                                            </div>
                                            <span class="bg-green-100 text-green-700 font-bold text-[11px] px-2.5 py-1 rounded-md">Đã hoàn thành</span>
                                        </div>
                                        <div class="p-5">
                                            <div class="bg-blue-50/50 p-4 rounded-xl border border-blue-100 mb-4">
                                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-[13px]">
                                                    <div>
                                                        <p class="text-slate-500 font-medium mb-0.5">Bác sĩ khám:</p>
                                                        <p class="font-bold text-slate-800">@(appt.Doctor?.FullName ?? "Bác sĩ Duy Tâm")</p>
                                                    </div>
                                                    <div>
                                                        <p class="text-slate-500 font-medium mb-0.5">Chẩn đoán (ICD-10):</p>
                                                        <p class="font-bold text-red-600">@(appt.ReasonForVisit ?? "Khám sức khỏe tổng quát")</p>
                                                    </div>
                                                    <div class="md:col-span-2 mt-2 pt-2 border-t border-blue-200">
                                                        <p class="text-slate-500 font-medium mb-0.5">Lời dặn của Bác sĩ:</p>
                                                        <p class="text-slate-700 italic">"Uống thuốc đúng giờ theo đơn, uống nhiều nước, tái khám khi có dấu hiệu bất thường."</p>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Khối chỉ định Tái khám Y khoa -->
                                            <div class="mt-4 pt-4 border-t border-slate-200 mb-4">
                                                <div class="bg-[#f0f9ff] border border-blue-200 p-4 rounded-xl">
                                                    <div class="flex items-start gap-3">
                                                        <span class="material-symbols-outlined text-[#0284c7] shrink-0 mt-0.5">clinical_notes</span>
                                                        <div class="w-full">
                                                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-2">
                                                                <h4 class="text-[14px] font-bold text-[#0369a1]">Kế hoạch điều trị: Tái khám định kỳ</h4>
                                                                <span class="bg-[#0284c7]/10 text-[#0284c7] font-bold text-[10px] px-2 py-0.5 rounded">Hẹn sau 7 ngày</span>
                                                            </div>
                                                            <p class="text-[12.5px] text-slate-600 mb-4">
                                                                Thời gian tái khám đề xuất: <strong>@appt.AppointmentDate.AddDays(7).ToString("dd/MM/yyyy")</strong>. Bác sĩ cần đánh giá tiến triển của chẩn đoán: <em>@(appt.ReasonForVisit ?? "Viêm dạ dày cấp tính")</em>.
                                                            </p>
                                                            
                                                            <div class="space-y-2 mb-4">
                                                                <div class="text-[12.5px] font-semibold text-slate-700">Đánh giá tình trạng triệu chứng hiện tại của bạn:</div>
                                                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                                                    <button type="button" onclick="setFollowUpStatus(@appt.Id, 'Giảm nhiều')" id="btn-giam-@appt.Id" class="symptom-btn-@appt.Id flex items-center justify-between px-4 py-2.5 rounded-xl border text-[13px] font-medium transition-all @(appt.FollowUpSymptoms == "Giảm nhiều" ? "border-emerald-500 bg-emerald-50/30 text-emerald-700" : "border-slate-200 text-slate-700 bg-white hover:bg-slate-50")">
                                                                        <span>Triệu chứng đã giảm nhiều</span>
                                                                        <span class="material-symbols-outlined text-emerald-600 text-[18px] @(appt.FollowUpSymptoms == "Giảm nhiều" ? "" : "hidden")" id="icon-giam-@appt.Id">check_circle</span>
                                                                    </button>
                                                                    <button type="button" onclick="setFollowUpStatus(@appt.Id, 'Chưa giảm')" id="btn-chuagiam-@appt.Id" class="symptom-btn-@appt.Id flex items-center justify-between px-4 py-2.5 rounded-xl border text-[13px] font-medium transition-all @(appt.FollowUpSymptoms == "Chưa giảm" ? "border-amber-500 bg-amber-50/30 text-amber-700" : "border-slate-200 text-slate-700 bg-white hover:bg-slate-50")">
                                                                        <span>Chưa giảm / Cần theo dõi thêm</span>
                                                                        <span class="material-symbols-outlined text-amber-600 text-[18px] @(appt.FollowUpSymptoms == "Chưa giảm" ? "" : "hidden")" id="icon-chuagiam-@appt.Id">warning</span>
                                                                    </button>
                                                                </div>
                                                            </div>

                                                            <!-- Phác đồ y khoa động dựa theo lựa chọn -->
                                                            <div id="phacdo-giamphe-@appt.Id" class="p-3 bg-emerald-50/50 border border-emerald-100 text-emerald-800 rounded-xl text-[12.5px] leading-relaxed mb-4 @(appt.FollowUpSymptoms == "Giảm nhiều" ? "" : "hidden")">
                                                                <div class="flex gap-2 font-bold mb-1"><span class="material-symbols-outlined text-[18px]">verified</span> Khuyến cáo phục hồi (Phác đồ 1):</div>
                                                                Triệu chứng phục hồi tốt. Bạn chỉ cần thực hiện <strong>tái khám 1 lần</strong> vào ngày hẹn để bác sĩ kiểm tra lâm sàng lần cuối, xác nhận dứt điểm bệnh lý và hoàn tất phác đồ điều trị.
                                                            </div>

                                                            <div id="phacdo-chuagiam-@appt.Id" class="p-3 bg-amber-50/50 border border-amber-100 text-amber-800 rounded-xl text-[12.5px] leading-relaxed mb-4 @(appt.FollowUpSymptoms == "Chưa giảm" ? "" : "hidden")">
                                                                <div class="flex gap-2 font-bold mb-1"><span class="material-symbols-outlined text-[18px]">report</span> Khuyến cáo điều trị (Phác đồ 2):</div>
                                                                Bệnh tình chưa thuyên giảm hoặc có nguy cơ trở nặng. Bạn bắt buộc phải thực hiện <strong>tái khám</strong> để bác sĩ điều chỉnh liều lượng thuốc hoặc thực hiện các kỹ thuật thăm dò cận lâm sàng sâu hơn. Sau lần khám này, bác sĩ sẽ chỉ định thêm các lịch hẹn theo dõi tiếp theo cho đến khi hoàn toàn hồi phục.
                                                            </div>

                                                            <div class="flex justify-between items-center pt-2">
                                                                <span class="text-[11px] text-slate-400 font-medium">Bác sĩ phụ trách: @(appt.Doctor?.FullName ?? "BS. Nguyễn Văn An")</span>
