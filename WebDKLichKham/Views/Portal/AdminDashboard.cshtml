                <button onclick="saveDoctorData()" class="px-6 py-2.5 bg-[#00346f] text-white rounded-xl font-bold text-[14px] hover:bg-[#002244] shadow-md hover:shadow-lg transition-all flex items-center gap-2" id="modal-doctor-btn">
                    <span class="material-symbols-outlined text-[18px]">save</span> Lưu hồ sơ Bác sĩ
                </button>
