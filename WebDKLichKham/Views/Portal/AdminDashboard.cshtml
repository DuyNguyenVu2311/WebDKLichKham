    <script>
        // Tab switching logic (SPA Routing simulation)
        function switchTab(tabId, titleText) {
            // Update Title
            document.getElementById('page-title').innerText = titleText;

            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            // Show targeted tab
            document.getElementById(`tab-${tabId}`).classList.add('active');

            // Update Sidebar styling
            const menus = ['dashboard', 'doctors', 'patients', 'appointments'];
            menus.forEach(menu => {
                const btn = document.getElementById(`menu-${menu}`);
                if (menu === tabId) {
                    btn.classList.add('bg-white/10', 'border-blue-500', 'text-white');
                    btn.classList.remove('hover:bg-white/5', 'border-transparent', 'text-slate-400');
                } else {
                    btn.classList.remove('bg-white/10', 'border-blue-500', 'text-white');
                    btn.classList.add('hover:bg-white/5', 'border-transparent', 'text-slate-400');
                }
            });
            
            // Re-render chart if switching back to dashboard to ensure correct sizing
            if(tabId === 'dashboard') {
                window.dispatchEvent(new Event('resize'));
            }
        }

        // Modals Logic
        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            // Timeout for CSS transition
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
            }, 10);
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            modal.classList.add('opacity-0');
            content.classList.add('scale-95');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 200); // Matches transition duration
        }

        // Initialize Charts (Chart.js)
        document.addEventListener('DOMContentLoaded', function() {
            // 1. Line/Area Chart (Revenue)
            const ctxRev = document.getElementById('revenueChart').getContext('2d');
            const gradientBlue = ctxRev.createLinearGradient(0, 0, 0, 300);
            gradientBlue.addColorStop(0, 'rgba(37, 99, 235, 0.3)');
            gradientBlue.addColorStop(1, 'rgba(37, 99, 235, 0.0)');

            window.revenueChartInstance = new Chart(ctxRev, {
                type: 'line',
                data: {
                    labels: ['Tháng 12', 'Tháng 01', 'Tháng 02', 'Tháng 03', 'Tháng 04', 'Tháng 05'],
                    datasets: [{
                        label: 'Doanh thu (Triệu VNĐ)',
                        data: [650, 590, 720, 810, 780, 845],
                        borderColor: '#2563eb', // blue-600
                        backgroundColor: gradientBlue,
                        borderWidth: 3,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#2563eb',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        fill: true,
                        tension: 0.4
                    },
                    {
                        label: 'Lượt khám',
                        data: [900, 850, 1050, 1120, 1100, 1248],
                        borderColor: '#10b981', // emerald-500
                        borderDash: [5, 5],
                        borderWidth: 2,
                        pointBackgroundColor: '#10b981',
                        pointRadius: 3,
                        tension: 0.4,
                        yAxisID: 'y1'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: { position: 'top', align: 'end', labels: { usePointStyle: true, boxWidth: 8, font: { family: 'Inter', size: 12 } } },
                        tooltip: { backgroundColor: '#1e293b', titleFont: { family: 'Inter', size: 13 }, bodyFont: { family: 'Inter', size: 13 }, padding: 12, cornerRadius: 8 }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { family: 'Inter' }, color: '#64748b' } },
                        y: { 
                            type: 'linear', display: true, position: 'left',
                            grid: { borderDash: [4, 4], color: '#e2e8f0' }, 
                            ticks: { font: { family: 'Inter' }, color: '#64748b', callback: function(value) { return value + ' Tr'; } } 
                        },
                        y1: {
                            type: 'linear', display: true, position: 'right',
                            grid: { drawOnChartArea: false },
                            ticks: { font: { family: 'Inter' }, color: '#64748b' }
                        }
                    }
                }
            });

            // 2. Doughnut Chart (Specialty)
            const ctxSpec = document.getElementById('specialtyChart').getContext('2d');
            window.specialtyChartInstance = new Chart(ctxSpec, {
                type: 'doughnut',
                data: {
                    labels: ['Nội Tiêu hóa', 'Nội Tim mạch', 'Nhi Khoa', 'Khác'],
                    datasets: [{
                        data: [35, 25, 20, 20],
                        backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#94a3b8'],
                        borderWidth: 2,
                        borderColor: '#ffffff',
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20, font: { family: 'Inter', size: 12, weight: '500' } } },
                        tooltip: { backgroundColor: '#1e293b', titleFont: { family: 'Inter', size: 13 }, bodyFont: { family: 'Inter', size: 13 }, padding: 12, cornerRadius: 8, callbacks: { label: function(context) { return ' ' + context.label + ': ' + context.raw + '%'; } } }
                    }
                }
            });
        });

        function openReceptionModal(rowId) {
            const row = document.getElementById(rowId);
            const name = row.querySelector('.patient-name').innerText;
            const service = row.querySelector('.service-name').innerText;
            
            document.getElementById('rec-patient-name').innerText = name;
            document.getElementById('rec-service-name').innerText = service;
            document.getElementById('rec-row-id').value = rowId;
            
            openModal('reception-modal');
        }

        function downloadReport() {
            const isPdf = document.getElementById('format-pdf').checked;
            const selectedMonth = document.querySelector('input[name="export-month"]:checked').value;
            
            let ext = isPdf ? ".pdf" : ".xlsx";
            let filename = `Bao_Cao_Doanh_Thu_T${selectedMonth}_2026${ext}`;

            closeModal('export-report-modal');
            setTimeout(() => {
                alert(`Hệ thống đang trích xuất dữ liệu và tải xuống:\n${filename}`);
            }, 300);
        }

        function updateCharts() {
            const facility = document.getElementById('facility-filter').value;
            
            // Lọc danh sách Lịch khám theo cơ sở
            const aptRows = document.querySelectorAll('.appointment-row');
            aptRows.forEach(row => {
                if(facility === 'all' || row.getAttribute('data-facility') === facility) {
                    row.style.display = 'table-row';
                } else {
                    row.style.display = 'none';
                }
            });
            
            // Lọc danh sách Bác sĩ theo cơ sở
            const docRows = document.querySelectorAll('.doctor-row');
            docRows.forEach(row => {
                if(facility === 'all' || row.getAttribute('data-facility') === facility) {
                    row.style.display = 'table-row';
                } else {
                    row.style.display = 'none';
                }
            });
            
            // Lọc danh sách Hồ sơ bệnh nhân theo cơ sở
            const patientRows = document.querySelectorAll('.patient-row');
            patientRows.forEach(row => {
                if(facility === 'all' || row.getAttribute('data-facility') === facility) {
                    row.style.display = 'table-row';
                } else {
                    row.style.display = 'none';
                }
            });

            // Update Metrics
            const mPatients = document.getElementById('metric-patients');
            const mRevenue = document.getElementById('metric-revenue');
            const mDoctors = document.getElementById('metric-doctors');
            const mTests = document.getElementById('metric-tests');
            
            if (facility === 'all') {
                mPatients.innerText = '1,248';
                mRevenue.innerText = '845';
                mDoctors.innerText = '42';
                mTests.innerText = '156';
            } else if (facility === '1') {
                mPatients.innerText = '830';
                mRevenue.innerText = '610';
                mDoctors.innerText = '28';
                mTests.innerText = '112';
            } else if (facility === '2') {
                mPatients.innerText = '418';
                mRevenue.innerText = '235';
                mDoctors.innerText = '14';
                mTests.innerText = '44';
            }

            if(window.revenueChartInstance && window.specialtyChartInstance) {
                // Randomize data based on selection for demo purposes
                window.revenueChartInstance.data.datasets[0].data = window.revenueChartInstance.data.datasets[0].data.map(x => Math.max(10, x + (Math.floor(Math.random() * 200) - 100)));
                window.revenueChartInstance.update();
                
                window.specialtyChartInstance.data.datasets[0].data = window.specialtyChartInstance.data.datasets[0].data.map(x => Math.max(5, x + (Math.floor(Math.random() * 10) - 5)));
                window.specialtyChartInstance.update();
            }
        }

        function syncFromApp() {
            const tableBody = document.getElementById('patient-table-body');
            tableBody.innerHTML = '<tr><td colspan="6" class="px-6 py-8 text-center text-slate-500"><span class="material-symbols-outlined animate-spin inline-block text-[24px]">sync</span> Đang đồng bộ dữ liệu...</td></tr>';
            
            fetch('/Portal/GetPatientRecords')
                .then(response => response.json())
                .then(data => {
                    tableBody.innerHTML = '';
                    if (data.length === 0) {
                        tableBody.innerHTML = '<tr><td colspan="6" class="px-6 py-8 text-center text-slate-500">Không có dữ liệu bệnh nhân nào.</td></tr>';
                        return;
                    }
                    data.forEach((p, index) => {
                        // random classification for UI realistic
                        const typeHtml = index % 3 === 0 
                            ? `<span class="bg-blue-50 text-blue-700 text-[11px] font-bold px-2.5 py-1 rounded-md border border-blue-200">BHYT</span>`
                            : `<span class="bg-slate-100 text-slate-700 text-[11px] font-bold px-2.5 py-1 rounded-md border border-slate-200">Dịch vụ</span>`;
                            
                        const paymentHtml = index % 4 === 0
                            ? `<span class="text-orange-600 bg-orange-50 border border-orange-200 font-bold text-[11px] px-2 py-1 rounded-md flex items-center justify-center gap-1 w-max mx-auto"><span class="material-symbols-outlined text-[14px]">warning</span> Còn nợ</span>`
                            : `<span class="text-green-600 bg-green-50 border border-green-200 font-bold text-[11px] px-2 py-1 rounded-md flex items-center justify-center gap-1 w-max mx-auto"><span class="material-symbols-outlined text-[14px]">check_circle</span> Đã thanh toán</span>`;

                        const facilityId = (p.id % 2) + 1;
                        const row = `
                            <tr class="hover:bg-slate-50 transition-colors patient-row" data-facility="${facilityId}">
                                <td class="px-6 py-4">
                                    <p class="font-bold text-slate-800 text-[14px]">${p.patientName}</p>
                                    <p class="text-[12px] text-slate-500 font-medium mt-0.5">Mã: BN-${(p.id + 100000)}</p>
                                    <p class="text-[12px] text-slate-500 mt-0.5">${p.patientPhone}</p>
                                </td>
                                <td class="px-6 py-4 text-[13px]">
                                    ${p.patientGender}<br><span class="text-slate-500">Ngày sinh: ${p.dob}</span>
                                </td>
                                <td class="px-6 py-4 text-center">${typeHtml}</td>
                                <td class="px-6 py-4 text-[13px]">
                                    <span class="font-bold text-slate-700">${p.appointmentDate}</span><br>
                                    <span class="text-slate-500">${p.service}</span>
                                </td>
                                <td class="px-6 py-4 text-center">${paymentHtml}</td>
                                <td class="px-6 py-4 text-right space-x-2">
                                    <button onclick="openModal('emr-modal')" class="text-[#00346f] hover:underline font-semibold text-[13px]">Xem EMR</button>
                                </td>
                            </tr>
                        `;
                        tableBody.innerHTML += row;
                    });
                    
                    setTimeout(() => {
                        showToast(`Đồng bộ thành công! Đã tải xuống ${data.length} hồ sơ từ máy chủ.`);
                        updateCharts(); // Trigger filter re-evaluation for new rows
                    }, 200);
                })
                .catch(error => {
                    console.error('Error fetching data:', error);
                    showToast("Lỗi khi kết nối hệ thống máy chủ.", "error");
                    tableBody.innerHTML = '<tr><td colspan="6" class="px-6 py-8 text-center text-red-500">Lỗi kết nối máy chủ. Vui lòng thử lại sau.</td></tr>';
                });
        }

        // Mock functions for Doctor row actions
        function openAddDoctor() {
            document.getElementById('modal-doctor-title').innerHTML = `<span class="material-symbols-outlined text-blue-600 text-[24px]">person_add</span> Hồ sơ Bác sĩ mới`;
            document.getElementById('modal-doctor-btn').innerHTML = `<span class="material-symbols-outlined text-[18px]">save</span> Lưu hồ sơ Bác sĩ`;
            
            // Xóa rỗng các field để thêm mới
            document.getElementById('doc-name-input').value = '';
            document.getElementById('doc-specialty-input').selectedIndex = 0;
            document.getElementById('doc-phone-input').value = '';
            document.getElementById('doc-email-input').value = '';
            document.getElementById('doc-cchn-input').value = '';
            document.getElementById('doc-exp-input').value = '';
            document.getElementById('doc-school-input').value = '';
            document.getElementById('doc-strength-input').value = '';
            document.getElementById('doc-fee-input').value = '300000';
            
            openModal('add-doctor-modal');
        }

        function saveDoctorData() {
            // Get form values
            const name = document.getElementById('doc-name-input').value;
            if (!name) {
                alert("Vui lòng nhập tên Bác sĩ!");
                return;
            }
            const mode = document.getElementById('modal-doctor-title').innerText.includes('Cập nhật') ? 'Cập nhật' : 'Thêm mới';
            
            closeModal('add-doctor-modal');
            showToast(`Đã ${mode} thành công hồ sơ Bác sĩ ${name}`);
            
            // Reload after 1.5s to see changes if backend was connected
            setTimeout(() => window.location.reload(), 1500);
        }

        function editDoctor(id, name, specialty) {
            document.getElementById('modal-doctor-title').innerHTML = `<span class="material-symbols-outlined text-blue-600 text-[24px]">manage_accounts</span> Cập nhật thông tin Bác sĩ`;
            document.getElementById('modal-doctor-btn').innerHTML = `<span class="material-symbols-outlined text-[18px]">save</span> Cập nhật hệ thống`;
            
            // Đổ dữ liệu thật của bác sĩ vào form
            document.getElementById('doc-name-input').value = name || '';
            
            const specSelect = document.getElementById('doc-specialty-input');
            if(specialty) {
                let found = false;
                for(let i = 0; i < specSelect.options.length; i++) {
                    if(specSelect.options[i].text === specialty) {
                        specSelect.selectedIndex = i;
                        found = true; break;
                    }
                }
                if(!found) specSelect.selectedIndex = 0;
            }

            // Generate realistic mock data for editing
            document.getElementById('doc-gender-input').selectedIndex = (name && name.toLowerCase().includes('thị')) ? 1 : 0;
            document.getElementById('doc-dob-input').value = `19${Math.floor(Math.random() * 20 + 70)}-0${Math.floor(Math.random() * 9 + 1)}-1${Math.floor(Math.random() * 9)}`;
            document.getElementById('doc-phone-input').value = '09' + Math.floor(Math.random() * 90000000 + 10000000);
            
            let emailName = (name || 'bacsian').toLowerCase().replace(/ /g, '');
            // remove accents
            emailName = emailName.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/đ/g, 'd');
            document.getElementById('doc-email-input').value = `${emailName}@@duytam.vn`;
            
            document.getElementById('doc-cchn-input').value = `00${Math.floor(Math.random() * 9000 + 1000)}/BYT-CCHN`;
            document.getElementById('doc-degree-input').selectedIndex = Math.floor(Math.random() * 4); // BS, CKI, CKII, ThS
            document.getElementById('doc-exp-input').value = Math.floor(Math.random() * 15 + 5);
            
            const schools = ["ĐH Y Dược TP.HCM", "ĐH Y Khoa Phạm Ngọc Thạch", "ĐH Y Hà Nội", "Học viện Quân Y"];
            document.getElementById('doc-school-input').value = schools[Math.floor(Math.random() * schools.length)];
            
            document.getElementById('doc-strength-input').value = `Khám và điều trị các bệnh lý chuyên sâu thuộc khoa ${specialty || 'Tổng hợp'}. Có nhiều năm kinh nghiệm lâm sàng và trực tiếp thực hiện các ca thủ thuật phức tạp.`;
            
            document.getElementById('doc-room-input').selectedIndex = Math.floor(Math.random() * 4);
            document.getElementById('doc-fee-input').value = Math.floor(Math.random() * 3 + 3) * 100000; // 300k, 400k, 500k
            document.getElementById('doc-duration-input').selectedIndex = 1; // 20 phút
            
            openModal('add-doctor-modal');
        }

        function deleteDoctor(id, name) {
            if (confirm("CẢNH BÁO: Bạn có chắc chắn muốn XÓA bác sĩ " + name + " khỏi hệ thống?\nHành động này không thể hoàn tác.")) {
                // In real app: call API to delete. Here we just hide the row
                showToast("Đã xóa thành công Bác sĩ " + name);
                setTimeout(() => window.location.reload(), 1500);
            }
        }
        
        // --- Thêm Toast Notification System ---
        function showToast(message, type="success") {
            const container = document.getElementById('toast-container') || createToastContainer();
            
            const toast = document.createElement('div');
            toast.className = `bg-white border-l-4 ${type === 'success' ? 'border-green-500' : 'border-blue-500'} shadow-lg rounded p-4 flex items-center justify-between mb-3 transform transition-all duration-300 translate-x-full opacity-0 max-w-sm w-full`;
            
            const icon = type === 'success' ? 'check_circle' : 'info';
            const iconColor = type === 'success' ? 'text-green-500' : 'text-blue-500';
            
            toast.innerHTML = `
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined ${iconColor}">${icon}</span>
                    <p class="text-slate-800 text-[14px] font-semibold">${message}</p>
                </div>
                <button onclick="this.parentElement.remove()" class="text-slate-400 hover:text-slate-600">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                </button>
            `;
            
            container.appendChild(toast);
            
            // Animate in
            setTimeout(() => {
                toast.classList.remove('translate-x-full', 'opacity-0');
            }, 10);
            
            // Auto remove after 3s
            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-x-full');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
        
        function createToastContainer() {
            const div = document.createElement('div');
            div.id = 'toast-container';
            div.className = 'fixed top-20 right-4 z-[9999] flex flex-col items-end';
            document.body.appendChild(div);
            return div;
        }

        function confirmReception() {
            const rowId = document.getElementById('rec-row-id').value;
            const row = document.getElementById(rowId);
            
            // Cập nhật DOM - Trạng thái thành Chờ khám
            row.querySelector('.status-col').innerHTML = `
                <span class="bg-blue-100 text-blue-700 text-[11px] font-bold px-3 py-1.5 rounded-full border border-blue-200 flex items-center justify-center gap-1 w-max mx-auto">
                    <span class="material-symbols-outlined text-[14px]">stethoscope</span> Chờ khám
                </span>
            `;
            
            // Xóa nút tiếp nhận, chỉ để lại icon tắt/hủy hoặc ẩn hẳn thao tác
            row.querySelector('.action-col').innerHTML = `
                <button class="text-slate-400 hover:text-red-500 text-[20px] transition-colors" title="Hủy tiếp nhận"><span class="material-symbols-outlined">close</span></button>
            `;
            
            closeModal('reception-modal');
            
            // Notification nhỏ thay vì alert (dùng UI alert đơn giản)
            showToast("Đang đồng bộ dữ liệu lưu trữ thời gian thực với máy chủ HIS...", "info");
            setTimeout(() => {
                showToast("Hoàn tất! Tiếp nhận thành công Bệnh nhân và cập nhật lên CSDL tổng.");
            }, 1000);
        }
    </script>
