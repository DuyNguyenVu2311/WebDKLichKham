    <!-- Modal Thêm Bác sĩ -->
    <div id="add-doctor-modal" class="fixed inset-0 bg-slate-900/70 z-50 hidden items-center justify-center backdrop-blur-sm transition-opacity opacity-0">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-4xl overflow-hidden transform scale-95 transition-transform flex flex-col max-h-[90vh]" id="add-doctor-content">
            <!-- Header Modal -->
            <div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex justify-between items-center shrink-0">
                <h2 class="font-bold text-[18px] text-[#00346f] flex items-center gap-2" id="modal-doctor-title">
                    <span class="material-symbols-outlined text-blue-600 text-[24px]">person_add</span> Hồ sơ Bác sĩ mới
                </h2>
                <button onclick="closeModal('add-doctor-modal')" class="w-8 h-8 rounded-full bg-slate-200 hover:bg-slate-300 text-slate-600 flex items-center justify-center transition-colors">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
            </div>
            
            <!-- Body Modal (Cuộn được) -->
            <div class="p-6 overflow-y-auto flex-1 custom-scrollbar">
                <form class="space-y-6">
                    <!-- Section 1: Thông tin cá nhân -->
                    <div>
                        <h3 class="text-[14px] font-bold text-slate-800 border-b border-slate-200 pb-2 mb-4 uppercase tracking-wider">Thông tin cá nhân</h3>
                        <div class="flex flex-col md:flex-row gap-6">
                            <!-- Avatar upload -->
                            <div class="shrink-0 flex flex-col items-center gap-2">
                                <div class="w-24 h-24 rounded-full border-2 border-dashed border-slate-300 flex items-center justify-center bg-slate-50 text-slate-400 hover:border-blue-500 hover:text-blue-500 cursor-pointer transition-colors relative overflow-hidden group">
                                    <span class="material-symbols-outlined text-[32px] group-hover:scale-110 transition-transform">add_a_photo</span>
                                </div>
                                <span class="text-[12px] font-semibold text-slate-500">Ảnh đại diện</span>
                            </div>
                            
                            <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Họ và tên <span class="text-red-500">*</span></label>
                                    <input type="text" id="doc-name-input" placeholder="VD: Nguyễn Văn An" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-all">
                                </div>
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Giới tính</label>
                                        <select id="doc-gender-input" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white">
                                            <option>Nam</option>
                                            <option>Nữ</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Ngày sinh</label>
                                        <input type="date" id="doc-dob-input" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white transition-all">
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Số điện thoại <span class="text-red-500">*</span></label>
                                    <input type="tel" id="doc-phone-input" placeholder="09xx xxx xxx" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-all">
                                </div>
                                <div>
                                    <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Email liên hệ</label>
                                    <input type="email" id="doc-email-input" placeholder="bacsian@duytam.vn" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-all">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Section 2: Chuyên môn & Pháp lý -->
                    <div>
                        <h3 class="text-[14px] font-bold text-slate-800 border-b border-slate-200 pb-2 mb-4 uppercase tracking-wider">Chứng chỉ hành nghề & Chuyên môn</h3>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Số CCHN <span class="text-red-500">*</span></label>
                                <input type="text" id="doc-cchn-input" placeholder="VD: 012345/BYT-CCHN" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-all font-mono text-[12px]">
                            </div>
                            <div>
                                <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Học hàm / Học vị <span class="text-red-500">*</span></label>
                                <select id="doc-degree-input" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white">
                                    <option>Bác sĩ (BS)</option>
                                    <option>Bác sĩ Chuyên khoa I (BS.CKI)</option>
                                    <option>Bác sĩ Chuyên khoa II (BS.CKII)</option>
                                    <option>Thạc sĩ Bác sĩ (ThS.BS)</option>
                                    <option>Tiến sĩ Bác sĩ (TS.BS)</option>
                                    <option>Phó Giáo sư Tiến sĩ (PGS.TS)</option>
                                    <option>Giáo sư Tiến sĩ (GS.TS)</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Kinh nghiệm lâm sàng</label>
                                <div class="relative">
                                    <input type="number" id="doc-exp-input" min="0" placeholder="0" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-all pr-12">
                                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-[13px] text-slate-500 font-semibold">Năm</span>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Chuyên khoa chính <span class="text-red-500">*</span></label>
                                <select id="doc-specialty-input" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white">
                                    @foreach (var sp in Model?.Select(m => m.SpecialtyInfo?.Name ?? m.Specialty).Distinct() ?? new List<string>())
                                    {
                                        <option>@sp</option>
                                    }
                                    <option>Nội Tiêu Hóa</option>
                                    <option>Nhi Khoa</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Trường đào tạo Y khoa</label>
                                <input type="text" id="doc-school-input" placeholder="ĐH Y Dược TP.HCM, ĐH Y Hà Nội..." class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-all">
                            </div>
                        </div>
                        <div class="mt-4">
                            <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Thế mạnh điều trị / Lĩnh vực lâm sàng chuyên sâu</label>
                            <textarea id="doc-strength-input" rows="3" placeholder="Nội soi tiêu hóa, Điều trị viêm gan, Cắt polyp..." class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-all resize-none"></textarea>
                        </div>
                    </div>

                    <!-- Section 3: Cấu hình Khám bệnh -->
                    <div>
                        <h3 class="text-[14px] font-bold text-slate-800 border-b border-slate-200 pb-2 mb-4 uppercase tracking-wider">Cấu hình lịch làm việc & Dịch vụ</h3>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Phòng làm việc (Mặc định)</label>
                                <select id="doc-room-input" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white">
                                    <option>Phòng số 01 - Tầng 1</option>
                                    <option>Phòng số 02 - Tầng 1</option>
                                    <option>Phòng số 03 - Tầng 2</option>
                                    <option>Phòng số 04 - Tầng 2</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Phí khám cơ bản (VNĐ) <span class="text-red-500">*</span></label>
                                <input type="number" id="doc-fee-input" placeholder="300000" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-all font-mono">
                            </div>
                            <div>
                                <label class="block text-[13px] font-bold text-slate-700 mb-1.5">Thời lượng 1 ca khám</label>
                                <select id="doc-duration-input" class="w-full bg-slate-50 border border-slate-300 text-slate-800 text-[13px] rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 focus:bg-white">
                                    <option>15 Phút</option>
                                    <option selected>20 Phút (Tiêu chuẩn)</option>
                                    <option>30 Phút (Chuyên sâu)</option>
                                    <option>45 Phút</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="mt-5 p-4 bg-blue-50 border border-blue-100 rounded-xl flex items-start gap-3">
                            <div class="mt-0.5">
                                <input type="checkbox" id="allow_bhyt" checked class="w-4 h-4 text-blue-600 bg-white border-slate-300 rounded focus:ring-blue-500 cursor-pointer">
                            </div>
                            <div>
                                <label for="allow_bhyt" class="text-[14px] font-bold text-slate-800 cursor-pointer">Chấp nhận thanh toán Bảo hiểm Y tế (BHYT)</label>
                                <p class="text-[12px] text-slate-600 mt-1">Bác sĩ này được phép kê đơn và chỉ định cận lâm sàng trong danh mục thanh toán của BHYT.</p>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            
            <!-- Footer Modal -->
            <div class="px-6 py-4 border-t border-slate-200 bg-slate-50 flex justify-end gap-3 shrink-0">
