@model IEnumerable<WebDKLichKham.Models.Doctor>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản trị hệ thống HIS - Phòng Khám Đa Khoa Duy Tâm</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f1f5f9; }
        .tab-content { display: none; animation: fadeIn 0.3s ease; }
        .tab-content.active { display: block; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="text-slate-800 flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-slate-900 text-white flex flex-col h-full shrink-0 shadow-xl z-20 relative">
        <div class="h-16 flex items-center gap-2 px-6 border-b border-white/10 bg-black/20">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center font-black text-white">DT</div>
            <span class="font-bold text-[15px] tracking-wide">Phòng Khám Duy Tâm</span>
        </div>
        <nav class="flex-1 py-6 overflow-y-auto">
            <div class="px-6 mb-3 text-[10px] font-black text-slate-500 uppercase tracking-widest">Bảng điều khiển</div>
            <ul class="space-y-1 mb-8">
                <li>
                    <button onclick="switchTab('dashboard', 'Tổng quan hoạt động (Tháng 05/2026)')" id="menu-dashboard" class="w-full flex items-center gap-3 px-6 py-3 bg-white/10 font-semibold text-[14px] border-l-4 border-blue-500 text-white transition-all">
                        <span class="material-symbols-outlined text-[20px]">dashboard</span> Tổng quan
                    </button>
                </li>
            </ul>

            <div class="px-6 mb-3 text-[10px] font-black text-slate-500 uppercase tracking-widest">Quản lý Y tế</div>
            <ul class="space-y-1">
                <li>
                    <button onclick="switchTab('doctors', 'Quản lý Nhân sự / Bác sĩ')" id="menu-doctors" class="w-full flex items-center gap-3 px-6 py-3 hover:bg-white/5 font-medium text-[14px] border-l-4 border-transparent text-slate-400 hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[20px]">medical_information</span> Danh sách Bác sĩ
                    </button>
                </li>
                <li>
                    <button onclick="switchTab('patients', 'Hồ sơ Bệnh nhân (EMR)')" id="menu-patients" class="w-full flex items-center gap-3 px-6 py-3 hover:bg-white/5 font-medium text-[14px] border-l-4 border-transparent text-slate-400 hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[20px]">group</span> Hồ sơ Bệnh nhân
                    </button>
                </li>
                <li>
                    <button onclick="switchTab('appointments', 'Lịch khám toàn hệ thống')" id="menu-appointments" class="w-full flex items-center gap-3 px-6 py-3 hover:bg-white/5 font-medium text-[14px] border-l-4 border-transparent text-slate-400 hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[20px]">event_note</span> Lịch khám & Tiếp nhận
                    </button>
                </li>
            </ul>
        </nav>
        <div class="p-4 border-t border-white/10 bg-black/20 space-y-2">
            <div class="flex items-center gap-3 mb-4 px-2">
                <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold shadow-lg">AD</div>
                <div class="overflow-hidden">
                    <p class="text-[13px] font-bold leading-none mb-1.5 truncate">Admin (Quản lý)</p>
                    <p class="text-[11px] text-slate-400 leading-none truncate">admin@duytam.vn</p>
                </div>
            </div>
            <a href="/" class="flex items-center justify-center gap-2 text-slate-300 bg-white/5 hover:bg-white/10 hover:text-white py-2.5 rounded-lg text-[13px] font-semibold transition-colors w-full">
                <span class="material-symbols-outlined text-[18px]">home</span> Về Cổng thông tin
            </a>
            <a href="/Home/Login" class="flex items-center justify-center gap-2 text-white bg-red-500/90 hover:bg-red-600 py-2.5 rounded-lg text-[13px] font-semibold transition-colors w-full shadow-md">
                <span class="material-symbols-outlined text-[18px]">logout</span> Đăng xuất
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-full bg-[#f8fafc] overflow-hidden relative">
        <!-- Header -->
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 shrink-0 shadow-sm z-10">
            <h1 id="page-title" class="font-black text-[18px] text-[#00346f] tracking-tight">Tổng quan hoạt động (Tháng 05/2026)</h1>
            <div class="flex items-center gap-6">
                <!-- Cơ sở Filter -->
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-slate-400 text-[18px]">location_on</span>
                    <select id="facility-filter" onchange="updateCharts()" class="bg-slate-50 border border-slate-200 text-slate-700 text-[13px] rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2 font-semibold font-sans outline-none cursor-pointer">
                        <option value="all">Tất cả Cơ sở</option>
                        <option value="1">Cơ sở 1: Thủ Đức</option>
                        <option value="2">Cơ sở 2: Nhơn Trạch</option>
                    </select>
                </div>
                <!-- Notifications -->
                <div class="relative group">
                    <button class="relative text-slate-500 hover:text-[#00346f] bg-slate-50 p-2 rounded-full hover:bg-slate-100 transition-colors focus:outline-none">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-1 right-1 w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-white"></span>
                    </button>
                    <!-- Dropdown -->
                    <div class="absolute right-0 mt-2 w-72 bg-white rounded-xl shadow-xl border border-slate-100 overflow-hidden hidden group-hover:block z-50">
                        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
                            <h3 class="font-bold text-[14px] text-slate-800">Thông báo hệ thống</h3>
                        </div>
                        <div class="max-h-64 overflow-y-auto">
                            <a href="#" class="block px-4 py-3 hover:bg-slate-50 border-b border-slate-50 transition-colors">
                                <p class="text-[13px] text-slate-800 font-semibold mb-1">Có 2 lịch hẹn mới vừa được đặt từ App</p>
                                <p class="text-[11px] text-slate-500 flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">schedule</span> 2 phút trước</p>
                            </a>
                            <a href="#" class="block px-4 py-3 hover:bg-slate-50 transition-colors">
                                <p class="text-[13px] text-slate-800 font-semibold mb-1">Bác sĩ Nguyễn Thị B (Phòng 02) xin nghỉ phép</p>
                                <p class="text-[11px] text-slate-500 flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">schedule</span> 1 giờ trước</p>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Content Area (Scrollable) -->
        <div class="flex-1 overflow-y-auto p-8">
            
            <!-- ===================== TAB: DASHBOARD ===================== -->
            <div id="tab-dashboard" class="tab-content active space-y-6">
                <!-- Key Metrics -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Metric 1 -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 relative overflow-hidden group hover:shadow-md transition-shadow">
                        <div class="absolute -right-4 -top-4 w-24 h-24 bg-blue-50 rounded-full group-hover:scale-110 transition-transform"></div>
                        <div class="flex justify-between items-start mb-4 relative z-10">
                            <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center shadow-sm">
                                <span class="material-symbols-outlined">group</span>
                            </div>
                            <span class="bg-green-100 text-green-700 text-[12px] font-bold px-2.5 py-1 rounded-md flex items-center gap-1 shadow-sm"><span class="material-symbols-outlined text-[14px]">trending_up</span> +12%</span>
                        </div>
                        <p class="text-slate-500 text-[13px] font-semibold mb-1 relative z-10 uppercase tracking-wider">Tổng bệnh nhân</p>
                        <h3 class="text-[32px] font-black text-slate-800 relative z-10 tracking-tight"><span id="metric-patients">1,248</span> <span class="text-[14px] text-slate-400 font-medium tracking-normal">lượt</span></h3>
                    </div>

                    <!-- Metric 2 -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 relative overflow-hidden group hover:shadow-md transition-shadow">
                        <div class="absolute -right-4 -top-4 w-24 h-24 bg-green-50 rounded-full group-hover:scale-110 transition-transform"></div>
                        <div class="flex justify-between items-start mb-4 relative z-10">
                            <div class="w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center shadow-sm">
                                <span class="material-symbols-outlined">payments</span>
                            </div>
                            <span class="bg-green-100 text-green-700 text-[12px] font-bold px-2.5 py-1 rounded-md flex items-center gap-1 shadow-sm"><span class="material-symbols-outlined text-[14px]">trending_up</span> +8%</span>
                        </div>
                        <p class="text-slate-500 text-[13px] font-semibold mb-1 relative z-10 uppercase tracking-wider">Doanh thu dự kiến</p>
                        <h3 class="text-[32px] font-black text-slate-800 relative z-10 tracking-tight"><span id="metric-revenue">845</span><span class="text-[18px] text-slate-500 font-bold ml-1 tracking-normal">Tr</span></h3>
                    </div>

                    <!-- Metric 3 -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 relative overflow-hidden group hover:shadow-md transition-shadow">
                        <div class="absolute -right-4 -top-4 w-24 h-24 bg-purple-50 rounded-full group-hover:scale-110 transition-transform"></div>
                        <div class="flex justify-between items-start mb-4 relative z-10">
                            <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center shadow-sm">
                                <span class="material-symbols-outlined">stethoscope</span>
                            </div>
                            <span class="text-slate-400 text-[11px] font-bold uppercase bg-slate-100 px-2 py-1 rounded-md">Toàn hệ thống</span>
                        </div>
                        <p class="text-slate-500 text-[13px] font-semibold mb-1 relative z-10 uppercase tracking-wider">Bác sĩ làm việc</p>
                        <h3 id="metric-doctors" class="text-[32px] font-black text-slate-800 relative z-10 tracking-tight">42</h3>
                    </div>

                    <!-- Metric 4 -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 relative overflow-hidden group hover:shadow-md transition-shadow">
                        <div class="absolute -right-4 -top-4 w-24 h-24 bg-orange-50 rounded-full group-hover:scale-110 transition-transform"></div>
                        <div class="flex justify-between items-start mb-4 relative z-10">
                            <div class="w-12 h-12 bg-orange-100 text-orange-600 rounded-xl flex items-center justify-center shadow-sm">
                                <span class="material-symbols-outlined">biotech</span>
                            </div>
                            <span class="text-slate-400 text-[11px] font-bold uppercase bg-slate-100 px-2 py-1 rounded-md">Hôm nay</span>
                        </div>
                        <p class="text-slate-500 text-[13px] font-semibold mb-1 relative z-10 uppercase tracking-wider flex items-center gap-1">Xét nghiệm & CĐHA <span class="material-symbols-outlined text-[14px] cursor-help text-slate-400 hover:text-slate-600" title="Chỉ định Cận lâm sàng: Bao gồm các xét nghiệm máu, nội soi, siêu âm, X-Quang...">info</span></p>
                        <h3 class="text-[32px] font-black text-slate-800 relative z-10 tracking-tight"><span id="metric-tests">156</span> <span class="text-[14px] text-slate-400 font-medium tracking-normal">ca</span></h3>
                    </div>
                </div>

                <!-- Charts Section -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!-- Line Chart -->
                    <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                        <div class="flex justify-between items-center mb-6">
                            <h2 class="font-bold text-[16px] text-slate-800">Biểu đồ Lượt khám & Doanh thu (6 tháng)</h2>
                            <button onclick="openModal('export-report-modal')" class="bg-blue-50 text-blue-700 border border-blue-200 px-3 py-1.5 rounded-lg text-[12px] font-bold hover:bg-blue-100 transition-colors flex items-center gap-1 shadow-sm"><span class="material-symbols-outlined text-[16px]">download</span> Xuất báo cáo</button>
                        </div>
                        <div class="h-64">
                            <canvas id="revenueChart"></canvas>
                        </div>
                    </div>
                    <!-- Doughnut Chart -->
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                        <h2 class="font-bold text-[16px] text-slate-800 mb-6">Cơ cấu Bệnh nhân theo Chuyên khoa</h2>
                        <div class="h-52 flex justify-center">
                            <canvas id="specialtyChart"></canvas>
                        </div>
                        <div class="mt-4 grid grid-cols-2 gap-2 text-[12px] font-medium text-slate-600">
                            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#0ea5e9]"></span> Nội Tiêu hóa (35%)</div>
                            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#3b82f6]"></span> Nội Tim mạch (25%)</div>
                            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#8b5cf6]"></span> Nhi Khoa (20%)</div>
                            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#cbd5e1]"></span> Khác (20%)</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===================== TAB: DOCTORS ===================== -->
            <div id="tab-doctors" class="tab-content space-y-6">
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden flex flex-col">
                    <div class="px-6 py-4 border-b border-slate-200 flex flex-col md:flex-row items-center justify-between bg-white gap-4">
                        <div class="relative w-full md:w-96">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                            <input type="text" placeholder="Tìm kiếm Bác sĩ theo Tên, Mã BS..." class="w-full bg-slate-50 border border-slate-200 text-slate-700 text-[13px] rounded-lg pl-10 pr-4 py-2.5 outline-none focus:border-blue-500 focus:bg-white transition-colors">
                        </div>
                        <button onclick="openAddDoctor()" class="w-full md:w-auto bg-[#00346f] text-white px-5 py-2.5 rounded-lg text-[13px] font-bold hover:bg-[#002244] transition-colors flex items-center justify-center gap-2 shadow-sm">
                            <span class="material-symbols-outlined text-[18px]">person_add</span> Thêm Bác sĩ
                        </button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-[14px]">
                            <thead class="bg-slate-50 border-b border-slate-200 text-slate-500 text-[12px] uppercase font-bold tracking-wider">
                                <tr>
                                    <th class="px-6 py-4">Bác sĩ</th>
                                    <th class="px-6 py-4">Chuyên khoa</th>
                                    <th class="px-6 py-4">Lịch làm việc (Hôm nay)</th>
                                    <th class="px-6 py-4 text-center">Trạng thái</th>
                                    <th class="px-6 py-4 text-right">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 bg-white">
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var doc in Model)
                                    {
                                        var sn = doc.SpecialtyInfo?.Name ?? doc.Specialty;
                                        var words = doc.FullName.Split(' ').Where(w => w.Length > 0).ToArray();
                                        var initials = "";
                                        if (words.Length > 1) {
                                            initials = words[words.Length - 2][0].ToString() + words[words.Length - 1][0].ToString();
                                        } else if (words.Length == 1) {
                                            initials = words[0][0].ToString();
                                        }
                                        initials = initials.ToUpper();

                                        var colors = new[] { "bg-blue-100 text-blue-700", "bg-pink-100 text-pink-700", "bg-green-100 text-green-700", "bg-purple-100 text-purple-700", "bg-orange-100 text-orange-700" };
                                        var color = colors[Math.Abs(doc.Id.GetHashCode()) % colors.Length];
                                        
                                        var facilityId = (doc.Id % 2) + 1;
                                        var facilityName = facilityId == 1 ? "Thủ Đức" : "Nhơn Trạch";

                                        <tr class="hover:bg-slate-50 transition-colors doctor-row" data-facility="@facilityId">
                                            <td class="px-6 py-4">
                                                <div class="flex items-center gap-3">
                                                    <div class="w-10 h-10 rounded-full @color flex items-center justify-center font-bold">@initials</div>
                                                    <div>
                                                        <p class="font-bold text-slate-800 text-[14px]">@doc.FullName</p>
                                                        <p class="text-[12px] text-slate-500 font-medium">Mã: BS@(doc.Id.ToString("D3"))</p>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 font-semibold text-slate-700">@sn</td>
                                            <td class="px-6 py-4 text-slate-600">T2 - CN (07:00 - 18:00)<br><span class="text-[12px] text-slate-400">Phòng khám mặc định - @facilityName</span></td>
                                            <td class="px-6 py-4 text-center">
                                                @if(doc.IsActive) {
                                                    <span class="bg-blue-100 text-blue-700 text-[11px] font-bold px-2.5 py-1 rounded-md border border-blue-200">Đang khám</span>
                                                } else {
                                                    <span class="bg-slate-100 text-slate-600 text-[11px] font-bold px-2.5 py-1 rounded-md border border-slate-200">Nghỉ phép</span>
                                                }
                                            </td>
                                            <td class="px-6 py-4 text-right space-x-2">
                                                <button onclick="editDoctor(@doc.Id, '@Html.Raw(doc.FullName.Replace("'", "\\'"))', '@Html.Raw((doc.SpecialtyInfo?.Name ?? doc.Specialty).Replace("'", "\\'"))')" class="text-slate-400 hover:text-blue-600 hover:bg-blue-50 p-1.5 rounded transition-colors" title="Sửa thông tin"><span class="material-symbols-outlined text-[20px]">edit</span></button>
                                                <button onclick="deleteDoctor(@doc.Id, '@Html.Raw(doc.FullName.Replace("'", "\\'"))')" class="text-slate-400 hover:text-red-600 hover:bg-red-50 p-1.5 rounded transition-colors" title="Xóa Bác sĩ"><span class="material-symbols-outlined text-[20px]">delete</span></button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="5" class="text-center py-4 text-slate-500">Không có dữ liệu bác sĩ.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="px-6 py-4 border-t border-slate-200 bg-slate-50 flex items-center justify-between text-[13px] text-slate-500">
                        <span>Hiển thị @(Model?.Count() ?? 0) Bác sĩ</span>
                        <div class="flex gap-1">
                            <button class="px-3 py-1 border border-slate-300 rounded hover:bg-slate-200 disabled:opacity-50" disabled>Trước</button>
                            <button class="px-3 py-1 bg-blue-600 text-white rounded font-bold">1</button>
                            <button class="px-3 py-1 border border-slate-300 rounded hover:bg-slate-200">2</button>
                            <button class="px-3 py-1 border border-slate-300 rounded hover:bg-slate-200">Tiếp</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===================== TAB: PATIENTS ===================== -->
            <div id="tab-patients" class="tab-content space-y-6">
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden flex flex-col">
                    <div class="px-6 py-4 border-b border-slate-200 flex flex-col md:flex-row items-center justify-between bg-white gap-4">
                        <div class="relative w-full md:w-96">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                            <input type="text" placeholder="Tìm bằng SĐT, Mã Bệnh nhân..." class="w-full bg-slate-50 border border-slate-200 text-slate-700 text-[13px] rounded-lg pl-10 pr-4 py-2.5 outline-none focus:border-blue-500 focus:bg-white transition-colors">
                        </div>
                        <div class="flex gap-2 w-full md:w-auto">
                            <button onclick="openModal('filter-patients-modal')" class="bg-white border border-slate-300 text-slate-700 px-4 py-2.5 rounded-lg text-[13px] font-bold hover:bg-slate-50 transition-colors flex items-center gap-2 shadow-sm">
                                <span class="material-symbols-outlined text-[18px]">filter_list</span> Lọc nâng cao
                            </button>
                            <button onclick="syncFromApp()" class="bg-green-600 text-white px-5 py-2.5 rounded-lg text-[13px] font-bold hover:bg-green-700 transition-colors flex items-center justify-center gap-2 shadow-sm" title="Khách hàng tự đăng ký qua ứng dụng, Admin chỉ việc đồng bộ và duyệt">
                                <span class="material-symbols-outlined text-[18px]">sync</span> Đồng bộ từ App
                            </button>
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-[14px]">
                            <thead class="bg-slate-50 border-b border-slate-200 text-slate-500 text-[12px] uppercase font-bold tracking-wider">
                                <tr>
                                    <th class="px-6 py-4">Bệnh nhân</th>
                                    <th class="px-6 py-4">Thông tin y tế</th>
                                    <th class="px-6 py-4 text-center">Phân loại</th>
                                    <th class="px-6 py-4">Lần khám gần nhất</th>
                                    <th class="px-6 py-4 text-center">Viện phí</th>
                                    <th class="px-6 py-4 text-right">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="patient-table-body" class="divide-y divide-slate-100 bg-white">
