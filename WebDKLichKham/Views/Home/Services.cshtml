@{
    ViewData["Title"] = "Dịch Vụ & Trang Thiết Bị";
}

<main class="font-sans bg-[#f8fafc] pb-20">
    <!-- Header Section -->
    <section class="pt-16 pb-12 px-4 bg-gradient-to-b from-[#eff6ff] to-[#f8fafc]">
        <div class="max-w-[1280px] mx-auto text-center">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#1e40af]/10 text-[#1e40af] rounded-full text-[13px] font-bold mb-4 animate-fade-in">
                <span class="material-symbols-outlined text-[16px]">medical_services</span> Dịch Vụ & Trang Thiết Bị
            </span>
            <h1 class="text-[36px] md:text-[44px] font-extrabold text-[#0f172a] mb-5 leading-tight tracking-tight">
                Dịch Vụ Khám Bệnh & Công Nghệ Y Khoa
            </h1>
            <p class="text-[16px] md:text-[18px] text-[#475569] leading-relaxed max-w-[750px] mx-auto">
                Phòng khám Đa khoa Duy Tâm kết hợp đội ngũ bác sĩ chuyên khoa giàu kinh nghiệm cùng hệ thống trang thiết bị chẩn đoán, xét nghiệm tự động hàng đầu thế giới để mang lại hiệu quả điều trị tốt nhất.
            </p>
        </div>
    </section>

    <div class="max-w-[1280px] mx-auto px-4 md:px-8">
        
        <!-- SECTION 1: DỊCH VỤ KHÁM CHỮA BỆNH -->
        <section class="mb-16">
            <div class="flex items-center gap-3 mb-3 border-b border-gray-200/60 pb-4">
                <span class="material-symbols-outlined text-[#1e40af] text-[30px]">local_hospital</span>
                <h2 class="text-[26px] font-extrabold text-[#0f172a]">Dịch Vụ Khám Chữa Bệnh</h2>
            </div>
            <p class="text-[14px] text-[#64748b] mb-8 max-w-[800px]">
                Các gói khám lâm sàng và kỹ thuật cận lâm sàng được thiết kế khoa học, tuân thủ nghiêm ngặt quy trình y khoa chuẩn hóa của Bộ Y Tế.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                
                <!-- 1. Khám Sức Khỏe Tổng Quát -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 hover:shadow-xl hover:border-[#1e40af]/20 transition-all duration-300 flex flex-col justify-between group">
                    <div>
                        <div class="flex justify-between items-start mb-5">
                            <div class="w-12 h-12 bg-blue-50 text-[#1e40af] rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                <span class="material-symbols-outlined text-[26px]">health_and_safety</span>
                            </div>
                            <span class="px-2.5 py-1 bg-[#eff6ff] text-[#1e40af] rounded-lg text-[11px] font-bold tracking-wide uppercase">Dịch vụ phổ biến</span>
                        </div>
                        <h3 class="text-[20px] font-extrabold text-[#0f172a] mb-3">Gói Khám Sức Khỏe Tổng Quát</h3>
                        <p class="text-[14px] text-[#475569] mb-5 leading-relaxed">
                            Tầm soát toàn diện và đánh giá chi tiết chức năng các cơ quan trong cơ thể, phát hiện sớm các bệnh lý âm thầm như tiểu đường, huyết áp, mỡ máu và ung thư giai đoạn đầu.
                        </p>
                        <ul class="space-y-2.5 mb-6 text-[13.5px] text-[#475569]">
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Khám lâm sàng toàn diện cùng Bác sĩ Nội tổng quát</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Xét nghiệm máu cơ bản (Đường huyết, mỡ máu, gan, thận)</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Chụp X-quang phổi thẳng & Siêu âm bụng tổng quát</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Đánh giá chỉ số BMI, huyết áp và tư vấn lối sống y khoa</span>
                            </li>
                        </ul>
                    </div>
                    <div class="pt-4 border-t border-gray-50 flex items-center justify-between">
                        <span class="text-[14px] text-[#64748b]">Mức giá hợp lý</span>
                        <a asp-controller="Appointments" asp-action="Create" asp-route-specialtyId="2" asp-route-medicalService="Gói khám sức khỏe Định kỳ"
                           class="inline-flex items-center gap-2 bg-[#1e40af] text-white px-4 py-2.5 rounded-xl font-bold text-[13px] no-underline hover:bg-[#1e3a8a] transition-all">
                            Đặt lịch khám <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                        </a>
                    </div>
                </div>

                <!-- 2. Khám Lâm Sàng & Chuyên Khoa -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 hover:shadow-xl hover:border-[#1e40af]/20 transition-all duration-300 flex flex-col justify-between group">
                    <div>
                        <div class="flex justify-between items-start mb-5">
                            <div class="w-12 h-12 bg-emerald-50 text-[#059669] rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                <span class="material-symbols-outlined text-[26px]">stethoscope</span>
                            </div>
                            <span class="px-2.5 py-1 bg-[#e6f4ea] text-[#137333] rounded-lg text-[11px] font-bold tracking-wide uppercase">Khám chuyên khoa</span>
                        </div>
                        <h3 class="text-[20px] font-extrabold text-[#0f172a] mb-3">Khám Lâm Sàng & Chuyên Khoa</h3>
                        <p class="text-[14px] text-[#475569] mb-5 leading-relaxed">
                            Khám và tư vấn chuyên sâu cùng các bác sĩ giàu kinh nghiệm thuộc nhiều chuyên khoa y tế khác nhau. Chuẩn đoán bệnh lý chính xác thông qua hỏi bệnh và thăm khám thực thể.
                        </p>
                        <ul class="space-y-2.5 mb-6 text-[13.5px] text-[#475569]">
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Chuyên khoa Nội: Tim mạch, Thần kinh, Tiêu hóa, Hô hấp</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Ngoại trú chuyên khoa: Da liễu, Tai Mũi Họng, Nhi khoa</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Sản phụ khoa & Khám Răng Hàm Mặt định kỳ</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Bác sĩ kê đơn thuốc chuẩn hóa y học chứng cứ</span>
                            </li>
                        </ul>
                    </div>
                    <div class="pt-4 border-t border-gray-50 flex items-center justify-between">
                        <span class="text-[14px] text-[#64748b]">Khám đa chuyên khoa</span>
                        <a asp-controller="Appointments" asp-action="Create" asp-route-medicalService="Khám Nội tổng quát & Chuyên khoa"
                           class="inline-flex items-center gap-2 bg-[#059669] text-white px-4 py-2.5 rounded-xl font-bold text-[13px] no-underline hover:bg-[#047857] transition-all">
                            Đặt lịch khám <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                        </a>
                    </div>
                </div>

                <!-- 3. Siêu Âm Chẩn Đoán Hình Ảnh -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 hover:shadow-xl hover:border-[#1e40af]/20 transition-all duration-300 flex flex-col justify-between group">
                    <div>
                        <div class="flex justify-between items-start mb-5">
                            <div class="w-12 h-12 bg-amber-50 text-[#d97706] rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                <span class="material-symbols-outlined text-[26px]">settings_accessibility</span>
                            </div>
                            <span class="px-2.5 py-1 bg-[#fffbeb] text-[#b45309] rounded-lg text-[11px] font-bold tracking-wide uppercase">Siêu âm chất lượng cao</span>
                        </div>
                        <h3 class="text-[20px] font-extrabold text-[#0f172a] mb-3">Siêu Âm Chẩn Đoán Hình Ảnh</h3>
                        <p class="text-[14px] text-[#475569] mb-5 leading-relaxed">
                            Ứng dụng sóng âm tần số cao để dựng lại hình ảnh cấu trúc bên trong cơ thể trực quan theo thời gian thực. Phương pháp an toàn, không đau đẽ, không phơi nhiễm bức xạ.
                        </p>
                        <ul class="space-y-2.5 mb-6 text-[13.5px] text-[#475569]">
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Siêu âm ổ bụng tổng quát, tuyến giáp, tuyến vú, tinh hoàn</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Siêu âm Doppler tim mạch máu chẩn đoán bệnh lý mạch</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Siêu âm thai nhi 5D dựng hình ảnh sắc nét, tầm soát dị tật</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Siêu âm đo độ cứng gan (ARFI) đánh giá mức độ xơ gan</span>
                            </li>
                        </ul>
                    </div>
                    <div class="pt-4 border-t border-gray-50 flex items-center justify-between">
                        <span class="text-[14px] text-[#64748b]">Kết quả lập tức</span>
                        <a asp-controller="Appointments" asp-action="Create" asp-route-specialtyId="10" asp-route-medicalService="Siêu âm chẩn đoán y khoa"
                           class="inline-flex items-center gap-2 bg-[#d97706] text-white px-4 py-2.5 rounded-xl font-bold text-[13px] no-underline hover:bg-[#b45309] transition-all">
                            Đặt lịch siêu âm <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                        </a>
                    </div>
                </div>

                <!-- 4. Chụp X-Quang Kỹ Thuật Số -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 hover:shadow-xl hover:border-[#1e40af]/20 transition-all duration-300 flex flex-col justify-between group">
                    <div>
                        <div class="flex justify-between items-start mb-5">
                            <div class="w-12 h-12 bg-sky-50 text-[#0284c7] rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                <span class="material-symbols-outlined text-[26px]">exposure</span>
                            </div>
                            <span class="px-2.5 py-1 bg-[#e0f2fe] text-[#0369a1] rounded-lg text-[11px] font-bold tracking-wide uppercase">Cận lâm sàng nhanh</span>
                        </div>
                        <h3 class="text-[20px] font-extrabold text-[#0f172a] mb-3">Chụp X-Quang Kỹ Thuật Số</h3>
                        <p class="text-[14px] text-[#475569] mb-5 leading-relaxed">
                            Phương pháp chẩn đoán hình ảnh cơ bản và nhanh chóng bằng tia X liều cực thấp, cho hình ảnh cấu trúc xương, tim và phổi sắc nét hiển thị ngay trên máy tính của bác sĩ.
                        </p>
                        <ul class="space-y-2.5 mb-6 text-[13.5px] text-[#475569]">
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Chụp X-quang phổi thẳng tầm soát lao, viêm phổi, u phổi</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Chụp X-quang xương khớp thẳng/nghiêng chẩn đoán gãy xương</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Chụp cột sống cổ, thắt lưng kiểm tra thoái hóa đĩa đệm</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Công nghệ cảm biến KTS giảm 70% liều tia xạ bảo vệ cơ thể</span>
                            </li>
                        </ul>
                    </div>
                    <div class="pt-4 border-t border-gray-50 flex items-center justify-between">
                        <span class="text-[14px] text-[#64748b]">An toàn liều thấp</span>
                        <a asp-controller="Appointments" asp-action="Create" asp-route-specialtyId="9" asp-route-medicalService="Chụp X-quang kỹ thuật số"
                           class="inline-flex items-center gap-2 bg-[#0284c7] text-white px-4 py-2.5 rounded-xl font-bold text-[13px] no-underline hover:bg-[#0369a1] transition-all">
                            Đặt lịch chụp <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                        </a>
                    </div>
                </div>

                <!-- 5. Xét Nghiệm Y Khoa Tự Động -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 hover:shadow-xl hover:border-[#1e40af]/20 transition-all duration-300 flex flex-col justify-between group">
                    <div>
                        <div class="flex justify-between items-start mb-5">
                            <div class="w-12 h-12 bg-indigo-50 text-[#4338ca] rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                <span class="material-symbols-outlined text-[26px]">biotech</span>
                            </div>
                            <span class="px-2.5 py-1 bg-[#e0e7ff] text-[#3730a3] rounded-lg text-[11px] font-bold tracking-wide uppercase">Đạt chuẩn ISO 15189</span>
                        </div>
                        <h3 class="text-[20px] font-extrabold text-[#0f172a] mb-3">Xét Nghiệm Y Khoa Tự Động</h3>
                        <p class="text-[14px] text-[#475569] mb-5 leading-relaxed">
                            Phân tích sinh hóa học các mẫu bệnh phẩm máu, nước tiểu... bằng robot tự động giúp giảm thiểu sai số do con người và cung cấp kết quả cực kỳ chuẩn xác cho bác sĩ lâm sàng.
                        </p>
                        <ul class="space-y-2.5 mb-6 text-[13.5px] text-[#475569]">
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Xét nghiệm máu định lượng mỡ máu, đường huyết, gout</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Kiểm tra chức năng bài tiết của gan, thận, tuyến giáp</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Xét nghiệm miễn dịch tầm soát Viêm gan B, C, giang mai, HIV</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Trả kết quả xét nghiệm qua SMS/Zalo hoặc hồ sơ bản cứng</span>
                            </li>
                        </ul>
                    </div>
                    <div class="pt-4 border-t border-gray-50 flex items-center justify-between">
                        <span class="text-[14px] text-[#64748b]">Kết quả nhanh (30 phút)</span>
                        <a asp-controller="Appointments" asp-action="Create" asp-route-specialtyId="2" asp-route-medicalService="Xét nghiệm y khoa tự động"
                           class="inline-flex items-center gap-2 bg-[#4338ca] text-white px-4 py-2.5 rounded-xl font-bold text-[13px] no-underline hover:bg-[#3730a3] transition-all">
                            Đặt lịch xét nghiệm <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                        </a>
                    </div>
                </div>

                <!-- 6. Nội Soi Tiêu Hóa Không Đau -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 hover:shadow-xl hover:border-[#1e40af]/20 transition-all duration-300 flex flex-col justify-between group">
                    <div>
                        <div class="flex justify-between items-start mb-5">
                            <div class="w-12 h-12 bg-red-50 text-[#dc2626] rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                <span class="material-symbols-outlined text-[26px]">visibility</span>
                            </div>
                            <span class="px-2.5 py-1 bg-[#fef2f2] text-[#991b1b] rounded-lg text-[11px] font-bold tracking-wide uppercase">Nội soi gây mê an toàn</span>
                        </div>
                        <h3 class="text-[20px] font-extrabold text-[#0f172a] mb-3">Nội Soi Tiêu Hóa Không Đau</h3>
                        <p class="text-[14px] text-[#475569] mb-5 leading-relaxed">
                            Giải pháp chẩn đoán chuyên sâu các bệnh trào ngược dạ dày, viêm loét đường tiêu hóa bằng phương pháp nội soi gây mê ngắn không đau, không buồn nôn.
                        </p>
                        <ul class="space-y-2.5 mb-6 text-[13.5px] text-[#475569]">
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Nội soi dạ dày qua đường mũi/đường miệng hoặc gây mê</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Nội soi đại trực tràng không đau chẩn đoán sớm polyp</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Cắt polyp đại trực tràng trực tiếp, sinh thiết tầm soát ung thư</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[#10b981] text-[18px] shrink-0 mt-0.5">check_circle</span>
                                <span>Kiểm tra vi khuẩn Helicobacter pylori (HP) dạ dày</span>
                            </li>
                        </ul>
                    </div>
                    <div class="pt-4 border-t border-gray-50 flex items-center justify-between">
                        <span class="text-[14px] text-[#64748b]">An toàn tuyệt đối</span>
                        <a asp-controller="Appointments" asp-action="Create" asp-route-specialtyId="10" asp-route-medicalService="Nội soi dạ dày & đại tràng không đau"
                           class="inline-flex items-center gap-2 bg-[#dc2626] text-white px-4 py-2.5 rounded-xl font-bold text-[13px] no-underline hover:bg-[#b91c1c] transition-all">
                            Đặt lịch nội soi <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                        </a>
                    </div>
                </div>

                <!-- 7. Chẩn Đoán Hình Ảnh Chuyên Sâu (CT & MRI) -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 hover:shadow-xl hover:border-[#1e40af]/20 transition-all duration-300 flex flex-col justify-between group md:col-span-2 lg:col-span-3">
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                        <div class="lg:col-span-2">
                            <div class="flex justify-between items-start mb-5">
                                <div class="w-12 h-12 bg-purple-50 text-[#7c3aed] rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                    <span class="material-symbols-outlined text-[26px]">donut_large</span>
                                </div>
                                <span class="px-2.5 py-1 bg-[#f5f3ff] text-[#6d28d9] rounded-lg text-[11px] font-bold tracking-wide uppercase">Kỹ thuật đỉnh cao</span>
