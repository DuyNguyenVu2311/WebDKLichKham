@model WebDKLichKham.Models.ViewModels.Article
@{
    ViewData["Title"] = Model.Title;
    var allArticles = WebDKLichKham.Data.ArticleRepository.GetAllArticles()
        .Where(a => a.Id != Model.Id)
        .Take(3)
        .ToList();
}

<main class="font-sans bg-[#f8fafc] py-12">
    <div class="max-w-container-max mx-auto px-4 md:px-8">
        
        <!-- Breadcrumbs -->
        <nav class="flex items-center gap-2 text-[14px] text-gray-500 mb-8 overflow-x-auto whitespace-nowrap">
            <a asp-controller="Home" asp-action="Index" class="hover:text-primary transition-colors no-underline">Trang chủ</a>
            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
            <a asp-controller="Home" asp-action="MedicalKnowledge" class="hover:text-primary transition-colors no-underline">Kiến thức y khoa</a>
            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
            <span class="text-gray-800 truncate max-w-[200px] md:max-w-none">@Model.Title</span>
        </nav>

        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Main Article Content -->
            <article class="flex-1 bg-white rounded-3xl border border-gray-100 p-6 md:p-10 shadow-sm">
                
                <!-- Category Badge -->
                <span class="inline-block text-white text-[12px] font-bold px-3.5 py-1.5 rounded-full uppercase tracking-wider mb-5" style="background-color: @Model.CategoryColor">
                    @Model.CategoryName
                </span>
                
                <!-- Title -->
                <h1 class="text-[28px] md:text-[38px] font-extrabold text-[#00346f] leading-tight mb-6">
                    @Model.Title
                </h1>
                
                <!-- Meta information -->
                <div class="flex flex-wrap items-center gap-6 pb-6 border-b border-gray-100 mb-8 text-[14px] text-gray-500">
                    <span class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">calendar_today</span>
                        @Model.DateString
                    </span>
                    <span class="flex items-center gap-2 text-[#008a7b] font-semibold bg-[#e6f4f2] px-3 py-1 rounded-full text-[13px]">
                        <span class="material-symbols-outlined text-[16px]">verified</span>
                        Đã kiểm duyệt chuyên môn
                    </span>
                </div>
                
                <!-- Featured Image -->
                <div class="rounded-2xl overflow-hidden aspect-[16/9] mb-8 bg-gray-100 shadow-inner">
                    <img src="@Model.ImageUrl" alt="@Model.Title" class="w-full h-full object-cover" />
                </div>
                
                <!-- Article Body -->
                <div class="prose max-w-none text-[#334155] text-[16px] leading-relaxed space-y-6">
                    @Html.Raw(Model.Content)
                </div>

                <!-- Footer Sign-off -->
                <div class="mt-12 pt-8 border-t border-gray-100 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-[#00346f]/10 text-[#00346f] flex items-center justify-center font-bold text-[14px]">
                            DT
                        </div>
                        <div>
                            <p class="text-[14px] font-bold text-gray-800 mb-0.5">Ban Biên Tập Y Khoa</p>
                            <p class="text-[12px] text-gray-400">Phòng khám Đa khoa Duy Tâm</p>
                        </div>
                    </div>
                    <button onclick="window.print()" class="p-2.5 rounded-full border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-primary transition-all flex items-center justify-center">
                        <span class="material-symbols-outlined text-[20px]">print</span>
                    </button>
                </div>

            </article>

            <!-- Sidebar -->
            <aside class="w-full lg:w-[380px] shrink-0 space-y-6">
                
                <!-- Booking CTA Card -->
                <div class="bg-gradient-to-br from-[#00346f] to-[#001e47] text-white rounded-3xl p-8 shadow-xl relative overflow-hidden">
                    <div class="absolute -right-10 -bottom-10 opacity-10 pointer-events-none">
                        <span class="material-symbols-outlined text-[180px]">calendar_month</span>
                    </div>
                    <div class="relative z-10">
                        <span class="inline-block px-3 py-1 bg-white/20 rounded-full text-[11px] font-bold uppercase tracking-wider mb-4">Dịch vụ trực tuyến</span>
                        <h3 class="text-[22px] font-bold mb-3">Đặt lịch khám nhanh chóng</h3>
                        <p class="text-blue-100 text-[14px] leading-relaxed mb-6">
                            Lựa chọn bác sĩ chuyên khoa giỏi, chủ động thời gian thăm khám và nhận kết quả nhanh chóng.
                        </p>
                        <a asp-controller="Appointments" asp-action="Create" class="w-full inline-flex items-center justify-center gap-2 bg-white text-[#00346f] hover:bg-blue-50 py-3.5 px-6 rounded-xl font-bold text-[15px] transition-colors shadow-md no-underline">
                            <span class="material-symbols-outlined text-[18px]">edit_calendar</span>
                            Đặt lịch hẹn ngay
                        </a>
                    </div>
                </div>

                <!-- Related Articles Card -->
                <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm">
                    <h3 class="text-[18px] font-bold text-[#00346f] mb-5 pb-3 border-b border-gray-50">Bài viết liên quan</h3>
                    <div class="space-y-5">
                        @foreach (var article in allArticles)
                        {
                            <a asp-controller="Home" asp-action="ArticleDetail" asp-route-id="@article.Id" class="group flex gap-4 no-underline text-inherit block">
                                <div class="w-20 h-20 rounded-lg overflow-hidden bg-gray-100 shrink-0">
                                    <img src="@article.ImageUrl" alt="@article.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                </div>
                                <div class="flex-1 flex flex-col justify-between py-0.5">
                                    <h4 class="text-[14px] font-bold text-gray-800 group-hover:text-primary transition-colors line-clamp-2 leading-snug">
                                        @article.Title
                                    </h4>
                                    <span class="text-[11px] text-gray-400 font-medium">@article.DateString</span>
                                </div>
                            </a>
                        }
                    </div>
                </div>

            </aside>

        </div>
    </div>
</main>
