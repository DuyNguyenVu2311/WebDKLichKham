                <div class="relative z-10 mt-auto">
                    <a asp-controller="Doctors" asp-action="Index" class="inline-flex items-center gap-2 w-full justify-center px-5 py-3.5 bg-white text-[#1e40af] rounded-xl font-bold text-[14px] shadow-sm hover:bg-blue-50 active:scale-[0.98] transition-all no-underline">
                        Khám phá tất cả bác sĩ
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

