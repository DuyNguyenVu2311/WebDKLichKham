@model WebDKLichKham.Models.ViewModels.HomeDashboardViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<section class="relative w-full min-h-[100vh] flex items-center overflow-hidden bg-[#f0f4ff]">
    <!-- Decorative blobs -->
    <div class="absolute top-[-120px] left-[-120px] w-[500px] h-[500px] bg-[#2563eb]/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-[-80px] right-[-80px] w-[400px] h-[400px] bg-[#0ea5e9]/10 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="relative z-10 w-full max-w-[1280px] mx-auto px-4 md:px-8 py-16 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        
        <!-- LEFT SIDE: Content -->
        <div class="flex flex-col gap-8">

            <!-- Badge -->
            <div class="flex items-center gap-2">
                <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-[#2563eb]/20 text-[#2563eb] rounded-full text-[13px] font-bold shadow-sm">
                    <span class="w-2 h-2 bg-[#2563eb] rounded-full animate-pulse"></span>
                    Tiêu chuẩn JCI Quốc tế
                </span>
                <span class="inline-flex items-center gap-1.5 px-4 py-2 bg-[#059669]/10 text-[#059669] rounded-full text-[13px] font-bold border border-[#059669]/20">
                    <span class="material-symbols-outlined text-[14px]">health_and_safety</span> Bộ Y Tế cấp phép
                </span>
            </div>

            <!-- Main Headline -->
            <div>
                <p class="text-[13px] font-bold text-[#2563eb] uppercase tracking-[0.15em] mb-3">Phòng Khám Đa Khoa Duy Tâm</p>
                <h1 class="text-[42px] md:text-[56px] font-extrabold text-[#0f172a] leading-[1.15] tracking-tight mb-5">
                    Chăm Sóc <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#2563eb] to-[#0ea5e9]">Tận Tâm,</span><br/>
                    Vươn Tầm <span class="text-[#0f172a]">Quốc Tế</span>
                </h1>
                <p class="text-[17px] text-[#475569] leading-relaxed max-w-lg">
                    Phòng khám đa khoa hàng đầu với đội ngũ bác sĩ chuyên gia và công nghệ chẩn đoán y khoa tiên tiến nhất hiện nay.
                </p>
            </div>

            <!-- Founder Story Card (Redesigned) -->
            <div class="bg-white rounded-3xl p-7 shadow-lg border border-gray-100 relative overflow-hidden">
                <!-- Subtle top-left accent -->
                <div class="absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-[#2563eb] to-[#0ea5e9] rounded-l-3xl"></div>
                
                <div class="pl-2">
                    <!-- Founder identity -->
                    <div class="flex items-center gap-4 mb-5">
                        <div class="relative shrink-0">
                            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#1e40af] to-[#2563eb] flex items-center justify-center text-white text-[22px] font-black shadow-md">NVD</div>
                            <div class="absolute -bottom-1.5 -right-1.5 w-6 h-6 bg-[#059669] rounded-full flex items-center justify-center shadow">
                                <span class="material-symbols-outlined text-white text-[14px]">verified</span>
                            </div>
                        </div>
                        <div>
                            <h3 class="text-[18px] font-bold text-[#1e293b]">CEO Nguyễn Vũ Duy</h3>
                            <p class="text-[12px] font-bold text-[#64748b] uppercase tracking-widest">Người sáng lập & Điều hành</p>
                        </div>
                    </div>
                    
                    <!-- Narrative Story -->
                    <div class="space-y-3 text-[14px] text-[#475569] leading-relaxed">
                        <p class="italic text-[15px] text-[#1e293b] font-medium border-l-4 border-[#2563eb]/30 pl-4">
                            "Tôi lớn lên trong một gia đình mà người thân mắc bệnh mãn tính. Tôi đã chứng kiến sự khó khăn, sự chờ đợi và nỗi lo lắng của họ tại mỗi lần đi khám..."
                        </p>
                        <p>
                            Đó là lý do tôi quyết định dành toàn bộ sự nghiệp để xây dựng một nơi mà bệnh nhân không chỉ được <strong class="text-[#1e293b]">chữa bệnh</strong> — mà còn được <strong class="text-[#1e293b]">cảm thấy an toàn và được lắng nghe</strong>.
                        </p>
                    </div>

                    <!-- Credentials row -->
                    <div class="flex flex-wrap gap-2 mt-5">
                        <span class="inline-flex items-center gap-1 text-[11px] font-bold text-[#2563eb] bg-[#eff6ff] px-3 py-1.5 rounded-full border border-[#bfdbfe]">
                            <span class="material-symbols-outlined text-[13px]">workspace_premium</span> Cam kết chất lượng
                        </span>
                        <span class="inline-flex items-center gap-1 text-[11px] font-bold text-[#059669] bg-[#ecfdf5] px-3 py-1.5 rounded-full border border-[#a7f3d0]">
                            <span class="material-symbols-outlined text-[13px]">shield</span> Minh bạch – Tận tâm
                        </span>
                        <span class="inline-flex items-center gap-1 text-[11px] font-bold text-[#d97706] bg-[#fffbeb] px-3 py-1.5 rounded-full border border-[#fde68a]">
                            <span class="material-symbols-outlined text-[13px]">star</span> 10+ năm kinh nghiệm
                        </span>
                    </div>
                </div>
            </div>

            <!-- Stats Row -->
            <div class="grid grid-cols-3 gap-3">
                <div class="bg-white rounded-2xl px-4 py-4 flex flex-col items-center gap-1.5 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <div class="w-9 h-9 rounded-xl bg-[#eff6ff] flex items-center justify-center mb-1">
                        <span class="material-symbols-outlined text-[#2563eb] text-[18px]">stethoscope</span>
                    </div>
                    <div class="text-[26px] font-black text-[#1e293b] leading-none">@Model.TotalDoctors<span class="text-[#2563eb]">+</span></div>
                    <div class="text-[12px] text-[#64748b] font-medium text-center leading-tight">Bác sĩ<br/>chuyên gia</div>
                </div>
                <div class="bg-white rounded-2xl px-4 py-4 flex flex-col items-center gap-1.5 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <div class="w-9 h-9 rounded-xl bg-[#ecfdf5] flex items-center justify-center mb-1">
                        <span class="material-symbols-outlined text-[#059669] text-[18px]">local_hospital</span>
                    </div>
                    <div class="text-[26px] font-black text-[#1e293b] leading-none">@Model.FeaturedSpecialties.Count<span class="text-[#059669]">+</span></div>
                    <div class="text-[12px] text-[#64748b] font-medium text-center leading-tight">Chuyên<br/>khoa</div>
                </div>
                <div class="bg-white rounded-2xl px-4 py-4 flex flex-col items-center gap-1.5 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <div class="w-9 h-9 rounded-xl bg-[#fff7ed] flex items-center justify-center mb-1">
                        <span class="material-symbols-outlined text-[#d97706] text-[18px]">schedule</span>
                    </div>
                    <div class="text-[26px] font-black text-[#1e293b] leading-none">15<span class="text-[#d97706] text-[16px] font-bold">'</span></div>
                    <div class="text-[12px] text-[#64748b] font-medium text-center leading-tight">Xác nhận<br/>lịch hẹn</div>
                </div>
            </div>
        </div>

        <!-- RIGHT SIDE: Booking Form -->
        <div class="flex justify-center lg:justify-end">
            <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 w-full max-w-[430px] overflow-hidden">
                <!-- Form header gradient -->
                <div class="bg-gradient-to-r from-[#1e40af] to-[#2563eb] px-8 py-6">
                    <h2 class="text-[20px] font-bold text-white flex items-center gap-2 mb-1">
                        <span class="material-symbols-outlined">edit_calendar</span> Đặt Lịch Khám Online
                    </h2>
                    <p class="text-[13px] text-blue-200">Xác nhận lịch hẹn trong vòng 15 phút</p>
                </div>
                
                <div class="px-8 py-7">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="bg-red-50 text-red-600 p-3 rounded-lg text-sm font-semibold mb-4 border border-red-200">
                            @TempData["ErrorMessage"]
                        </div>
                    }
                    <form id="homeBookingForm" class="space-y-4">
                        <div>
                            <label class="block text-[13px] font-semibold text-[#374151] mb-1.5">Họ và tên *</label>
                            <input name="fullName" id="fullName" type="text" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#2563eb] focus:border-transparent outline-none transition-all text-[15px] bg-[#f8fafc]" placeholder="Nguyễn Văn A" />
                        </div>
                        <div>
                            <label class="block text-[13px] font-semibold text-[#374151] mb-1.5">Số điện thoại *</label>
                            <input name="phoneNumber" id="phoneNumber" type="tel" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#2563eb] focus:border-transparent outline-none transition-all text-[15px] bg-[#f8fafc]" placeholder="0901 234 567" />
                        </div>
                        <div>
                            <label class="block text-[13px] font-semibold text-[#374151] mb-1.5">Chuyên khoa khám</label>
                            <select name="specialtyId" id="homeSpecialtySelect" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#2563eb] focus:border-transparent outline-none transition-all appearance-none bg-[#f8fafc] text-[15px]">
                                <option value="">-- Chọn chuyên khoa --</option>
                                @foreach (var sp in Model.AllSpecialtiesWithDoctors)
                                {
                                    <option value="@sp.Id">@sp.Name</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-[13px] font-semibold text-[#374151] mb-1.5">Cơ sở khám</label>
                            <select name="Facility" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#2563eb] focus:border-transparent outline-none transition-all appearance-none bg-[#f8fafc] text-[15px]">
                                <option value="">-- Chọn cơ sở --</option>
                                <option value="CS1">Cơ sở 1: TP. Thủ Đức</option>
                                <option value="CS2">Cơ sở 2: Nhơn Trạch</option>
                            </select>
                        </div>
                        <!-- Dịch vụ khám -->
                        <div>
                            <label class="block text-[13px] font-semibold text-[#374151] mb-1.5">Dịch vụ khám</label>
                            <select name="medicalService" id="homeMedicalServiceSelect" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#2563eb] focus:border-transparent outline-none transition-all appearance-none bg-[#f8fafc] text-[15px]">
                                <option value="">-- Chọn dịch vụ khám --</option>
                                <optgroup label="Khám Chuyên Khoa">
                                    <option value="Khám Nội tổng quát">Khám Nội tổng quát</option>
                                    <option value="Tầm soát Tim mạch & Đái tháo đường">Tầm soát Tim mạch & Đái tháo đường</option>
                                    <option value="Khám & Điều trị bệnh lý Da liễu">Khám & Điều trị bệnh lý Da liễu</option>
                                    <option value="Trị mụn & Chăm sóc da chuyên sâu">Trị mụn & Chăm sóc da chuyên sâu</option>
                                    <option value="Khám Nhi tổng quát & Tư vấn dinh dưỡng">Khám Nhi tổng quát & Tư vấn dinh dưỡng</option>
                                    <option value="Khám & Tiêm chủng vắc-xin cho trẻ">Khám & Tiêm chủng vắc-xin cho trẻ</option>
                                    <option value="Khám & Nội soi Tai Mũi Họng">Khám & Nội soi Tai Mũi Họng</option>
                                    <option value="Điều trị viêm mũi họng, viêm xoang">Điều trị viêm mũi họng, viêm xoang</option>
                                    <option value="Khám thai định kỳ & Quản lý thai sản">Khám thai định kỳ & Quản lý thai sản</option>
                                    <option value="Khám Phụ khoa & Tầm soát ung thư cổ tử cung">Khám Phụ khoa & Tầm soát ung thư cổ tử cung</option>
                                    <option value="Khám răng tổng quát & Cạo vôi răng">Khám răng tổng quát & Cạo vôi răng</option>
                                    <option value="Nhổ răng khôn & Hàn răng thẩm mỹ">Nhổ răng khôn & Hàn răng thẩm mỹ</option>
                                    <option value="Khám Nội thần kinh (Đau đầu, chóng mặt, mất ngủ)">Khám Nội thần kinh (Đau đầu, chóng mặt, mất ngủ)</option>
                                    <option value="Tầm soát nguy cơ đột quỵ & Tai biến">Tầm soát nguy cơ đột quỵ & Tai biến</option>
                                </optgroup>
                                <optgroup label="Dịch Vụ Khám Đặc Thù">
                                    <option value="Khám sức khỏe tổng quát định kỳ">Khám sức khỏe tổng quát định kỳ</option>
                                    <option value="Gói tầm soát sức khỏe Toàn diện (VIP)">Gói tầm soát sức khỏe Toàn diện (VIP)</option>
                                    <option value="Xét nghiệm máu & Kiểm tra sinh hóa tại nhà">Xét nghiệm máu & Kiểm tra sinh hóa tại nhà</option>
                                </optgroup>
                            </select>
                        </div>

                        <!-- Thời gian khám (Ngày) -->
                        <div>
                            <label class="block text-[13px] font-semibold text-[#374151] mb-2 flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-green-600 text-[18px]">calendar_today</span> Thời gian khám
                            </label>
                            <input name="appointmentDate" id="appointmentDate" type="hidden" />
                            <div class="grid grid-cols-4 gap-2 md:gap-3" id="homeDateCardsContainer">
                                <button type="button" id="homeQuickDateCard0" class="date-card py-2.5 px-2 border border-gray-200 rounded-xl flex flex-col items-center justify-center transition-all bg-white hover:border-gray-400 cursor-pointer">
                                    <span class="text-[13px] font-bold text-gray-800" id="homeQuickDateStr0"></span>
                                    <span class="text-[10px] text-gray-400 mt-0.5" id="homeQuickDayStr0"></span>
                                </button>
                                <button type="button" id="homeQuickDateCard1" class="date-card py-2.5 px-2 border border-gray-200 rounded-xl flex flex-col items-center justify-center transition-all bg-white hover:border-gray-400 cursor-pointer">
                                    <span class="text-[13px] font-bold text-gray-800" id="homeQuickDateStr1"></span>
                                    <span class="text-[10px] text-gray-400 mt-0.5" id="homeQuickDayStr1"></span>
                                </button>
                                <button type="button" id="homeQuickDateCard2" class="date-card py-2.5 px-2 border border-gray-200 rounded-xl flex flex-col items-center justify-center transition-all bg-white hover:border-gray-400 cursor-pointer">
                                    <span class="text-[13px] font-bold text-gray-800" id="homeQuickDateStr2"></span>
                                    <span class="text-[10px] text-gray-400 mt-0.5" id="homeQuickDayStr2"></span>
                                </button>
                                <button type="button" id="homeOtherDateCard" class="date-card py-2.5 px-2 border border-gray-200 rounded-xl flex flex-col items-center justify-center transition-all bg-white hover:border-gray-400 cursor-pointer relative">
                                    <span class="material-symbols-outlined text-[18px] text-gray-500 mb-0.5">calendar_month</span>
                                    <span class="text-[10px] text-gray-500 font-bold">Ngày khác</span>
                                    <input type="date" id="homeHiddenDateInput" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full" />
                                </button>
                            </div>
                        </div>

                        <!-- Chọn giờ khám -->
                        <div>
                            <label class="block text-[13px] font-semibold text-[#374151] mb-2 flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-green-600 text-[18px]">schedule</span> Chọn giờ khám
                            </label>
                            <input name="startTime" id="homeStartTime" type="hidden" />
                            <input name="endTime" id="homeEndTime" type="hidden" />
                            <div class="grid grid-cols-4 gap-2 text-center" id="homeTimeSlotsContainer">
                                @{
                                    var timeSlots = new[] {
                                        "07:00", "07:30", "08:00", "08:30",
                                        "09:00", "09:30", "10:00", "10:30",
                                        "11:00", "11:30", "13:00", "13:30",
                                        "14:00", "14:30", "15:00", "15:30",
                                        "16:00", "16:30", "17:00", "17:30"
                                    };
                                }
                                @foreach (var ts in timeSlots)
                                {
                                    <button type="button" data-time="@ts" onclick="selectHomeTimeSlot('@ts')" class="home-time-slot-btn py-2 px-1 text-[13px] font-medium rounded-xl border border-gray-200 bg-white hover:border-green-500 hover:text-green-600 transition-all cursor-pointer text-gray-700">
                                        @ts
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[13px] font-semibold text-[#374151] mb-1.5">Mã xác nhận (4 số) *</label>
                                <input name="passcode" id="passcode" type="password" maxlength="4" pattern="\d{4}" inputmode="numeric" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#2563eb] focus:border-transparent outline-none transition-all text-[15px] bg-[#f8fafc]" placeholder="1234" />
                            </div>
                            <div>
                                <label class="block text-[13px] font-semibold text-[#374151] mb-1.5">Nhập lại mã *</label>
                                <input name="confirmPasscode" id="confirmPasscode" type="password" maxlength="4" pattern="\d{4}" inputmode="numeric" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#2563eb] focus:border-transparent outline-none transition-all text-[15px] bg-[#f8fafc]" placeholder="1234" />
                            </div>
                        </div>
                        <p class="text-[11px] text-amber-600 font-medium leading-normal mt-1 m-0">
                            Lưu ý: Bạn phải nhớ mã này để tra cứu lịch khám sau này.
                        </p>
                        <button type="button" onclick="showQuickBookModal()" class="w-full py-4 bg-gradient-to-r from-[#1e40af] to-[#2563eb] text-white rounded-2xl font-bold text-[16px] shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-[0.98] transition-all mt-2 flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">event_available</span> ĐĂNG KÝ NGAY
                        </button>
                    </form>

                    <!-- Trust signals below form -->
                    <div class="flex items-center justify-center gap-5 mt-5 pt-5 border-t border-gray-100">
                        <div class="flex items-center gap-1.5 text-[12px] text-[#64748b]">
                            <span class="material-symbols-outlined text-[#059669] text-[16px]">lock</span> Bảo mật thông tin
                        </div>
                        <div class="w-px h-4 bg-gray-200"></div>
                        <div class="flex items-center gap-1.5 text-[12px] text-[#64748b]">
                            <span class="material-symbols-outlined text-[#2563eb] text-[16px]">verified</span> Xác nhận ngay
                        </div>
                        <div class="w-px h-4 bg-gray-200"></div>
                        <div class="flex items-center gap-1.5 text-[12px] text-[#64748b]">
                            <span class="material-symbols-outlined text-[#d97706] text-[16px]">support_agent</span> Hỗ trợ 24/7
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- Modal Đăng Ký Nhanh -->
<div id="quickBookModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm px-4">
    <div class="bg-white p-8 rounded-3xl max-w-md w-full shadow-2xl relative animate-fadeInUp">
        <div class="w-16 h-16 bg-surface-container-low text-primary rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="material-symbols-outlined text-[32px]">contact_support</span>
        </div>
        <h3 class="text-headline-md font-headline-md text-primary text-center mb-3">Bạn có muốn tư vấn kỹ hơn?</h3>
        <p class="text-on-surface-variant text-center mb-8 text-body-md">Việc cung cấp thêm triệu chứng và tình trạng bệnh sử sẽ giúp bác sĩ chuẩn bị phác đồ tư vấn chính xác nhất cho bạn.</p>
        
        <div class="flex flex-col gap-3">
            <button type="button" onclick="submitDetailedBook()" class="w-full py-3.5 bg-primary text-white rounded-xl font-bold hover:bg-primary-container transition-colors shadow-md flex items-center justify-center gap-2">
                <span class="material-symbols-outlined">edit_document</span> Có, nhập thêm triệu chứng
            </button>
            <form id="postQuickBookForm" method="post" asp-controller="Appointments" asp-action="QuickBook">
                <!-- hidden fields auto populated by JS -->
                <button type="submit" onclick="populatePostForm()" class="w-full py-3.5 bg-white text-primary border-2 border-primary/20 rounded-xl font-bold hover:bg-surface-container-low transition-colors flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">flash_on</span> Không, đặt lịch ngay
                </button>
            </form>
            <button type="button" onclick="hideQuickBookModal()" class="w-full py-2 text-on-surface-variant font-medium underline mt-2 hover:text-primary transition-colors">
                Đóng
            </button>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeInUpModal {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .animate-fadeInUp { animation: fadeInUpModal 0.3s ease-out forwards; }
</style>

<script>
    function selectHomeTimeSlot(timeStr) {
        document.getElementById('homeStartTime').value = timeStr;
        
        let [h, m] = timeStr.split(':').map(Number);
        let endMin = h * 60 + m + 30;
        let endH = Math.floor(endMin / 60) % 24;
        let endM = endMin % 60;
        document.getElementById('homeEndTime').value = String(endH).padStart(2, '0') + ':' + String(endM).padStart(2, '0');
        
        document.querySelectorAll('.home-time-slot-btn').forEach(btn => {
            if (btn.dataset.time === timeStr) {
                btn.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
                btn.classList.add('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'font-bold', 'scale-[1.02]');
            } else {
                btn.classList.remove('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'font-bold', 'scale-[1.02]');
                btn.classList.add('bg-white', 'text-gray-700', 'border-gray-200');
            }
        });
    }

    function showQuickBookModal() {
        const form = document.getElementById('homeBookingForm');
        
        // Custom validations for Date and Time
        const dateInput = document.getElementById('appointmentDate');
        if (!dateInput.value) {
            alert('Vui lòng chọn ngày khám.');
            return;
        }

        const startTime = document.getElementById('homeStartTime');
        if (!startTime.value) {
            alert('Vui lòng chọn khung giờ khám.');
            return;
        }

        // Passcode match validation
        const passcode = document.getElementById('passcode');
        const confirmPasscode = document.getElementById('confirmPasscode');
        if (passcode.value !== confirmPasscode.value) {
            confirmPasscode.setCustomValidity('Mã xác nhận nhập lại không khớp.');
        } else {
            confirmPasscode.setCustomValidity('');
        }

        // HTML5 validation
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }
        const modal = document.getElementById('quickBookModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }

    function hideQuickBookModal() {
        const modal = document.getElementById('quickBookModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }

    function submitDetailedBook() {
        const form = document.getElementById('homeBookingForm');
        form.method = 'get';
        form.action = '/Appointments/Create';
        form.submit();
    }

    function populatePostForm() {
        const getForm = document.getElementById('homeBookingForm');
        const postForm = document.getElementById('postQuickBookForm');
        
        postForm.querySelectorAll('input[type="hidden"]:not([name="__RequestVerificationToken"])').forEach(e => e.remove());

        const fields = ['fullName', 'phoneNumber', 'specialtyId', 'Facility', 'appointmentDate', 'passcode', 'confirmPasscode', 'startTime', 'endTime', 'medicalService'];
        fields.forEach(field => {
            const el = getForm.querySelector(`[name="${field}"]`);
            if (el) {
                const val = el.value;
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = field;
                input.value = val;
                postForm.appendChild(input);
            }
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        const specialtySelect = document.getElementById('homeSpecialtySelect');
        const serviceSelectElement = document.getElementById('homeMedicalServiceSelect');

        const medicalServices = [
            // Nội tổng hợp
            { value: "Khám Nội tổng quát", text: "Khám Nội tổng quát", specialty: "Nội tổng hợp", group: "Khám Chuyên Khoa" },
            { value: "Tầm soát Tim mạch & Đái tháo đường", text: "Tầm soát Tim mạch & Đái tháo đường", specialty: "Nội tổng hợp", group: "Khám Chuyên Khoa" },
            
            // Da liễu
            { value: "Khám & Điều trị bệnh lý Da liễu", text: "Khám & Điều trị bệnh lý Da liễu", specialty: "Da liễu", group: "Khám Chuyên Khoa" },
            { value: "Trị mụn & Chăm sóc da chuyên sâu", text: "Trị mụn & Chăm sóc da chuyên sâu", specialty: "Da liễu", group: "Khám Chuyên Khoa" },
            
            // Nhi khoa
            { value: "Khám Nhi tổng quát & Tư vấn dinh dưỡng", text: "Khám Nhi tổng quát & Tư vấn dinh dưỡng", specialty: "Nhi khoa", group: "Khám Chuyên Khoa" },
            { value: "Khám & Tiêm chủng vắc-xin cho trẻ", text: "Khám & Tiêm chủng vắc-xin cho trẻ", specialty: "Nhi khoa", group: "Khám Chuyên Khoa" },
            
            // Tai Mũi Họng
            { value: "Khám & Nội soi Tai Mũi Họng", text: "Khám & Nội soi Tai Mũi Họng", specialty: "Tai Mũi Họng", group: "Khám Chuyên Khoa" },
            { value: "Điều trị viêm mũi họng, viêm xoang", text: "Điều trị viêm mũi họng, viêm xoang", specialty: "Tai Mũi Họng", group: "Khám Chuyên Khoa" },
            
            // Sản phụ khoa
            { value: "Khám thai định kỳ & Quản lý thai sản", text: "Khám thai định kỳ & Quản lý thai sản", specialty: "Sản phụ khoa", group: "Khám Chuyên Khoa" },
            { value: "Khám Phụ khoa & Tầm soát ung thư cổ tử cung", text: "Khám Phụ khoa & Tầm soát ung thư cổ tử cung", specialty: "Sản phụ khoa", group: "Khám Chuyên Khoa" },
            
            // Răng Hàm Mặt
            { value: "Khám răng tổng quát & Cạo vôi răng", text: "Khám răng tổng quát & Cạo vôi răng", specialty: "Răng Hàm Mặt", group: "Khám Chuyên Khoa" },
            { value: "Nhổ răng khôn & Hàn răng thẩm mỹ", text: "Nhổ răng khôn & Hàn răng thẩm mỹ", specialty: "Răng Hàm Mặt", group: "Khám Chuyên Khoa" },
            
            // Nội thần kinh
            { value: "Khám Nội thần kinh (Đau đầu, chóng mặt, mất ngủ)", text: "Khám Nội thần kinh (Đau đầu, chóng mặt, mất ngủ)", specialty: "Nội thần kinh", group: "Khám Chuyên Khoa" },
            { value: "Tầm soát nguy cơ đột quỵ & Tai biến", text: "Tầm soát nguy cơ đột quỵ & Tai biến", specialty: "Nội thần kinh", group: "Khám Chuyên Khoa" },
            
            // Dịch Vụ Khám Đặc Thù
            { value: "Khám sức khỏe tổng quát định kỳ", text: "Khám sức khỏe tổng quát định kỳ", specialty: "", group: "Dịch Vụ Khám Đặc Thù" },
            { value: "Gói tầm soát sức khỏe Toàn diện (VIP)", text: "Gói tầm soát sức khỏe Toàn diện (VIP)", specialty: "", group: "Dịch Vụ Khám Đặc Thù" },
            { value: "Xét nghiệm máu & Kiểm tra sinh hóa tại nhà", text: "Xét nghiệm máu & Kiểm tra sinh hóa tại nhà", specialty: "", group: "Dịch Vụ Khám Đặc Thù" }
        ];

        const specialtyNameToId = {};
        const specialtyIdToName = {};
        if (specialtySelect) {
            Array.from(specialtySelect.options).forEach(opt => {
                if (opt.value) {
                    specialtyNameToId[opt.text.trim()] = opt.value;
                    specialtyIdToName[opt.value] = opt.text.trim();
                }
            });
        }

        function renderServices(specialtyName) {
            if (!serviceSelectElement) return;
            const currentServiceVal = serviceSelectElement.value;
            
            const filtered = medicalServices.filter(s => {
                return !specialtyName || s.specialty === specialtyName;
            });

            serviceSelectElement.innerHTML = '<option value="">-- Chọn dịch vụ khám --</option>';
            const groups = {};
            filtered.forEach(s => {
                if (!groups[s.group]) groups[s.group] = [];
                groups[s.group].push(s);
            });

            for (const groupName in groups) {
                const optGroup = document.createElement('optgroup');
                optGroup.label = groupName;
                groups[groupName].forEach(s => {
                    const opt = document.createElement('option');
                    opt.value = s.value;
                    opt.textContent = s.text;
                    if (s.value === currentServiceVal) opt.selected = true;
                    optGroup.appendChild(opt);
                });
                serviceSelectElement.appendChild(optGroup);
            }
        }

        function lockSpecialties(allowedSpecialtyId) {
            if (!specialtySelect) return;
            Array.from(specialtySelect.options).forEach(opt => {
                if (opt.value === "") {
                    opt.style.display = "";
                    opt.disabled = false;
                } else if (allowedSpecialtyId !== "" && opt.value === allowedSpecialtyId) {
                    opt.style.display = "";
                    opt.disabled = false;
                } else {
                    opt.style.display = "none";
                    opt.disabled = true;
                }
            });
        }

        function unlockSpecialties() {
            if (!specialtySelect) return;
            Array.from(specialtySelect.options).forEach(opt => {
                opt.style.display = "";
                opt.disabled = false;
            });
        }

        function syncHomeSpecialtyAndService(changedSource) {
            const specialtyVal = specialtySelect ? specialtySelect.value : '';
            const specialtyName = specialtyIdToName[specialtyVal] || '';
            const serviceVal = serviceSelectElement ? serviceSelectElement.value : '';
            const selectedService = medicalServices.find(s => s.value === serviceVal);

            if (changedSource === 'specialty') {
                renderServices(specialtyName);
                
                const currentServiceObj = medicalServices.find(s => s.value === serviceSelectElement.value);
                if (currentServiceObj && specialtyVal !== "" && currentServiceObj.specialty !== specialtyName) {
                    serviceSelectElement.value = "";
                }
            } 
            else if (changedSource === 'service') {
                if (selectedService) {
                    if (selectedService.specialty !== "") {
                        const targetSpecialtyId = specialtyNameToId[selectedService.specialty];
                        if (targetSpecialtyId) {
                            specialtySelect.value = targetSpecialtyId;
                            lockSpecialties(targetSpecialtyId);
                        }
                    } else {
                        specialtySelect.value = "";
                        lockSpecialties("");
                    }
                    renderServices(selectedService.specialty);
                } else {
                    unlockSpecialties();
                    renderServices(specialtyName);
                }
            }
        }

        if (serviceSelectElement) {
            serviceSelectElement.addEventListener('change', function() {
                syncHomeSpecialtyAndService('service');
            });
        }
        if (specialtySelect) {
            specialtySelect.addEventListener('change', function() {
                syncHomeSpecialtyAndService('specialty');
            });
        }

        // Run initial synchronization
        if (specialtySelect && specialtySelect.value) {
            syncHomeSpecialtyAndService('specialty');
        } else if (serviceSelectElement && serviceSelectElement.value) {
            syncHomeSpecialtyAndService('service');
        }

        const dateInput = document.getElementById('appointmentDate');
        if (dateInput) {
            const now = new Date();
            const todayStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
            let minDateStr = todayStr;
            
            // If past 17:30, clinic is closed for today, set min and value to tomorrow
            if (now.getHours() > 17 || (now.getHours() === 17 && now.getMinutes() >= 30)) {
                const tomorrow = new Date(now);
                tomorrow.setDate(tomorrow.getDate() + 1);
                const tomorrowStr = tomorrow.getFullYear() + '-' + String(tomorrow.getMonth() + 1).padStart(2, '0') + '-' + String(tomorrow.getDate()).padStart(2, '0');
                dateInput.min = tomorrowStr;
                minDateStr = tomorrowStr;
                dateInput.value = tomorrowStr;
            } else {
                dateInput.min = todayStr;
                dateInput.value = todayStr;
            }

            // Initialize quick date cards for Home page
            initHomeQuickDateCards(minDateStr);
        }

        function initHomeQuickDateCards(minDateStr) {
            const parts = minDateStr.split('-');
            const baseDate = new Date(parts[0], parts[1] - 1, parts[2]);
            const dates = [];
            for (let i = 0; i < 3; i++) {
                const d = new Date(baseDate);
                d.setDate(baseDate.getDate() + i);
                dates.push(d);
            }

            const dayNames = ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'];

            dates.forEach((d, idx) => {
                const yyyy = d.getFullYear();
                const mm = String(d.getMonth() + 1).padStart(2, '0');
                const dd = String(d.getDate()).padStart(2, '0');
                const ymd = `${yyyy}-${mm}-${dd}`;

                const dateStr = `${dd}/${mm}`;
                const dayStr = dayNames[d.getDay()];

                const cardBtn = document.getElementById(`homeQuickDateCard${idx}`);
                if (cardBtn) {
                    document.getElementById(`homeQuickDateStr${idx}`).textContent = dateStr;
                    document.getElementById(`homeQuickDayStr${idx}`).textContent = dayStr;
                    cardBtn.dataset.date = ymd;

                    cardBtn.onclick = function() {
                        dateInput.value = ymd;
                        updateHomeDateCardsHighlight();
                    };
                }
            });

            const hiddenDateInput = document.getElementById('homeHiddenDateInput');
            if (hiddenDateInput) {
                hiddenDateInput.min = minDateStr;
                hiddenDateInput.onchange = function() {
                    if (this.value) {
                        dateInput.value = this.value;
                        updateHomeDateCardsHighlight();
                    }
                };
            }

            updateHomeDateCardsHighlight();
        }

        function updateHomeDateCardsHighlight() {
            const selectedVal = dateInput.value;
            let found = false;

            for (let i = 0; i < 3; i++) {
                const cardBtn = document.getElementById(`homeQuickDateCard${i}`);
                if (cardBtn) {
                    if (cardBtn.dataset.date === selectedVal) {
                        cardBtn.classList.remove('bg-white', 'text-gray-800', 'border-gray-200');
                        cardBtn.classList.add('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'shadow-sm', 'font-bold');
                        found = true;
                    } else {
                        cardBtn.classList.remove('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'shadow-sm', 'font-bold');
                        cardBtn.classList.add('bg-white', 'text-gray-800', 'border-gray-200');
                    }
                }
            }

            const otherCard = document.getElementById('homeOtherDateCard');
            if (otherCard) {
                const labelSpan = otherCard.querySelector('span.font-bold');
                const iconSpan = otherCard.querySelector('span.material-symbols-outlined');
                if (!found && selectedVal) {
                    otherCard.classList.remove('bg-white', 'text-gray-800', 'border-gray-200');
                    otherCard.classList.add('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'shadow-sm', 'font-bold');
                    
                    const parts = selectedVal.split('-');
                    if (parts.length === 3) {
                        labelSpan.textContent = `${parts[2]}/${parts[1]}`;
                    }
                    if (iconSpan) {
                        iconSpan.classList.remove('text-gray-500');
                        iconSpan.classList.add('text-white');
                    }
                } else {
                    otherCard.classList.remove('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'shadow-sm', 'font-bold');
                    otherCard.classList.add('bg-white', 'text-gray-800', 'border-gray-200');
                    labelSpan.textContent = 'Ngày khác';
                    if (iconSpan) {
                        iconSpan.classList.remove('text-white');
                        iconSpan.classList.add('text-gray-500');
                    }
                }
            }
            filterHomeTimeSlots();
        }

        function filterHomeTimeSlots() {
            const selectedVal = dateInput.value;
            const now = new Date();
            const todayStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
            const isToday = selectedVal === todayStr;

            const timeBtnSelected = document.getElementById('homeStartTime').value;

            document.querySelectorAll('.home-time-slot-btn').forEach(btn => {
                const slotTime = btn.dataset.time;
                if (!slotTime) return;

                let isPast = false;
                if (isToday) {
                    const [sh, sm] = slotTime.split(':').map(Number);
                    if (sh < now.getHours() || (sh === now.getHours() && sm <= now.getMinutes())) {
                        isPast = true;
                    }
                }

                if (isPast) {
                    btn.disabled = true;
                    btn.classList.remove('bg-white', 'text-gray-700', 'border-gray-200', 'bg-[#10b981]', 'text-white', 'border-[#10b981]', 'font-bold', 'scale-[1.02]');
                    btn.classList.add('bg-gray-50', 'text-gray-300', 'border-gray-200', 'cursor-not-allowed', 'opacity-60');
                    btn.style.pointerEvents = 'none';

                    if (timeBtnSelected === slotTime) {
                        document.getElementById('homeStartTime').value = "";
                        document.getElementById('homeEndTime').value = "";
                    }
                } else {
                    btn.disabled = false;
                    btn.style.pointerEvents = '';
                    btn.classList.remove('bg-gray-50', 'text-gray-300', 'cursor-not-allowed', 'opacity-60');
                    
                    if (timeBtnSelected === slotTime) {
                        btn.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
                        btn.classList.add('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'font-bold', 'scale-[1.02]');
                    } else {
                        btn.classList.remove('bg-[#10b981]', 'text-white', 'border-[#10b981]', 'font-bold', 'scale-[1.02]');
                        btn.classList.add('bg-white', 'text-gray-700', 'border-gray-200');
                    }
                }
            });
        }
    });
</script>

