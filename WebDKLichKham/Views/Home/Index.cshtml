<div id="diseaseModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 backdrop-blur-sm px-4 py-8" onclick="if(arguments[0].target===this)closeDiseaseModal()">
    <div class="bg-white rounded-3xl w-full max-w-3xl max-h-[90vh] overflow-y-auto shadow-2xl relative">
        <button onclick="closeDiseaseModal()" class="absolute top-5 right-5 w-10 h-10 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors z-10">
            <span class="material-symbols-outlined text-[#475569]">close</span>
        </button>
        <div id="diseaseModalContent" class="p-8"></div>
    </div>
</div>

<script>
    var diseaseData = {
        sxh: {
            color: '#dc2626', bg: '#fef2f2', tag: '🦟 Truyền nhiễm',
            title: 'Sốt xuất huyết Dengue',
            s1title: '1. Triệu chứng & Phán đoán nhanh',
            s1: '<ul class="space-y-2 text-[15px] text-[#475569]"><li><b>Giai đoạn sốt (ngày 1–3):</b> Sốt cao đột ngột 39–40°C, đau đầu dữ dội vùng trán, đau hốc mắt, đau cơ khớp toàn thân.</li><li><b>Giai đoạn nguy hiểm (ngày 4–6):</b> Sốt giảm đột ngột, xuất hiện chấm/mảng xuất huyết dưới da, chảy máu chân răng, nôn ra máu, đau bụng vùng gan.</li><li><b>Dấu hiệu nặng cần cấp cứu ngay:</b> Chảy máu không cầm, tay chân lạnh, mạch nhanh yếu, li bì hoặc vật vã, tiểu ít.</li></ul>',
            s2title: '2. Cách sơ cứu & Xử lý ban đầu',
            s2: '<ul class="space-y-2 text-[15px] text-[#475569] mb-4"><li>✅ Cho người bệnh <b>nghỉ ngơi tuyệt đối</b>, uống nhiều nước (oresol, nước dừa, nước trái cây).</li><li>✅ Hạ sốt bằng <b>Paracetamol</b> (không dùng Ibuprofen, Aspirin — tăng nguy cơ xuất huyết).</li><li>✅ Lau mát bằng khăn ấm vùng trán, nách, bẹn khi sốt cao.</li><li>✅ Theo dõi nhiệt độ và dấu hiệu xuất huyết 4–6 giờ/lần.</li></ul><div class="bg-red-50 border-2 border-red-500 rounded-xl p-4"><p class="text-red-700 font-black text-[15px]">⚠️ LƯU Ý QUAN TRỌNG: Nếu người bệnh có các dấu hiệu cảnh báo nguy hiểm, KHÔNG tự ý điều trị tại nhà mà PHẢI ĐẾN NGAY TRUNG TÂM Y TẾ GẦN NHẤT để được cấp cứu kịp thời.</p></div>',
            s3title: '3. Điều trị & Gợi ý thuốc',
            s3: '<p class="text-[15px] text-[#475569]">Hiện chưa có thuốc kháng virus đặc hiệu. Điều trị chủ yếu là hỗ trợ triệu chứng theo chỉ định bác sĩ: bù dịch truyền tĩnh mạch (Ringer Lactate) khi cần, truyền tiểu cầu khi tiểu cầu < 20.000/µL. <b>Tuyệt đối không tự ý mua thuốc uống khi chưa có chỉ định của bác sĩ.</b></p>',
            s4title: '4. Biện pháp phòng ngừa',
            s4: '<ul class="space-y-2 text-[15px] text-[#475569]"><li>🪣 Dọn dẹp các vật chứa nước đọng (lọ hoa, xô, máng nước) — nơi muỗi Aedes đẻ trứng.</li><li>🦟 Ngủ màn, mặc quần áo dài, dùng kem chống muỗi kể cả ban ngày.</li><li>🏠 Lắp lưới chắn muỗi cửa sổ, cửa ra vào.</li><li>💉 Tiêm vaccine phòng Dengue (Qdenga) cho người từ 6 tuổi trở lên.</li></ul>'
        },
        dd: {
            color: '#d97706', bg: '#fffbeb', tag: '🫁 Tiêu hóa',
            title: 'Viêm loét & Trào ngược dạ dày',
            s1title: '1. Triệu chứng & Phán đoán nhanh',
            s1: '<ul class="space-y-2 text-[15px] text-[#475569]"><li><b>Viêm loét dạ dày:</b> Đau âm ỉ hoặc灼热 (burning) vùng thượng vị, đau tăng khi đói hoặc sau ăn, ợ chua, buồn nôn, nôn.</li><li><b>Trào ngược (GERD):</b> Ợ nóng, cảm giác acid trào lên họng, ho mạn tính về đêm, khàn tiếng sáng sớm.</li><li><b>Dấu hiệu nguy hiểm:</b> Nôn ra máu hoặc chất màu cà phê, phân đen như hắc ín, sụt cân không rõ nguyên nhân, khó nuốt.</li></ul>',
            s2title: '2. Cách sơ cứu & Xử lý ban đầu',
            s2: '<ul class="space-y-2 text-[15px] text-[#475569] mb-4"><li>✅ Ăn nhỏ giọt 5–6 bữa/ngày, tránh để dạ dày rỗng quá lâu.</li><li>✅ Tránh thức ăn cay, chua, đồ uống có gas, cà phê, rượu bia.</li><li>✅ Không nằm ngay sau ăn — chờ ít nhất 2–3 giờ.</li><li>✅ Kê gối cao đầu 15–20cm khi ngủ để giảm trào ngược.</li></ul><div class="bg-red-50 border-2 border-red-500 rounded-xl p-4"><p class="text-red-700 font-black text-[15px]">⚠️ LƯU Ý QUAN TRỌNG: Nếu người bệnh có các dấu hiệu cảnh báo nguy hiểm, KHÔNG tự ý điều trị tại nhà mà PHẢI ĐẾN NGAY TRUNG TÂM Y TẾ GẦN NHẤT để được cấp cứu kịp thời.</p></div>',
            s3title: '3. Điều trị & Gợi ý thuốc',
            s3: '<p class="text-[15px] text-[#475569]">Bác sĩ thường kê: <b>PPI</b> (Omeprazole, Pantoprazole) giảm tiết acid; <b>Antacid</b> (Phosphalugel) trung hòa acid nhanh; <b>Kháng sinh diệt H.Pylori</b> (Amoxicillin + Clarithromycin) nếu xét nghiệm dương tính. <b>Không tự mua kháng sinh uống — nguy cơ kháng thuốc rất cao.</b></p>',
            s4title: '4. Biện pháp phòng ngừa',
            s4: '<ul class="space-y-2 text-[15px] text-[#475569]"><li>🥗 Ăn đúng giờ, đủ bữa, nhai chậm, không bỏ bữa sáng.</li><li>🚭 Bỏ thuốc lá — nicotine làm tăng tiết acid và giảm cơ thắt thực quản dưới.</li><li>💊 Hạn chế thuốc NSAID (Ibuprofen, Aspirin) — gây tổn thương niêm mạc dạ dày.</li><li>😌 Quản lý stress: yoga, thiền định, ngủ đủ giấc.</li></ul>'
        },
        dq: {
            color: '#7c3aed', bg: '#f5f3ff', tag: '🧠 Thần kinh',
            title: 'Đột quỵ (Tai biến mạch máu não)',
            s1title: '1. Triệu chứng & Phán đoán nhanh — Quy tắc BE-FAST',
            s1: '<div class="grid grid-cols-2 gap-3 mb-3"><div class="bg-[#f5f3ff] rounded-xl p-3 text-center"><div class="text-[24px] font-black text-[#7c3aed]">B</div><div class="text-[13px] font-bold">Balance — Mất thăng bằng</div></div><div class="bg-[#f5f3ff] rounded-xl p-3 text-center"><div class="text-[24px] font-black text-[#7c3aed]">E</div><div class="text-[13px] font-bold">Eyes — Mờ mắt đột ngột</div></div><div class="bg-[#f5f3ff] rounded-xl p-3 text-center"><div class="text-[24px] font-black text-[#7c3aed]">F</div><div class="text-[13px] font-bold">Face — Méo miệng, liệt mặt</div></div><div class="bg-[#f5f3ff] rounded-xl p-3 text-center"><div class="text-[24px] font-black text-[#7c3aed]">A</div><div class="text-[13px] font-bold">Arms — Yếu liệt tay chân</div></div><div class="bg-[#f5f3ff] rounded-xl p-3 text-center"><div class="text-[24px] font-black text-[#7c3aed]">S</div><div class="text-[13px] font-bold">Speech — Nói ngọng, khó nói</div></div><div class="bg-red-100 rounded-xl p-3 text-center"><div class="text-[24px] font-black text-red-600">T</div><div class="text-[13px] font-bold text-red-600">Time — Gọi 115 NGAY!</div></div></div>',
            s2title: '2. Cách sơ cứu & Xử lý ban đầu',
            s2: '<ul class="space-y-2 text-[15px] text-[#475569] mb-4"><li>✅ <b>Gọi 115 ngay lập tức</b> — không chờ xem triệu chứng có tự hết không.</li><li>✅ Đặt người bệnh nằm nghiêng an toàn nếu bất tỉnh, đầu và vai hơi cao.</li><li>✅ Nới lỏng quần áo, tháo cà vạt, mở cổ áo để dễ thở.</li><li>❌ Không cho ăn/uống bất cứ thứ gì — nguy cơ sặc vào phổi.</li><li>❌ Không tự lấy kim chích các đầu ngón tay.</li></ul><div class="bg-red-50 border-2 border-red-500 rounded-xl p-4"><p class="text-red-700 font-black text-[15px]">⚠️ LƯU Ý QUAN TRỌNG: Nếu người bệnh có các dấu hiệu cảnh báo nguy hiểm, KHÔNG tự ý điều trị tại nhà mà PHẢI ĐẾN NGAY TRUNG TÂM Y TẾ GẦN NHẤT để được cấp cứu kịp thời.</p></div>',
            s3title: '3. Điều trị & Gợi ý thuốc',
            s3: '<p class="text-[15px] text-[#475569]">Điều trị phụ thuộc loại đột quỵ: <b>Nhồi máu não</b> — tiêu huyết khối tPA trong 4,5 giờ đầu hoặc lấy huyết khối cơ học. <b>Xuất huyết não</b> — kiểm soát huyết áp, phẫu thuật nếu cần. Sau cấp cứu: phục hồi chức năng ngôn ngữ, vận động. <b>Tuyệt đối không tự ý dùng thuốc chống đông hay hạ áp khi chưa có chỉ định bác sĩ.</b></p>',
            s4title: '4. Biện pháp phòng ngừa',
            s4: '<ul class="space-y-2 text-[15px] text-[#475569]"><li>💊 Kiểm soát <b>huyết áp</b> (mục tiêu < 130/80 mmHg), <b>đường máu</b>, <b>mỡ máu</b> định kỳ.</li><li>🚭 Bỏ thuốc lá — tăng nguy cơ đột quỵ gấp 2–4 lần.</li><li>🏃 Vận động 30 phút/ngày, 5 ngày/tuần.</li><li>🥗 Chế độ ăn DASH: nhiều rau, trái cây, hạn chế muối < 5g/ngày.</li><li>🩺 Tầm soát rung nhĩ, hẹp động mạch cảnh mỗi năm nếu có yếu tố nguy cơ.</li></ul>'
        }
    };
    function openDiseaseModal(id) {
        var d = diseaseData[id];
        document.getElementById('diseaseModalContent').innerHTML =
            '<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-[12px] font-bold mb-4" style="background:' + d.bg + ';color:' + d.color + '">' + d.tag + '</div>' +
            '<h2 class="text-[26px] font-extrabold text-[#1e293b] mb-6">' + d.title + '</h2>' +
            '<div class="space-y-6">' +
            '<div><h3 class="text-[16px] font-bold mb-3 pb-2 border-b-2" style="color:' + d.color + ';border-color:' + d.color + '">' + d.s1title + '</h3>' + d.s1 + '</div>' +
            '<div><h3 class="text-[16px] font-bold mb-3 pb-2 border-b-2" style="color:' + d.color + ';border-color:' + d.color + '">' + d.s2title + '</h3>' + d.s2 + '</div>' +
            '<div><h3 class="text-[16px] font-bold mb-3 pb-2 border-b-2" style="color:' + d.color + ';border-color:' + d.color + '">' + d.s3title + '</h3>' + d.s3 + '</div>' +
            '<div><h3 class="text-[16px] font-bold mb-3 pb-2 border-b-2" style="color:' + d.color + ';border-color:' + d.color + '">' + d.s4title + '</h3>' + d.s4 + '</div>' +
            '</div>' +
            '<div class="mt-8 pt-6 border-t border-gray-100 flex gap-3"><a href="/Appointments/Create" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-white font-bold text-[14px] no-underline" style="background:' + d.color + '"><span class="material-symbols-outlined text-[16px]">edit_calendar</span>Đặt lịch khám ngay</a><button onclick="closeDiseaseModal()" class="px-6 py-3 rounded-xl border border-gray-200 text-[#475569] font-bold text-[14px] hover:bg-gray-50">Đóng</button></div>';
        var m = document.getElementById('diseaseModal');
        m.classList.remove('hidden'); m.classList.add('flex');
    }
    function closeDiseaseModal() {
        var m = document.getElementById('diseaseModal');
        m.classList.add('hidden'); m.classList.remove('flex');
    }
</script>

<section class="py-24 bg-white">
    <div class="max-w-[1280px] mx-auto px-4 md:px-8">
        <div class="text-center mb-16">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#2563eb]/10 text-[#2563eb] rounded-full text-[13px] font-bold mb-4">
                <span class="material-symbols-outlined text-[16px]">edit_calendar</span> Đặt Lịch Trực Tuyến
            </span>
            <h2 class="text-[32px] md:text-[38px] font-extrabold text-[#1e293b] mb-4">Quy Trình Đặt Lịch Khám Online</h2>
            <p class="text-[16px] text-[#64748b] max-w-2xl mx-auto">Chỉ vài bước đơn giản — bạn có ngay lịch hẹn khám với bác sĩ mà không cần xếp hàng chờ đợi.</p>
        </div>

        <div class="relative">
            <div class="hidden md:block absolute top-[52px] left-[calc(16.66%-20px)] right-[calc(16.66%-20px)] h-0.5 bg-gradient-to-r from-[#2563eb] via-[#0ea5e9] to-[#2563eb] opacity-20 z-0"></div>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative z-10">

                <div class="flex flex-col items-center text-center group">
                    <div class="w-[72px] h-[72px] rounded-2xl bg-gradient-to-br from-[#2563eb] to-[#0ea5e9] flex items-center justify-center shadow-lg shadow-[#2563eb]/20 mb-5 group-hover:scale-110 transition-transform duration-300">
                        <span class="material-symbols-outlined text-white text-[32px]">app_registration</span>
                    </div>
                    <div class="w-7 h-7 rounded-full bg-[#2563eb] text-white text-[12px] font-black flex items-center justify-center mb-4 -mt-2">1</div>
                    <h3 class="text-[17px] font-bold text-[#1e293b] mb-2">Điền thông tin</h3>
                    <p class="text-[14px] text-[#64748b] leading-relaxed">Nhập họ tên, số điện thoại, chọn chuyên khoa và ngày giờ mong muốn trên form đặt lịch.</p>
                </div>

                <div class="flex flex-col items-center text-center group">
                    <div class="w-[72px] h-[72px] rounded-2xl bg-gradient-to-br from-[#0ea5e9] to-[#059669] flex items-center justify-center shadow-lg shadow-[#0ea5e9]/20 mb-5 group-hover:scale-110 transition-transform duration-300">
                        <span class="material-symbols-outlined text-white text-[32px]">event_available</span>
                    </div>
