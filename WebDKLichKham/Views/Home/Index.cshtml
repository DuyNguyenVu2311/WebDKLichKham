<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .step-icon-active {
        background: linear-gradient(135deg, #2563eb, #00346f);
        color: white;
        border-color: transparent;
        transform: scale(1.15);
        box-shadow: 0 10px 25px -5px rgba(0, 52, 111, 0.4);
    }
    .step-icon-active.step-5 {
        background: linear-gradient(135deg, #10b981, #059669);
        box-shadow: 0 10px 25px -5px rgba(5, 150, 105, 0.4);
    }
    .step-title-active {
        color: #1d4ed8;
    }
    .step-title-active.step-5 {
        color: #059669;
    }
    .step-icon-inactive {
        background: white;
        border-color: #e2e8f0;
        color: #94a3b8;
        opacity: 0.8;
    }
    .step-icon-inactive:hover {
        opacity: 1;
        border-color: #60a5fa;
        color: #3b82f6;
        transform: translateY(-4px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    .step-title-inactive {
        color: #64748b;
    }
</style>

<script>
    function showProcessStep(stepId) {
        // Hide all contents
        document.querySelectorAll('.process-step-content').forEach(el => {
            el.classList.add('hidden');
            el.classList.remove('block');
        });
        
        // Update styles for all icons
        for(let i = 1; i <= 5; i++) {
            const icon = document.getElementById('step-icon-' + i);
            const title = document.getElementById('step-title-' + i);
            
            if(icon && title) {
                // Reset classes
                icon.className = "w-20 h-20 rounded-3xl border flex items-center justify-center mb-5 transition-all duration-400";
                title.className = "text-[18px] font-bold mb-2 transition-colors";
                
                if (i === stepId) {
                    icon.classList.add("step-icon-active");
                    title.classList.add("step-title-active");
                    if (stepId === 5) {
                        icon.classList.add("step-5");
                        title.classList.add("step-5");
                    }
                } else {
                    icon.classList.add("step-icon-inactive");
                    title.classList.add("step-title-inactive");
                }
            }
        }
        
        // Show active content
        const activeContent = document.getElementById('step-content-' + stepId);
        if(activeContent) {
            activeContent.classList.remove('hidden');
            activeContent.classList.add('block');
        }
    }
</script>

