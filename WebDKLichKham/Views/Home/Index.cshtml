            </div>
            <div class="group bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 cursor-pointer" onclick="openDiseaseModal('dd')">
                <div class="aspect-[16/9] overflow-hidden relative">
                    <img src="/images/gastric_ulcer.png" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Viêm loét dạ dày" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                    <span class="absolute top-4 left-4 px-3 py-1 bg-[#d97706] text-white text-[11px] font-bold rounded-full">🫁 Tiêu hóa</span>
