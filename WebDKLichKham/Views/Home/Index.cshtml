    var patient = d.patient.map(function(p){ return '<li class="flex items-start gap-2 text-[14px] text-[#475569]"><span class="text-[#059669] mt-0.5">✅</span>'+p+'</li>'; }).join('');
    document.getElementById('equipModalContent').innerHTML =
        '<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-[12px] font-bold mb-4" style="background:'+d.bg+';color:'+d.color+'"><span class="material-symbols-outlined text-[14px]">'+d.icon+'</span>'+d.brand+'</div>'+
        '<h2 class="text-[24px] font-extrabold text-[#1e293b] mb-1">'+d.name+'</h2>'+
        '<p class="text-[13px] text-[#059669] font-bold mb-4">🏅 Chứng nhận: '+d.certs+'</p>'+
        '<p class="text-[15px] text-[#475569] leading-relaxed mb-6">'+d.desc+'</p>'+
        '<div class="space-y-5">'+
        '<div><h3 class="text-[14px] font-black uppercase tracking-wider mb-3" style="color:'+d.color+'">📊 Thông số kỹ thuật</h3><div class="bg-gray-50 rounded-2xl px-5 py-1">'+specs+'</div></div>'+
        '<div><h3 class="text-[14px] font-black uppercase tracking-wider mb-3" style="color:'+d.color+'">🏥 Chuyên khoa áp dụng</h3><p class="text-[14px] text-[#475569] bg-gray-50 rounded-2xl px-5 py-3">'+d.uses+'</p></div>'+
        '<div><h3 class="text-[14px] font-black uppercase tracking-wider mb-3" style="color:'+d.color+'">💚 Lợi ích cho bệnh nhân</h3><ul class="space-y-2">'+patient+'</ul></div>'+
        '</div>'+
        '<div class="mt-8 pt-6 border-t border-gray-100 flex flex-col sm:flex-row gap-3">'+
        '<a href="'+d.link+'" class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl text-white font-bold text-[14px] no-underline transition-all" style="background:'+d.color+'"><span class="material-symbols-outlined text-[16px]">edit_calendar</span>Đặt lịch dịch vụ này</a>'+
        '<button onclick="closeEquipModal()" class="px-6 py-3.5 rounded-xl border-2 border-gray-200 text-[#475569] font-bold text-[14px] hover:bg-gray-50 transition-colors">Đóng</button></div>';
    var m = document.getElementById('equipModal');
    m.classList.remove('hidden'); m.classList.add('flex');
}
function closeEquipModal() {
    var m = document.getElementById('equipModal');
    m.classList.add('hidden'); m.classList.remove('flex');
}
</script>

