                    <h3 id="step-title-@s.Id" class="text-[18px] font-bold mb-2 transition-colors @titleClass">@s.Id. @s.Title</h3>
                    <p class="text-[14px] text-slate-500 px-2 line-clamp-3 leading-relaxed">@s.Desc</p>
