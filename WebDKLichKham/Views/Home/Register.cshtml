@model WebDKLichKham.Models.ViewModels.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký hồ sơ y tế - Phòng Khám Đa Khoa Duy Tâm</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</head>
<body class="min-h-screen bg-white text-slate-800 flex flex-col md:flex-row">

    <!-- Left Panel -->
    <div class="hidden md:flex md:w-[400px] lg:w-[450px] bg-gradient-to-b from-[#f4f7fc] to-[#eaf1ff] border-r border-slate-200 flex-col p-8 lg:p-12 relative overflow-hidden shrink-0">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/5 rounded-full blur-3xl"></div>
        
        <div class="mb-10 relative z-10">
            <a href="/" class="inline-flex items-center gap-3 no-underline shrink-0 mb-6">
                <div class="w-10 h-10 bg-gradient-to-br from-[#1e40af] to-[#2563eb] rounded-xl flex items-center justify-center shadow-md">
                    <span class="material-symbols-outlined text-white text-[22px]">local_hospital</span>
                </div>
                <div>
                    <div class="text-[17px] font-bold text-[#1e293b] leading-tight">Duy Tâm</div>
                    <div class="text-[12px] text-[#64748b] font-medium leading-none">Phòng Khám Đa Khoa</div>
                </div>
            </a>
            <h1 class="text-[24px] font-bold text-[#00346f] mb-2">Đăng Ký Tài Khoản</h1>
            <p class="text-[14px] text-slate-500 leading-relaxed">Tạo hồ sơ sức khỏe điện tử để dễ dàng đặt lịch khám trực tuyến và quản lý kết quả bệnh án của bạn.</p>
        </div>

        <div class="space-y-6 flex-1 relative z-10">
            <div class="bg-white/80 backdrop-blur border border-white rounded-xl p-5 shadow-sm">
                <div class="flex items-center gap-3 mb-2">
                    <span class="material-symbols-outlined text-blue-600">health_and_safety</span>
                    <h4 class="font-bold text-[#1e293b] text-[15px]">Lịch hẹn trực tuyến</h4>
                </div>
                <p class="text-[13px] text-slate-500 leading-relaxed m-0">Đặt lịch hẹn nhanh chóng với các bác sĩ chuyên khoa mà không cần phải chờ đợi xếp hàng.</p>
            </div>
            
            <div class="bg-white/80 backdrop-blur border border-white rounded-xl p-5 shadow-sm">
                <div class="flex items-center gap-3 mb-2">
                    <span class="material-symbols-outlined text-teal-600">history_edu</span>
                    <h4 class="font-bold text-[#1e293b] text-[15px]">Hồ sơ điện tử</h4>
                </div>
                <p class="text-[13px] text-slate-500 leading-relaxed m-0">Xem và lưu trữ hồ sơ bệnh án điện tử, đơn thuốc và kết quả cận lâm sàng của bạn một cách bảo mật.</p>
            </div>

            <div class="bg-white/80 backdrop-blur border border-white rounded-xl p-5 shadow-sm">
                <div class="flex items-center gap-3 mb-2">
                    <span class="material-symbols-outlined text-orange-600">notifications_active</span>
                    <h4 class="font-bold text-[#1e293b] text-[15px]">Thông báo thời gian thực</h4>
                </div>
                <p class="text-[13px] text-slate-500 leading-relaxed m-0">Nhận thông báo nhắc lịch khám, đơn thuốc mới và cập nhật kết quả xét nghiệm tức thì.</p>
            </div>
        </div>

        <div class="mt-8 pt-6 border-t border-slate-200/50">
            <p class="text-[12px] text-slate-400">Hệ thống Duy Tâm eHospital v3.0</p>
        </div>
    </div>

    <!-- Right Panel: Registration Form -->
    <div class="flex-1 flex items-center justify-center p-6 sm:p-12 relative overflow-y-auto max-h-screen">
        <!-- Back to Home -->
        <a href="/" class="absolute top-6 right-6 lg:top-8 lg:right-8 flex items-center gap-2 text-[14px] font-semibold text-slate-500 hover:text-[#00346f] transition-colors">
            <span class="material-symbols-outlined text-[18px]">home</span> Về trang chủ
        </a>

        <div class="w-full max-w-[650px] py-8">
            <div class="md:hidden text-center mb-8">
                <h1 class="text-[24px] font-bold text-[#00346f] mb-1">Duy Tâm eHospital</h1>
                <p class="text-[14px] text-slate-500">Đăng ký hồ sơ y tế trực tuyến</p>
            </div>

            <div class="mb-8 text-center md:text-left">
                <h2 class="text-[32px] font-bold text-[#0f172a] mb-2">Tạo tài khoản mới</h2>
                <p class="text-[15px] text-slate-500">Vui lòng điền đầy đủ các thông tin cá nhân dưới đây.</p>
            </div>

            <form action="/Home/SubmitRegister" method="post" class="space-y-6">
                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="bg-red-50 text-red-600 p-4 rounded-xl text-[14px] font-medium border border-red-100 flex flex-col gap-1.5">
                    <div class="flex items-center gap-2 font-bold"><span class="material-symbols-outlined">error</span> Có lỗi xảy ra:</div>
                </div>

                <div class="bg-blue-50/30 border border-blue-100 rounded-2xl p-6 space-y-6">
                    <h3 class="text-[16px] font-bold text-[#00346f] flex items-center gap-2 pb-3 border-b border-blue-100">
                        <span class="material-symbols-outlined text-[20px]">person</span> THÔNG TIN CƠ BẢN (BẮT BUỘC)
                    </h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <!-- Full Name -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Họ và tên bệnh nhân *</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">person_outline</span>
                                <input type="text" name="FullName" value="@Model.FullName" required class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all placeholder:text-slate-400 bg-white" placeholder="VD: Nguyễn Văn A" />
                            </div>
                            <span asp-validation-for="FullName" class="text-red-500 text-[12px] mt-1 block"></span>
                        </div>

                        <!-- Phone Number -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Số điện thoại *</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">smartphone</span>
                                <input type="tel" name="PhoneNumber" value="@Model.PhoneNumber" required class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all placeholder:text-slate-400 bg-white" placeholder="Số điện thoại đăng nhập" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-red-500 text-[12px] mt-1 block"></span>
                        </div>

                        <!-- Date of Birth -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Ngày sinh *</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">calendar_today</span>
                                <input type="date" name="DateOfBirth" value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" required class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all bg-white" />
                            </div>
                            <span asp-validation-for="DateOfBirth" class="text-red-500 text-[12px] mt-1 block"></span>
                        </div>

                        <!-- Gender -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Giới tính *</label>
                            <div class="grid grid-cols-2 gap-3">
                                <label class="flex items-center justify-center gap-2 p-3 rounded-xl border border-slate-300 cursor-pointer hover:bg-slate-50 transition-all bg-white">
                                    <input type="radio" name="Gender" value="Nam" @(Model.Gender == "Nam" ? "checked" : "") class="w-4 h-4 text-[#00346f] focus:ring-[#00346f]" />
                                    <span class="text-[14px] font-semibold text-slate-700">Nam</span>
                                </label>
                                <label class="flex items-center justify-center gap-2 p-3 rounded-xl border border-slate-300 cursor-pointer hover:bg-slate-50 transition-all bg-white">
                                    <input type="radio" name="Gender" value="Nữ" @(Model.Gender == "Nữ" ? "checked" : "") class="w-4 h-4 text-[#00346f] focus:ring-[#00346f]" />
                                    <span class="text-[14px] font-semibold text-slate-700">Nữ</span>
                                </label>
                            </div>
                            <span asp-validation-for="Gender" class="text-red-500 text-[12px] mt-1 block"></span>
                        </div>

                        <!-- Password -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Mật khẩu mới *</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">lock</span>
                                <input type="password" name="Password" required class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all placeholder:text-slate-400 bg-white" placeholder="Tối thiểu 6 ký tự" />
                            </div>
                            <span asp-validation-for="Password" class="text-red-500 text-[12px] mt-1 block"></span>
                        </div>

                        <!-- Confirm Password -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Xác nhận mật khẩu *</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">lock</span>
                                <input type="password" name="ConfirmPassword" required class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all placeholder:text-slate-400 bg-white" placeholder="Nhập lại mật khẩu" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-red-500 text-[12px] mt-1 block"></span>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 space-y-6">
                    <h3 class="text-[16px] font-bold text-slate-700 flex items-center gap-2 pb-3 border-b border-slate-200">
                        <span class="material-symbols-outlined text-[20px]">badge</span> HỒ SƠ Y TẾ & ĐỊA CHỈ (TÙY CHỌN)
                    </h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <!-- Identity Card -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Số CCCD / CMND</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">badge</span>
                                <input type="text" name="IdentityCard" value="@Model.IdentityCard" class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all placeholder:text-slate-400 bg-white" placeholder="12 số căn cước công dân" />
                            </div>
                        </div>

                        <!-- Insurance Code -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Mã số thẻ BHYT</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">medical_services</span>
                                <input type="text" name="InsuranceCode" value="@Model.InsuranceCode" class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all placeholder:text-slate-400 bg-white" placeholder="VD: GD479791150001" />
                            </div>
                        </div>

                        <!-- Occupation -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Nghề nghiệp</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">work</span>
                                <input type="text" name="Occupation" value="@Model.Occupation" class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all placeholder:text-slate-400 bg-white" placeholder="Tự nhập nghề nghiệp..." />
                            </div>
                        </div>

                        <!-- Street Address -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Số nhà, tên đường</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">home_pin</span>
                                <input type="text" name="StreetAddress" value="@Model.StreetAddress" class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all placeholder:text-slate-400 bg-white" placeholder="Địa chỉ nơi cư trú" />
                            </div>
                        </div>

                        <!-- Province -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Tỉnh / Thành phố</label>
                            <input type="text" name="Province" value="@Model.Province" class="w-full px-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all bg-white" placeholder="VD: TP. Hồ Chí Minh" />
                        </div>

                        <!-- District -->
                        <div>
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Quận / Huyện</label>
                            <input type="text" name="District" value="@Model.District" class="w-full px-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all bg-white" placeholder="VD: TP. Thủ Đức" />
                        </div>

                        <!-- Ward -->
                        <div class="md:col-span-2">
                            <label class="block text-[12px] font-bold text-slate-600 uppercase tracking-wider mb-2">Phường / Xã</label>
                            <input type="text" name="Ward" value="@Model.Ward" class="w-full px-4 py-3 rounded-xl border border-slate-300 text-[15px] focus:border-[#00346f] focus:ring-1 focus:ring-[#00346f] outline-none transition-all bg-white" placeholder="VD: Phường Phước Long A" />
                        </div>
                    </div>
                </div>

                <div class="flex flex-col gap-4">
                    <button type="submit" class="w-full bg-[#00346f] text-white py-4 rounded-xl font-bold text-[15px] hover:bg-[#002244] shadow-md hover:shadow-lg transition-all flex items-center justify-center gap-2">
                        <span>ĐĂNG KÝ HỒ SƠ Y TẾ</span> <span class="material-symbols-outlined text-[20px]">how_to_reg</span>
                    </button>
                    
                    <div class="text-center">
                        <p class="text-[14px] text-slate-600">Bạn đã có hồ sơ y tế? <a href="/Home/Login" class="font-bold text-[#00346f] hover:underline">Đăng nhập ngay</a></p>
                    </div>
                </div>
            </form>
        </div>
    </div>

</body>
</html>
