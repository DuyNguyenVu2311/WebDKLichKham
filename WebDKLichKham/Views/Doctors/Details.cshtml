@model WebDKLichKham.Models.Doctor
@{
    ViewData["Title"] = "Chi tiết bác sĩ";
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <span class="badge text-bg-primary-subtle text-primary-emphasis mb-3">@Model.Specialty</span>
                <h1 class="h3">@Model.FullName</h1>
                <p class="text-secondary">@Model.Qualification</p>
                <p>@Model.Biography</p>
                <dl class="row small mb-0">
                    <dt class="col-sm-4">Kinh nghiệm</dt>
                    <dd class="col-sm-8">@Model.ExperienceYears năm</dd>
                    <dt class="col-sm-4">Liên hệ</dt>
                    <dd class="col-sm-8">@Model.PhoneNumber</dd>
                    <dt class="col-sm-4">Phí khám</dt>
                    <dd class="col-sm-8">@Model.Fee.ToString("N0") VND</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h4 mb-0">Lịch làm việc dự kiến</h2>
                    <a class="btn btn-primary btn-sm" asp-controller="Appointments" asp-action="Create">Đặt lịch với bác sĩ này</a>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Ngày</th>
                                <th>Ca</th>
                                <th>Khung giờ</th>
                                <th>Tối đa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var schedule in Model.Schedules.OrderBy(s => s.WorkDate))
                            {
                                <tr>
                                    <td>@schedule.WorkDate.ToString("dd/MM/yyyy")</td>
                                    <td>@schedule.Shift.GetDisplayName()</td>
                                    <td>@schedule.StartTime.ToString(@"hh\:mm") - @schedule.EndTime.ToString(@"hh\:mm")</td>
                                    <td>@schedule.MaxAppointments</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
