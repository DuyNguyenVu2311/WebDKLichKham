<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Phòng Khám Đa Khoa Duy Tâm</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Public+Sans:wght@600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-background":"#0b1c30","inverse-surface":"#213145","surface-container":"#e5eeff",
                        "tertiary":"#2d3640","secondary":"#006a63","primary-container":"#004a99",
                        "on-primary-container":"#9bbdff","on-tertiary-fixed":"#131d26","surface-bright":"#f8f9ff",
                        "surface-container-lowest":"#ffffff","on-tertiary":"#ffffff","surface-tint":"#255dad",
                        "secondary-container":"#90f4e8","background":"#f8f9ff","on-error":"#ffffff",
                        "primary-fixed-dim":"#abc7ff","surface-container-low":"#eff4ff",
                        "on-secondary-fixed-variant":"#00504a","secondary-fixed-dim":"#73d7cc",
                        "on-primary":"#ffffff","on-surface-variant":"#424751","inverse-primary":"#abc7ff",
                        "on-secondary":"#ffffff","surface-container-high":"#dce9ff",
                        "inverse-on-surface":"#eaf1ff","on-error-container":"#93000a",
                        "secondary-fixed":"#90f4e8","on-tertiary-container":"#b3beca",
                        "on-secondary-fixed":"#00201d","surface-variant":"#d3e4fe","outline":"#737783",
                        "surface":"#f8f9ff","primary-fixed":"#d7e2ff","on-primary-fixed-variant":"#00458f",
                        "tertiary-container":"#434d57","primary":"#00346f",
                        "on-secondary-container":"#007169","surface-container-highest":"#d3e4fe",
                        "tertiary-fixed-dim":"#bdc7d4","error-container":"#ffdad6","on-surface":"#0b1c30",
                        "surface-dim":"#cbdbf5","error":"#ba1a1a",
                        "outline-variant":"#c2c6d3","on-primary-fixed":"#001b3f","tertiary-fixed":"#d9e3f0"
                    },
                    spacing:{"container-max":"1280px","base":"8px","margin-mobile":"16px","margin-desktop":"40px","gutter":"24px"},
                    fontFamily:{"label-md":["Inter"],"body-lg":["Inter"],"headline-md":["Public Sans"],"headline-lg":["Public Sans"],"headline-xl":["Public Sans"],"body-sm":["Inter"],"body-md":["Inter"],"label-sm":["Inter"]},
                    fontSize:{
                        "label-md":["14px",{"lineHeight":"16px","letterSpacing":"0.05em","fontWeight":"600"}],
                        "body-lg":["18px",{"lineHeight":"28px","fontWeight":"400"}],
                        "headline-md":["24px",{"lineHeight":"32px","fontWeight":"600"}],
                        "headline-lg":["32px",{"lineHeight":"40px","fontWeight":"600"}],
                        "headline-xl":["48px",{"lineHeight":"56px","letterSpacing":"-0.02em","fontWeight":"700"}],
                        "body-sm":["14px",{"lineHeight":"20px","fontWeight":"400"}],
                        "body-md":["16px",{"lineHeight":"24px","fontWeight":"400"}],
                        "label-sm":["12px",{"lineHeight":"16px","fontWeight":"500"}]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings:'FILL' 0,'wght' 400,'GRAD' 0,'opsz' 24; display:inline-block; line-height:1; }
        .glass-card { background:rgba(255,255,255,0.75); backdrop-filter:blur(16px); border:1px solid rgba(255,255,255,0.4); }
        .step-path { position:absolute; top:2rem; left:50%; width:100%; border-top:2px dashed #c2c6d3; z-index:0; }
    </style>
</head>
<body class="bg-background text-on-surface font-body-md">

<header class="sticky top-0 w-full bg-white/90 backdrop-blur-md border-b border-gray-100 z-50 shadow-sm">
    <div class="max-w-[1280px] mx-auto px-4 md:px-8 h-20 flex justify-between items-center gap-6">

        <!-- LOGO -->
        <a asp-area="" asp-controller="Home" asp-action="Index" class="flex items-center gap-3 no-underline shrink-0">
            <div class="w-10 h-10 bg-gradient-to-br from-[#1e40af] to-[#2563eb] rounded-xl flex items-center justify-center shadow-md">
                <span class="material-symbols-outlined text-white text-[22px]">local_hospital</span>
            </div>
            <div class="hidden sm:block">
                <div class="text-[17px] font-bold text-[#1e293b] leading-tight">Duy Tâm</div>
                <div class="text-[12px] text-[#64748b] font-medium leading-none">Phòng Khám Đa Khoa</div>
            </div>
        </a>

        <!-- DESKTOP NAV -->
        <nav class="hidden xl:flex items-center gap-1.5">
            @{
                var cController = ViewContext.RouteData.Values["controller"]?.ToString();
                var cAction = ViewContext.RouteData.Values["action"]?.ToString();
                string IsActive(string ctrl, string act) => (cController == ctrl && cAction == act)
                    ? "bg-[#eff6ff] text-[#2563eb] font-bold"
                    : "text-[#475569] hover:bg-gray-100 hover:text-[#1e293b]";
            }
            <a class="@IsActive("Home", "Index") transition-all text-[15px] font-semibold no-underline px-4 py-2.5 rounded-lg whitespace-nowrap" asp-controller="Home" asp-action="Index">Trang Chủ</a>
            <a class="@IsActive("Doctors", "Index") transition-all text-[15px] font-semibold no-underline px-4 py-2.5 rounded-lg whitespace-nowrap" asp-controller="Doctors" asp-action="Index">Bác Sĩ</a>
            <a class="@IsActive("Home", "MedicalKnowledge") transition-all text-[15px] font-semibold no-underline px-4 py-2.5 rounded-lg whitespace-nowrap" asp-controller="Home" asp-action="MedicalKnowledge">Thông Tin Y Khoa</a>
            <a class="@IsActive("Home", "Services") transition-all text-[15px] font-semibold no-underline px-4 py-2.5 rounded-lg whitespace-nowrap" asp-controller="Home" asp-action="Services">Dịch Vụ</a>
            <a class="@IsActive("Home", "Contact") transition-all text-[15px] font-semibold no-underline px-4 py-2.5 rounded-lg whitespace-nowrap" asp-controller="Home" asp-action="Contact">Liên Hệ</a>
        </nav>

        <!-- RIGHT ACTIONS -->
        <div class="flex items-center gap-3 shrink-0">
            <!-- Login partial -->
            <div class="hidden xl:block">
                <partial name="_LoginPartial" />
            </div>

            <!-- My Schedule -->
            <a class="hidden xl:inline-flex items-center gap-1.5 text-[15px] font-semibold text-[#475569] hover:text-[#2563eb] transition-colors no-underline px-3.5 py-2.5 rounded-lg hover:bg-[#eff6ff]"
               asp-controller="Appointments" asp-action="Lookup">
                <span class="material-symbols-outlined text-[19px]">calendar_month</span>
                <span class="hidden lg:inline">Lịch của tôi</span>
            </a>

            <!-- Book Appointment CTA -->
            <a class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-gradient-to-r from-[#1e40af] to-[#2563eb] text-white rounded-xl text-[15px] font-bold shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all no-underline"
               asp-controller="Appointments" asp-action="Create">
                <span class="material-symbols-outlined text-[18px]">edit_calendar</span>
                <span class="hidden sm:inline">Đặt Lịch Khám</span>
                <span class="sm:hidden">Đặt Lịch</span>
            </a>

            <!-- Mobile hamburger -->
            <button id="mobileMenuBtn" class="xl:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors flex items-center justify-center" onclick="document.getElementById('mobileNav').classList.toggle('hidden')">
                <span class="material-symbols-outlined text-[#475569] text-[24px]">menu</span>
            </button>
        </div>
    </div>

    <!-- MOBILE NAV -->
    <div id="mobileNav" class="hidden xl:hidden bg-white border-t border-gray-100 shadow-lg">
        <div class="max-w-[1280px] mx-auto px-4 py-3 flex flex-col gap-1">
            <a class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#eff6ff] hover:text-[#2563eb] text-[#1e293b] text-[14px] font-semibold no-underline transition-all" asp-controller="Home" asp-action="Index">
                <span class="material-symbols-outlined text-[20px]">home</span> Trang Chủ
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#eff6ff] hover:text-[#2563eb] text-[#1e293b] text-[14px] font-semibold no-underline transition-all" asp-controller="Doctors" asp-action="Index">
                <span class="material-symbols-outlined text-[20px]">stethoscope</span> Bác Sĩ
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#eff6ff] hover:text-[#2563eb] text-[#1e293b] text-[14px] font-semibold no-underline transition-all" asp-controller="Home" asp-action="MedicalKnowledge">
                <span class="material-symbols-outlined text-[20px]">article</span> Thông Tin Y Khoa
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#eff6ff] hover:text-[#2563eb] text-[#1e293b] text-[14px] font-semibold no-underline transition-all" asp-controller="Home" asp-action="Services">
                <span class="material-symbols-outlined text-[20px]">medical_services</span> Dịch Vụ
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#eff6ff] hover:text-[#2563eb] text-[#1e293b] text-[14px] font-semibold no-underline transition-all" asp-controller="Home" asp-action="Contact" onclick="document.getElementById('mobileNav').classList.add('hidden')">
                <span class="material-symbols-outlined text-[20px]">call</span> Liên Hệ
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#eff6ff] hover:text-[#2563eb] text-[#1e293b] text-[14px] font-semibold no-underline transition-all" asp-controller="Appointments" asp-action="Lookup">
                <span class="material-symbols-outlined text-[20px]">calendar_month</span> Lịch Của Tôi
            </a>
            @if (User.Identity?.IsAuthenticated == true || Context.Request.Cookies["PortalRole"] != null)
            {
                <a class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-red-50 hover:text-red-600 text-[#1e293b] text-[14px] font-semibold no-underline transition-all" href="/Home/LogoutPortal">
                    <span class="material-symbols-outlined text-[20px]">logout</span> Đăng xuất
                </a>
            }
            else
            {
                <a class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#eff6ff] hover:text-[#2563eb] text-[#1e293b] text-[14px] font-semibold no-underline transition-all" asp-area="" asp-controller="Home" asp-action="Login">
                    <span class="material-symbols-outlined text-[20px]">person</span> Đăng nhập hệ thống
                </a>
            }
            <div class="mt-2 pt-2 border-t border-gray-100">
                <a class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-gradient-to-r from-[#1e40af] to-[#2563eb] text-white rounded-xl text-[14px] font-bold no-underline" asp-controller="Appointments" asp-action="Create">
                    <span class="material-symbols-outlined text-[18px]">edit_calendar</span> Đặt Lịch Khám Ngay
                </a>
            </div>
        </div>
    </div>
</header>

<main>
    @{
        var requestPath = Context.Request.Path.Value ?? string.Empty;
        var returnUrl = Context.Request.Query["ReturnUrl"].ToString();
        var isBookingLogin = (requestPath.Contains("/Account/Login", StringComparison.OrdinalIgnoreCase) || 
                              requestPath.Contains("/Account/Register", StringComparison.OrdinalIgnoreCase)) && 
                             (!string.IsNullOrEmpty(returnUrl) && returnUrl.Contains("/Appointments/Create", StringComparison.OrdinalIgnoreCase));
    }
    @if (isBookingLogin)
    {
        <div class="max-w-[1280px] mx-auto px-4 md:px-8 pt-8">
            <partial name="_BookingSteps" model="3" />
        </div>
    }
    @if (TempData["SuccessMessage"] is string msg)
    {
        <div class="max-w-container-max mx-auto px-margin-desktop pt-4">
            <div class="p-4 bg-secondary-container text-on-secondary-container rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined">check_circle</span> @msg
            </div>
        </div>
    }
    @RenderBody()
</main>

<section class="py-20 bg-primary-container text-on-primary-container text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-primary/10 to-transparent opacity-50"></div>
    <div class="max-w-container-max mx-auto px-margin-desktop relative z-10">
        <h2 class="text-headline-xl font-headline-xl mb-6">Trải nghiệm dịch vụ y tế đẳng cấp quốc tế</h2>
        <p class="text-body-lg font-body-lg mb-12 max-w-2xl mx-auto text-on-primary-container/80">Chủ động bảo vệ sức khỏe của bạn và gia đình bằng cách đặt lịch thăm khám định kỳ cùng các chuyên gia hàng đầu.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-white text-primary rounded-full font-headline-md text-headline-md shadow-2xl hover:scale-105 active:scale-95 transition-all no-underline" asp-controller="Appointments" asp-action="Create">
                <span class="material-symbols-outlined">calendar_month</span> Đặt Lịch Hẹn Ngay
            </a>
            <a class="inline-flex items-center justify-center gap-3 px-10 py-5 border-2 border-white/50 text-white rounded-full font-headline-md text-headline-md hover:bg-white/10 transition-all no-underline" href="https://zalo.me/0775571311" target="_blank">
                <span class="material-symbols-outlined">chat</span> Zalo: 0775 571 311
            </a>
        </div>
    </div>
</section>

<footer id="footer" class="w-full py-12 px-4 md:px-8 bg-[#1a2639] text-[#b3beca] font-sans border-t border-[#2a374a]">
    <div class="max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="space-y-4 pr-4">
            <div class="text-[18px] font-bold text-white flex items-center gap-2">
                Phòng Khám Đa Khoa Duy Tâm
            </div>
            <p class="text-[13px] leading-relaxed">Phòng Khám Đa Khoa Duy Tâm — nơi hội tụ đội ngũ bác sĩ chuyên gia và công nghệ y khoa tiên tiến, tận tâm chăm sóc sức khỏe toàn diện cho bạn và gia đình.</p>
            <div class="flex gap-3 pt-2">
                <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-blue-600 transition-colors cursor-pointer no-underline text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-facebook" viewBox="0 0 16 16"><path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"/></svg>
                </a>
                <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-red-600 transition-colors cursor-pointer no-underline text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-youtube" viewBox="0 0 16 16"><path d="M8.051 1.999h.089c.822.003 4.987.033 6.11.335a2.01 2.01 0 0 1 1.415 1.42c.101.38.172 1.284.22 2.456.028.694.04 1.41.04 2.164 0 .754-.012 1.47-.04 2.164-.048 1.172-.119 2.076-.22 2.456a2.01 2.01 0 0 1-1.415 1.42c-1.123.302-5.288.332-6.11.335h-.089c-.822-.003-4.987-.033-6.11-.335a2.01 2.01 0 0 1-1.415-1.42c-.101-.38-.172-1.284-.22-2.456-.028-.694-.04-1.41-.04-2.164 0-.754.012-1.47.04-2.164.048-1.172.119-2.076.22-2.456a2.01 2.01 0 0 1 1.415-1.42c1.123-.302 5.288-.332 6.11-.335m-3.266 9.47 5.75-3.21-5.75-3.21v6.42z"/></svg>
                </a>
            </div>
        </div>
        <div class="space-y-4">
            <h4 class="font-bold text-[13px] text-white uppercase tracking-wider">LIÊN KẾT NHANH</h4>
            <nav class="flex flex-col gap-3">
                <a class="text-[13px] hover:text-white transition-colors no-underline text-[#b3beca]" asp-controller="Home" asp-action="AboutUs">Về chúng tôi</a>
                <a class="text-[13px] hover:text-white transition-colors no-underline text-[#b3beca]" asp-controller="Home" asp-action="PrivacyPolicy">Chính sách bảo mật</a>
                <a class="text-[13px] hover:text-white transition-colors no-underline text-[#b3beca]" asp-controller="Home" asp-action="TermsOfService">Điều khoản sử dụng</a>
                <a class="text-[13px] hover:text-white transition-colors no-underline text-[#b3beca]" asp-controller="Home" asp-action="Faqs">Câu hỏi thường gặp</a>
            </nav>
        </div>
        <div class="space-y-4">
            <h4 class="font-bold text-[13px] text-white uppercase tracking-wider">HỆ THỐNG CHI NHÁNH</h4>
            <div class="space-y-3">
                <div>
                    <p class="text-[13px] text-white font-bold mb-1">Cơ sở 1: TP. Thủ Đức</p>
                    <a href="https://maps.app.goo.gl/4m9eDZ2x4PDi9RJe8" target="_blank" class="text-[13px] text-[#b3beca] hover:text-white transition-colors no-underline block leading-relaxed">
                        129 Tây Hòa, P. Phước Long A,<br/>TP. Thủ Đức, TP. HCM
                    </a>
                </div>
                <div>
                    <p class="text-[13px] text-white font-bold mb-1">Cơ sở 2: Nhơn Trạch</p>
                    <a href="https://maps.app.goo.gl/3X14NP2pmQsnBSj5A" target="_blank" class="text-[13px] text-[#b3beca] hover:text-white transition-colors no-underline block leading-relaxed">
                        Đường Trần Thị Nhật, X. Phú Hội,<br/>H. Nhơn Trạch, T. Đồng Nai
                    </a>
                </div>
            </div>
        </div>
        <div class="space-y-4">
            <h4 class="font-bold text-[13px] text-white uppercase tracking-wider">ĐĂNG KÝ NHẬN TIN</h4>
            <p class="text-[13px]">Nhận thông tin ưu đãi và kiến thức y khoa mới nhất.</p>
            <div class="flex gap-2">
                <input id="newsletterEmail" type="email" placeholder="Email của bạn" class="w-full bg-[#2a374a] border border-[#3b4b61] text-white text-[13px] px-3 py-2 rounded outline-none focus:border-blue-500" />
                <button id="newsletterBtn" class="bg-[#00346f] text-white px-3 py-2 rounded hover:bg-[#002244] transition-colors flex items-center justify-center">
                    <span class="material-symbols-outlined text-[18px]">send</span>
                </button>
            </div>
            <p id="newsletterMsg" class="text-[12px] hidden mt-1"></p>
        </div>
    </div>
    <div class="max-w-[1280px] mx-auto mt-12 pt-6 border-t border-white/10 text-center text-[12px]">
        <p>© 2026 Phòng Khám Đa Khoa Duy Tâm. Mọi quyền được bảo lưu. | Đồ án Nguyễn Vũ Duy — MSSV 2380600369</p>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    $(document).ready(function() {
        $('#newsletterBtn').click(function(e) {
            e.preventDefault();
            submitNewsletter();
        });

        $('#newsletterEmail').keypress(function(e) {
            if (e.which === 13) {
                e.preventDefault();
                submitNewsletter();
            }
        });

        function submitNewsletter() {
            var email = $('#newsletterEmail').val();
            var $msg = $('#newsletterMsg');

            if (!email) {
                $msg.text('Vui lòng nhập địa chỉ email.').removeClass('hidden text-green-400 text-gray-500').addClass('text-red-400');
                return;
            }

            $msg.text('Đang đăng ký...').removeClass('hidden text-red-400 text-green-400').addClass('text-gray-500');

            $.post('/Home/SubscribeNewsletter', { email: email }, function(response) {
                if (response.success) {
                    $msg.text(response.message).removeClass('hidden text-red-400 text-gray-500').addClass('text-green-400');
                    $('#newsletterEmail').val('');
                } else {
                    $msg.text(response.message).removeClass('hidden text-green-400 text-gray-500').addClass('text-red-400');
                }
            }).fail(function() {
                $msg.text('Đã xảy ra lỗi kết nối. Vui lòng thử lại sau.').removeClass('hidden text-green-400 text-gray-500').addClass('text-red-400');
            });
        }
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

