@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@if (Context.Request.Cookies["PortalRole"] != null)
{
    var role = Context.Request.Cookies["PortalRole"];
    var userName = Context.Request.Cookies["PortalUser"];
    var dashboardUrl = role == "Customer" ? "/Portal/PatientDashboard" : role == "Doctor" ? "/Portal/DoctorDashboard" : "/Portal/AdminDashboard";

    <div class="hidden sm:flex items-center gap-2">
        <a class="inline-flex items-center gap-2 text-[15px] font-bold text-[#00346f] hover:text-[#002244] bg-blue-50 hover:bg-blue-100 border border-blue-200 transition-all no-underline px-4 py-2 rounded-xl" href="@dashboardUrl">
            <div class="w-6 h-6 rounded-full bg-[#00346f] text-white flex items-center justify-center text-[12px]">@userName?.Substring(0, 1)</div>
            Chào, @userName
        </a>
        <a href="/Home/LogoutPortal" class="inline-flex items-center text-red-500 hover:text-white hover:bg-red-500 px-3 py-2 rounded-xl transition-colors" title="Đăng xuất">
            <span class="material-symbols-outlined text-[20px]">logout</span>
        </a>
    </div>
}
else if (User.IsInRole("Admin"))
{
    <a class="hidden sm:inline-flex items-center gap-1.5 text-[15px] font-semibold text-[#475569] hover:text-[#2563eb] hover:bg-[#eff6ff] transition-all no-underline px-3 py-2 rounded-lg" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
        <span class="material-symbols-outlined text-[18px]">admin_panel_settings</span> Quản trị
    </a>
}
else
{
    <a class="hidden sm:inline-flex items-center gap-2 text-[15px] font-bold text-[#00346f] hover:text-white bg-blue-50 hover:bg-[#00346f] border border-blue-200 hover:border-[#00346f] transition-all no-underline px-4 py-2 rounded-xl shadow-sm" asp-area="" asp-controller="Home" asp-action="Login">
        <span class="material-symbols-outlined text-[20px]">login</span> Đăng nhập
    </a>
}

@if (SignInManager.IsSignedIn(User))
{
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" class="inline">
        <button type="submit" class="inline-flex items-center gap-1.5 text-[15px] font-semibold text-[#475569] hover:text-red-600 hover:bg-red-50 transition-all no-underline px-3 py-2 rounded-lg border-none bg-transparent cursor-pointer">
            <span class="material-symbols-outlined text-[18px]">logout</span> Đăng xuất
        </button>
    </form>
}

